# Naurra.ai Environment Configuration

# ==========================================
# Backend URL - Voice AI Backend
# ==========================================
# Local Development:
VITE_BACKEND_URL=http://localhost:3001

# Production (Railway/Your Backend):
# VITE_BACKEND_URL=https://your-backend-url.railway.app
# Set this in your Netlify environment variables!

# ==========================================
# Supabase Configuration
# ==========================================
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ==========================================
# MCP Server URL
# ==========================================
# Local Development:
VITE_MCP_SERVER_URL=http://localhost:3000

# Production:
# VITE_MCP_SERVER_URL=https://your-mcp-server-url.com
# Set this in your Netlify environment variables!

# ==========================================
# Stripe Configuration
# ==========================================
# Get these from: Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Note: Keep SECRET keys in backend only, never in frontend!
