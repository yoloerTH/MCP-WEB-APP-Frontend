---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { solutionPages } from '../../data/solutionPages'

const solutionsImage = '/solutions/custom-ai-solutions-og.png'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://naurra.ai/solutions/' }
  ]
}

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Custom AI Agent Solutions for Small Business',
  description: 'Custom AI agents for small business: CRM and quoting, invoicing, lead capture, customer support, scheduling, and proposals. Fixed-price builds from €2K, deployed in 3 to 6 weeks.',
  url: 'https://naurra.ai/solutions/',
  image: `https://naurra.ai${solutionsImage}`,
  primaryImageOfPage: `https://naurra.ai${solutionsImage}`,
  inLanguage: 'en-US',
  mainEntityOfPage: 'https://naurra.ai/solutions/',
  publisher: {
    '@type': 'Organization',
    name: 'Naurra.ai',
    url: 'https://naurra.ai/',
    logo: 'https://naurra.ai/logo-transparent.png'
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: solutionPages.map((solution, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `https://naurra.ai/solutions/${solution.slug}/`,
      name: solution.name
    }))
  }
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What kinds of custom AI solutions does Naurra.ai build?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The most requested builds are AI CRM and quoting agents, invoicing agents, lead capture agents, customer support agents, scheduling agents, and proposal agents. Each build is scoped around the client’s real workflow, systems, and edge cases.'
      }
    },
    {
      '@type': 'Question',
      name: 'When does a custom AI agent make more sense than off-the-shelf software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Custom AI makes the most sense when the workflow is tied directly to revenue, when pricing or process logic is specific to the business, when leads or work come in across multiple channels, or when generic SaaS tools create more manual work than they remove.'
      }
    },
    {
      '@type': 'Question',
      name: 'How much do Naurra.ai custom AI solutions cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most solutions on this page start from around €2,000, with fixed-price builds typically landing between €2,000 and €10,000 depending on the workflow depth, integrations, and level of automation.'
      }
    },
    {
      '@type': 'Question',
      name: 'How long does a custom AI build take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most projects are deployed in 3 to 6 weeks. Discovery happens first, then the core workflow is prototyped, integrations are connected, and the system is tuned against the real workflow before handoff.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can Naurra.ai integrate with our existing tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Naurra.ai custom solutions are built to work with existing tools and source-of-truth systems such as Gmail, Google Calendar, Google Sheets, Google Drive, WhatsApp, CRMs, databases, and other internal tools.'
      }
    }
  ]
}

const categoryBySlug: Record<string, string> = {
  'ai-agent-custom-crm-quoting-system-small-business': 'Sales / Revenue',
  'ai-agent-automate-invoicing-payment-reminders-small-business': 'Finance / Cashflow',
  'ai-agent-capture-qualify-leads-instagram-whatsapp-email-small-business': 'Marketing / Inbound',
  'ai-agent-handle-customer-support-emails-small-business': 'Customer / Retention',
  'ai-agent-schedule-confirm-client-appointments-small-business': 'Operations / Scheduling',
  'ai-agent-generate-proposals-statements-of-work-small-business': 'Sales / Proposals'
}

const featured = solutionPages[0]

const industries = [
  'Real estate', 'Legal', 'Construction', 'Health & wellness',
  'Agencies', 'Manufacturing', 'Hospitality', 'Logistics',
  'E-commerce', 'Hospitality'
]
---

<BaseLayout
  title="Custom AI Agent Solutions for Small Business | CRM, Quoting, Invoicing & More"
  description="Explore Naurra.ai custom AI solutions for small business: CRM and quoting, invoicing, lead capture, support, scheduling, and proposal workflows. Fixed-price builds from €2K, deployed in 3 to 6 weeks."
  keywords="custom ai agent solutions, custom ai solutions for small business, ai crm solution, ai invoicing solution, ai lead capture solution, ai support automation solution, ai scheduling solution, ai proposal agent, custom ai workflow automation"
  image={solutionsImage}
  imageAlt="Naurra.ai solutions page preview showing custom AI agents for small business"
  url="https://naurra.ai/solutions/"
  structuredData={[breadcrumbSchema, collectionSchema, faqSchema]}
>

<div class="min-h-screen bg-[#0a0e1a] text-white overflow-hidden" style="font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;">

  <!-- Background -->
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-amber-500/5"></div>
    <div class="absolute top-0 -right-1/4 w-[800px] h-[800px] bg-emerald-500/10 rounded-full blur-[120px] orb-float-a"></div>
    <div class="absolute bottom-0 -left-1/4 w-[800px] h-[800px] bg-amber-500/10 rounded-full blur-[120px] orb-float-b"></div>
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 56px 56px;"></div>
  </div>

  <!-- Nav -->
  <nav class="relative border-b border-emerald-500/10 bg-[#0a0e1a]/95 backdrop-blur-xl sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-10 h-10 flex items-center justify-center">
          <div class="absolute inset-0 bg-emerald-500/20 blur-xl rounded-full group-hover:bg-emerald-500/30 transition-all"></div>
          <img src="/logo-transparent.png" alt="Naurra.ai" class="w-full h-full object-contain relative z-10" />
        </div>
        <span style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em; font-size: 20px; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          Naurra.ai
        </span>
      </a>
      <div class="flex items-center gap-4 flex-wrap justify-end">
        <a href="/about/" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium hidden sm:inline">About</a>
        <a href="/blog/" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium hidden sm:inline">Blog</a>
        <a href="/contact/" class="text-sm font-semibold px-5 py-2 rounded-lg transition-all" style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #10b981;">Book a free call</a>
      </div>
    </div>
  </nav>

  <!-- ============== HERO ============== -->
  <section class="relative max-w-7xl mx-auto px-6 lg:px-8 pt-16 lg:pt-24 pb-12">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <div class="reveal inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-emerald-500/10 to-amber-500/10 border border-emerald-500/20 rounded-full mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
          </span>
          <span class="text-xs font-mono uppercase tracking-widest text-emerald-300">Custom AI agents, shipped end to end</span>
        </div>

        <h1 style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.045em;" class="reveal text-5xl lg:text-6xl xl:text-7xl leading-[0.95] tracking-tight mb-6">
          <span class="text-white">The AI agent your</span><br/>
          <span class="text-white">business actually needs,</span><br/>
          <span class="bg-gradient-to-r from-emerald-400 via-emerald-300 to-amber-400 bg-clip-text text-transparent gradient-shimmer">built around your workflow</span>
        </h1>

        <p class="reveal text-lg lg:text-xl text-gray-400 max-w-2xl leading-relaxed mb-8">
          Stop bending your business around generic SaaS. We design and ship a custom AI agent that knows your products, your pricing, your tone, and your edge cases. Fixed price. Deployed in 3 to 6 weeks. Engineers ship every project, not account managers.
        </p>

        <div class="reveal flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8">
          <a href="/contact/" class="group px-7 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl font-semibold text-base shadow-lg shadow-emerald-500/30 border border-emerald-400/30 text-white transition-all hover:shadow-xl hover:shadow-emerald-500/40 hover:-translate-y-0.5 inline-flex items-center gap-2">
            Book a free 30-min consultation
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="#solutions" class="text-gray-400 hover:text-white transition-colors font-medium inline-flex items-center gap-2">
            Browse the 6 most-requested builds
            <svg class="w-4 h-4 animate-bounce-slow" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
          </a>
        </div>

        <div class="reveal flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-gray-500 font-mono uppercase tracking-wider">
          <span class="flex items-center gap-2"><svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Fixed price</span>
          <span class="flex items-center gap-2"><svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Free discovery call</span>
          <span class="flex items-center gap-2"><svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>You own the code</span>
        </div>
      </div>

      <!-- Hero visual: stylized agent dashboard mock -->
      <div class="lg:col-span-5 relative reveal-scale">
        <div class="absolute -inset-6 rounded-3xl blur-3xl bg-gradient-to-br from-emerald-500/20 to-amber-500/20 animate-pulse-glow"></div>
        <div class="relative rounded-3xl overflow-hidden border border-white/10 bg-gradient-to-br from-gray-800/80 to-gray-900/80 backdrop-blur-xl shadow-2xl">
          <div class="flex items-center gap-2 px-5 py-3 border-b border-white/5">
            <span class="w-2.5 h-2.5 rounded-full bg-rose-500/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-400/70"></span>
            <span class="ml-3 text-[10px] font-mono uppercase tracking-widest text-gray-500">agent.naurra.ai</span>
            <span class="ml-auto flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-emerald-300">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>Live
            </span>
          </div>
          <div class="p-5 space-y-3">
            <div class="stagger-item flex items-center gap-3 p-3 rounded-xl bg-emerald-500/5 border border-emerald-500/15" style="--delay: 0.1s">
              <div class="w-8 h-8 rounded-lg bg-emerald-500/15 flex items-center justify-center text-emerald-300 text-xs font-bold">IN</div>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-emerald-300 font-mono uppercase tracking-wider">New WhatsApp lead</div>
                <div class="text-sm text-white truncate">Sarah from Acme Realty wants a quote</div>
              </div>
              <div class="text-[10px] font-mono text-gray-500">0:02s</div>
            </div>
            <div class="stagger-item flex items-center gap-3 p-3 rounded-xl bg-amber-500/5 border border-amber-500/15" style="--delay: 0.5s">
              <div class="w-8 h-8 rounded-lg bg-amber-500/15 flex items-center justify-center text-amber-300 text-xs font-bold">AI</div>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-amber-300 font-mono uppercase tracking-wider">Drafting branded quote</div>
                <div class="h-2 mt-1.5 rounded-full bg-white/5 overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-amber-400 to-emerald-400 progress-fill"></div>
                </div>
              </div>
            </div>
            <div class="stagger-item flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/5" style="--delay: 1.1s">
              <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-gray-400 text-xs font-bold">→</div>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-gray-400 font-mono uppercase tracking-wider">Logged in CRM</div>
                <div class="text-sm text-gray-300 truncate">Deal #1287 created · €3,400</div>
              </div>
              <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div class="stagger-item flex items-center gap-3 p-3 rounded-xl bg-white/[0.03] border border-white/5" style="--delay: 1.5s">
              <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-gray-400 text-xs font-bold">→</div>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-gray-400 font-mono uppercase tracking-wider">Calendar invite sent</div>
                <div class="text-sm text-gray-300 truncate">Tue 14:00 · Tour booked</div>
              </div>
              <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
          </div>
          <div class="px-5 py-3 border-t border-white/5 flex items-center justify-between">
            <span class="text-[10px] font-mono uppercase tracking-widest text-gray-500">End to end · 47 seconds</span>
            <span class="text-[10px] font-mono uppercase tracking-widest text-emerald-300">All hands-off</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== METRICS STRIP (animated counters) ============== -->
  <section class="relative max-w-7xl mx-auto px-6 lg:px-8 pb-16">
    <div class="reveal grid grid-cols-2 md:grid-cols-4 rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur overflow-hidden">
      <div class="px-6 py-6 border-b md:border-b-0 md:border-r border-white/5 group hover:bg-white/[0.02] transition-colors">
        <div class="text-3xl lg:text-4xl font-bold text-white" style="font-family: 'Sora', sans-serif; letter-spacing: -0.03em;">€<span class="counter" data-target="2">0</span>K<span class="text-emerald-400">+</span></div>
        <div class="text-xs text-gray-500 font-mono uppercase tracking-wider mt-1">Fixed-price builds from</div>
      </div>
      <div class="px-6 py-6 border-b md:border-b-0 md:border-r border-white/5 group hover:bg-white/[0.02] transition-colors">
        <div class="text-3xl lg:text-4xl font-bold text-white" style="font-family: 'Sora', sans-serif; letter-spacing: -0.03em;"><span class="counter" data-target="3">0</span><span class="text-gray-500">-</span><span class="counter" data-target="6">0</span> <span class="text-amber-400 text-xl">wks</span></div>
        <div class="text-xs text-gray-500 font-mono uppercase tracking-wider mt-1">Discovery to deployment</div>
      </div>
      <div class="px-6 py-6 md:border-r border-white/5 group hover:bg-white/[0.02] transition-colors">
        <div class="text-3xl lg:text-4xl font-bold text-white" style="font-family: 'Sora', sans-serif; letter-spacing: -0.03em;"><span class="counter" data-target="7">0</span><span class="text-emerald-400">.</span></div>
        <div class="text-xs text-gray-500 font-mono uppercase tracking-wider mt-1">Industries shipped for</div>
      </div>
      <div class="px-6 py-6 group hover:bg-white/[0.02] transition-colors">
        <div class="text-3xl lg:text-4xl font-bold text-white" style="font-family: 'Sora', sans-serif; letter-spacing: -0.03em;"><span class="counter" data-target="100">0</span><span class="text-amber-400">%</span></div>
        <div class="text-xs text-gray-500 font-mono uppercase tracking-wider mt-1">You own the code</div>
      </div>
    </div>
  </section>

  <!-- ============== IMPACT CHART (NOT a box grid) ============== -->
  <section class="relative max-w-7xl mx-auto px-6 lg:px-8 pb-24">
    <div class="grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-5 reveal">
        <div class="text-xs font-mono uppercase tracking-widest text-emerald-300 mb-3">/ Before / After</div>
        <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.03em;" class="text-3xl lg:text-5xl text-white leading-tight mb-5">
          The week your <span class="bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">team gets back</span>
        </h2>
        <p class="text-gray-400 leading-relaxed mb-6">
          Across the six builds on this page, the typical pattern is the same: hours of manual back-and-forth collapse into minutes. The chart shows the average shift in time spent per workflow, before vs after a custom build.
        </p>
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-sm">
            <span class="w-3 h-3 rounded-sm bg-gray-600"></span>
            <span class="text-gray-400">Before · manual hours / week</span>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <span class="w-3 h-3 rounded-sm bg-gradient-to-br from-emerald-400 to-amber-400"></span>
            <span class="text-gray-400">After · with custom AI agent</span>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 reveal">
        <div class="relative rounded-3xl border border-white/10 bg-gradient-to-br from-gray-800/40 to-gray-900/50 p-6 lg:p-8 overflow-hidden">
          <div class="absolute -top-32 -right-32 w-72 h-72 bg-emerald-500/15 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-32 -left-32 w-72 h-72 bg-amber-500/10 rounded-full blur-3xl"></div>

          <div class="relative">
            <div class="flex items-center justify-between mb-6">
              <div class="text-xs font-mono uppercase tracking-widest text-gray-500">Hours per week, per workflow</div>
              <div class="text-xs font-mono uppercase tracking-widest text-emerald-300">Typical client</div>
            </div>

            <div class="space-y-5">
              {[
                { label: 'CRM + Quoting', before: 14, after: 2 },
                { label: 'Invoicing', before: 8, after: 1 },
                { label: 'Lead capture', before: 10, after: 1 },
                { label: 'Customer support', before: 12, after: 3 },
                { label: 'Scheduling', before: 6, after: 1 },
                { label: 'Proposals', before: 9, after: 1 }
              ].map((row) => (
                <div>
                  <div class="flex items-center justify-between mb-1.5 text-xs">
                    <span class="text-gray-300 font-medium">{row.label}</span>
                    <span class="font-mono text-gray-500">
                      <span class="text-gray-500">{row.before}h</span>
                      <span class="mx-2 text-gray-700">→</span>
                      <span class="text-emerald-400 font-bold">{row.after}h</span>
                    </span>
                  </div>
                  <div class="relative h-7 rounded-md bg-white/[0.025] overflow-hidden">
                    <div class="absolute inset-y-0 left-0 bg-gray-700/50 rounded-md bar-grow" style={`--bar-w: ${row.before * 5}%`}></div>
                    <div class="absolute inset-y-0 left-0 bg-gradient-to-r from-emerald-500 to-amber-500 rounded-md bar-grow" style={`--bar-w: ${row.after * 5}%; --bar-delay: 0.4s`}></div>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-7 pt-6 border-t border-white/5 grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold text-white" style="font-family: 'Sora', sans-serif; letter-spacing: -0.02em;"><span class="counter" data-target="59">0</span>h</div>
                <div class="text-[10px] font-mono uppercase tracking-wider text-gray-500 mt-1">Before / week</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-white" style="font-family: 'Sora', sans-serif; letter-spacing: -0.02em;"><span class="counter" data-target="9">0</span>h</div>
                <div class="text-[10px] font-mono uppercase tracking-wider text-gray-500 mt-1">After / week</div>
              </div>
              <div>
                <div class="text-2xl font-bold bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent" style="font-family: 'Sora', sans-serif; letter-spacing: -0.02em;">−<span class="counter" data-target="85">0</span>%</div>
                <div class="text-[10px] font-mono uppercase tracking-wider text-gray-500 mt-1">Time reclaimed</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== FEATURED SOLUTION ============== -->
  <section class="relative max-w-7xl mx-auto px-6 lg:px-8 pb-24">
    <div class="flex items-end justify-between mb-8 gap-6 flex-wrap reveal">
      <div>
        <div class="text-xs font-mono uppercase tracking-widest text-emerald-300 mb-3">/ 01 · Featured solution</div>
        <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.03em;" class="text-3xl lg:text-5xl text-white leading-tight">
          The build that <span class="bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">pays for itself</span> in weeks
        </h2>
      </div>
      <a href={`/solutions/${featured.slug}/`} class="text-sm font-semibold text-emerald-400 hover:text-emerald-300 transition-colors inline-flex items-center gap-2 group whitespace-nowrap">
        Read the full breakdown
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>

    <div class="reveal-scale relative rounded-3xl overflow-hidden border border-emerald-500/20 bg-gradient-to-br from-emerald-500/[0.08] via-gray-900/60 to-amber-500/[0.05] gradient-border-glow">
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-emerald-500/20 rounded-full blur-3xl orb-float-a"></div>
