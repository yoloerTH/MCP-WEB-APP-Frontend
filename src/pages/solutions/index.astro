---
import BaseLayout from '../../layouts/BaseLayout.astro'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://naurra.ai/solutions/' }
  ]
}

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Custom AI Agent Solutions for Small Business',
  description: 'Custom AI agents for small business: CRM and quoting, invoicing, lead capture, customer support, scheduling, and proposals. Fixed-price builds, deployed in 3 to 6 weeks.',
  url: 'https://naurra.ai/solutions/',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, url: 'https://naurra.ai/solutions/ai-crm-quoting-agent/', name: 'AI CRM and Quoting Agent' }
    ]
  }
}

const solutions = [
  {
    title: 'AI CRM + Quoting Agent',
    summary: 'Replace spreadsheet CRMs and Word-template quoting. Inbound lead to branded quote in minutes.',
    href: '/solutions/ai-crm-quoting-agent/',
    pricing: '$6K - $15K',
    timeline: '4 - 6 weeks',
    badge: 'Most popular',
    status: 'live',
    accent: 'emerald'
  },
  {
    title: 'AI Invoicing Agent',
    summary: 'Issue invoices, chase unpaid balances, reconcile payments. Get back a full day every month.',
    href: '/blog/ai-agent-automate-invoicing-payment-reminders-small-business/',
    pricing: '$4.5K - $11K',
    timeline: '3 - 5 weeks',
    badge: 'Coming soon',
    status: 'coming',
    accent: 'amber'
  },
  {
    title: 'AI Lead Capture Agent',
    summary: 'Listen to Instagram, WhatsApp, email, and forms. Qualify leads, reply in your tone, route to sales.',
    href: '/blog/ai-agent-capture-qualify-leads-instagram-whatsapp-email-small-business/',
    pricing: '$5K - $13K',
    timeline: '4 - 6 weeks',
    badge: 'Coming soon',
    status: 'coming',
    accent: 'cyan'
  },
  {
    title: 'AI Customer Support Agent',
    summary: 'Triage every support email, draft replies in your voice, auto-resolve the simple ones, escalate the rest.',
    href: '/blog/ai-agent-handle-customer-support-emails-small-business/',
    pricing: '$4K - $11K',
    timeline: '3 - 5 weeks',
    badge: 'Coming soon',
    status: 'coming',
    accent: 'violet'
  },
  {
    title: 'AI Scheduling Agent',
    summary: 'Book appointments over WhatsApp and email, send confirmations, reduce no-shows automatically.',
    href: '/blog/ai-agent-schedule-confirm-client-appointments-small-business/',
    pricing: '$4K - $9K',
    timeline: '3 - 5 weeks',
    badge: 'Coming soon',
    status: 'coming',
    accent: 'sky'
  },
  {
    title: 'AI Proposal Agent',
    summary: 'Read the brief, search past wins, draft scope and pricing in your voice, output a branded PDF.',
    href: '/blog/ai-agent-generate-proposals-statements-of-work-small-business/',
    pricing: '$5K - $13K',
    timeline: '4 - 6 weeks',
    badge: 'Coming soon',
    status: 'coming',
    accent: 'rose'
  }
]

const accentMap: Record<string, { dot: string; bg: string; border: string }> = {
  emerald: { dot: 'bg-emerald-400', bg: 'bg-emerald-500/10', border: 'border-emerald-500/20' },
  amber: { dot: 'bg-amber-400', bg: 'bg-amber-500/10', border: 'border-amber-500/20' },
  cyan: { dot: 'bg-cyan-400', bg: 'bg-cyan-500/10', border: 'border-cyan-500/20' },
  violet: { dot: 'bg-violet-400', bg: 'bg-violet-500/10', border: 'border-violet-500/20' },
  sky: { dot: 'bg-sky-400', bg: 'bg-sky-500/10', border: 'border-sky-500/20' },
  rose: { dot: 'bg-rose-400', bg: 'bg-rose-500/10', border: 'border-rose-500/20' }
}
---

<BaseLayout
  title="Custom AI Agent Solution Types for Small Business — Naurra.ai"
  description="Browse Naurra.ai solution types for small business: AI CRM and quoting, invoicing, lead capture, support, scheduling, and proposal workflows. Fixed-price builds grouped by use case and business outcome."
  keywords="custom ai agent solutions, ai automation solutions for small business, ai crm solution, ai invoicing solution, ai lead capture solution, ai support automation solution, ai scheduling solution"
  url="https://naurra.ai/solutions/"
  structuredData={[breadcrumbSchema, collectionSchema]}
>

<div class="min-h-screen bg-[#0a0e1a] text-white overflow-hidden" style="font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;">

  <!-- Background Orbs -->
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-amber-500/5"></div>
    <div class="absolute top-0 -right-1/4 w-[800px] h-[800px] bg-emerald-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 -left-1/4 w-[800px] h-[800px] bg-amber-500/10 rounded-full blur-[120px]"></div>
  </div>

  <!-- Nav -->
  <nav class="relative border-b border-emerald-500/10 bg-[#0a0e1a]/95 backdrop-blur-xl sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-10 h-10 flex items-center justify-center">
          <div class="absolute inset-0 bg-emerald-500/20 blur-xl rounded-full group-hover:bg-emerald-500/30 transition-all"></div>
          <img src="/logo-transparent.png" alt="Naurra.ai" class="w-full h-full object-contain relative z-10" />
        </div>
        <span style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em; font-size: 20px; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          Naurra.ai
        </span>
      </a>
      <div class="flex items-center gap-4 flex-wrap justify-end">
        <a href="/company/" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium">Case Studies</a>
        <a href="/blog/" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium">Blog</a>
        <a href="/contact/" class="text-sm font-semibold px-5 py-2 rounded-lg transition-all" style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #10b981;">Book a free call</a>
      </div>
    </div>
  </nav>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-24">

    <!-- Hero -->
    <div class="text-center mb-20 fade-in">
      <div class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-emerald-500/10 to-amber-500/10 border border-emerald-500/20 rounded-full mb-6">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="text-xs font-mono uppercase tracking-widest text-emerald-300">Solutions</span>
      </div>

      <h1 style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em;" class="text-5xl lg:text-6xl xl:text-7xl leading-[0.95] tracking-tight mb-6">
        <span class="text-white">Custom AI Agents</span><br/>
        <span class="bg-gradient-to-r from-emerald-400 via-emerald-300 to-amber-400 bg-clip-text text-transparent">for Small Business</span>
      </h1>

      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-8">
        Fixed-price builds. Deployed in 3 to 6 weeks. Built around your exact workflow, not a SaaS template. Engineers ship every project, not account managers.
      </p>

      <div class="flex flex-wrap gap-3 justify-center mb-10">
        <span class="px-4 py-2 rounded-full text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">From $4K</span>
        <span class="px-4 py-2 rounded-full text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">3 to 6 weeks</span>
        <span class="px-4 py-2 rounded-full text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">Fixed price</span>
        <span class="px-4 py-2 rounded-full text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">Free consultation</span>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact/" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl font-semibold text-lg shadow-lg shadow-emerald-500/30 border border-emerald-400/30 text-white transition-all hover:shadow-xl hover:shadow-emerald-500/40">
          Book a free consultation
        </a>
        <a href="/company/" class="px-8 py-4 bg-white/5 border border-white/10 rounded-xl text-gray-400 hover:bg-white/10 hover:text-white transition-all font-medium">
          See case studies
        </a>
      </div>
    </div>

    <!-- Solutions Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-24">
      {solutions.map((sol) => {
        const accent = accentMap[sol.accent]
        return (
          <a href={sol.href} class={`group relative block h-full ${sol.status === 'coming' ? 'opacity-80' : ''}`}>
            <div class="h-full bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl overflow-hidden hover:border-emerald-500/30 transition-all duration-300 p-7 flex flex-col">
              <div class="flex items-center justify-between mb-5">
                <span class={`inline-flex items-center gap-2 px-2.5 py-1 ${accent.bg} ${accent.border} border rounded-lg`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${accent.dot}`}></span>
                  <span class="text-xs font-mono text-gray-300">{sol.pricing}</span>
                </span>
                {sol.badge && (
                  <span class={`px-2.5 py-1 rounded-full text-xs font-bold ${sol.status === 'live' ? 'bg-gradient-to-r from-emerald-500 to-emerald-600 text-white' : 'bg-white/5 text-gray-400 border border-white/10'}`}>
                    {sol.badge}
                  </span>
                )}
              </div>

              <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-xl text-white mb-3 group-hover:text-emerald-300 transition-colors">
                {sol.title}
              </h2>
              <p class="text-sm text-gray-400 leading-relaxed mb-5 flex-1">
                {sol.summary}
              </p>

              <div class="flex items-center justify-between pt-4 border-t border-white/5">
                <span class="text-xs text-gray-500">Timeline: <span class="text-gray-300 font-mono">{sol.timeline}</span></span>
                <div class="flex items-center gap-1.5 text-emerald-400 text-sm font-semibold">
                  <span>{sol.status === 'live' ? 'See solution' : 'Read approach'}</span>
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </div>

              <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-emerald-500 to-amber-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
            </div>
          </a>
        )
      })}
    </div>

    <!-- How it works -->
    <div class="mb-24">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-1 h-8 bg-gradient-to-b from-emerald-500 to-amber-500 rounded-full"></div>
        <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-3xl text-white">How a build works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">01 / DISCOVERY</div>
          <h3 class="text-lg text-white font-semibold mb-2">Week 1</h3>
          <p class="text-sm text-gray-400 leading-relaxed">We map your actual workflow, edge cases, and source-of-truth systems. Output: a fixed-price proposal with no scope creep.</p>
        </div>
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">02 / CORE BUILD</div>
          <h3 class="text-lg text-white font-semibold mb-2">Weeks 2 - 3</h3>
          <p class="text-sm text-gray-400 leading-relaxed">The agent's core logic goes into a working prototype. You see a real demo at the end of each week, not at the end of the project.</p>
        </div>
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">03 / INTEGRATIONS</div>
          <h3 class="text-lg text-white font-semibold mb-2">Weeks 3 - 5</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Integrations into your existing stack (Gmail, Calendar, Sheets, WhatsApp, your CRM, your DB) and the dashboard get wired up.</p>
        </div>
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">04 / DEPLOY</div>
          <h3 class="text-lg text-white font-semibold mb-2">Week 5 - 6</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Goes live against your real workflow. We watch every output for the first two weeks and tune until you are confident running unattended.</p>
        </div>
      </div>
    </div>

    <!-- SEO Content Section -->
    <div class="max-w-3xl mx-auto mb-20" style="color: rgba(255,255,255,0.64); font-size: 16px; line-height: 1.8;">
      <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-2xl text-white mb-6">Why custom over off-the-shelf</h2>
      <p class="mb-4">
        Most small businesses do not need another SaaS subscription. They need software that works the way <em>their</em> business actually works. A custom <strong style="color: #f1f5f9; font-weight: 700;">AI agent</strong> is built around your exact products, your real pricing rules, your tone of voice, and your edge cases. The 200 features you would never use are not in it.
      </p>
      <p class="mb-4">
        For workflows where you do less than ten of something a month, off-the-shelf tools usually win. For workflows where the cost of slow or sloppy execution is real revenue, the math almost always favors a custom build. We help you figure out which side you are on before writing a single line of code.
      </p>
      <p>
        Read the full breakdown in our guide on <a href="/blog/custom-ai-agents-vs-off-the-shelf-ai-which-one-does-your-business-need/" style="color: #10b981; text-decoration: none; font-weight: 600;">custom vs off-the-shelf AI</a>, see real <a href="/company/" style="color: #10b981; text-decoration: none; font-weight: 600;">case studies across 7 industries</a>, or jump into the <a href="/blog/how-much-do-custom-ai-agents-cost-real-pricing-ranges-for-small-business/" style="color: #10b981; text-decoration: none; font-weight: 600;">honest pricing breakdown</a>.
      </p>
    </div>

    <!-- CTA -->
    <div class="bg-gradient-to-br from-gray-800/60 to-gray-900/60 border border-gray-700/50 rounded-3xl p-12 lg:p-16 text-center">
      <h2 style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em;" class="text-3xl lg:text-4xl text-white mb-4">
        Ready to scope a build?
      </h2>
      <p class="text-lg text-gray-400 max-w-xl mx-auto mb-8">
        Book a free 30-minute consultation. We will give you an honest read on whether a custom AI agent makes sense for your workflow, and a fixed-price proposal within 48 hours if it does.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact/" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl font-semibold text-lg shadow-lg shadow-emerald-500/30 border border-emerald-400/30 text-white transition-all hover:shadow-xl hover:shadow-emerald-500/40">
          Book a free consultation
        </a>
        <a href="/company/" class="px-8 py-4 bg-white/5 border border-white/10 rounded-xl text-gray-400 hover:bg-white/10 hover:text-white transition-all font-medium">
          See case studies
        </a>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="relative border-t border-gray-700/50 bg-[#0a0e1a] mt-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-gray-500 text-sm">&copy; 2026 Naurra.ai. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="/privacy/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Privacy</a>
        <a href="/terms/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Terms</a>
        <a href="/blog/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Blog</a>
        <a href="/contact/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Contact</a>
      </div>
    </div>
  </footer>
</div>

</BaseLayout>
