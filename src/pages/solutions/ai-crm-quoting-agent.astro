---
import BaseLayout from '../../layouts/BaseLayout.astro'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://naurra.ai/solutions/' },
    { '@type': 'ListItem', position: 3, name: 'AI CRM and Quoting Agent', item: 'https://naurra.ai/solutions/ai-crm-quoting-agent/' }
  ]
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Custom AI Agent Development',
  name: 'Custom AI CRM and Quoting Agent for Small Business',
  description: 'A custom AI agent that captures inbound leads, drafts branded quotes from your real pricing, and runs a lightweight CRM for your sales team. Fixed-price build, deployed in 4 to 6 weeks.',
  url: 'https://naurra.ai/solutions/ai-crm-quoting-agent/',
  provider: {
    '@type': 'ProfessionalService',
    name: 'Naurra.ai',
    url: 'https://naurra.ai/',
    logo: 'https://naurra.ai/logo-transparent.png',
    founder: {
      '@type': 'Person',
      name: 'Athanasios-Ioannis Panagiotakopoulos',
      jobTitle: 'CEO and AI Engineer'
    }
  },
  areaServed: 'Worldwide',
  audience: { '@type': 'BusinessAudience', audienceType: 'Small Business' },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: '6000',
    highPrice: '15000',
    availability: 'https://schema.org/InStock',
    eligibleQuantity: { '@type': 'QuantitativeValue', value: '1' }
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    bestRating: '5',
    ratingCount: '7'
  },
  review: {
    '@type': 'Review',
    author: { '@type': 'Person', name: 'Automotive Reseller Client' },
    reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
    reviewBody: 'Thanos helped me set up automation for my automotive business and it completely changed the game for me. Since implementing it we have been averaging around $15K profit every two weeks.'
  }
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What does a custom AI CRM and quoting agent cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical small business build lands between $6,000 and $15,000 as a fixed-price engagement. Ongoing AI and hosting costs after launch are usually $100 to $375 per month depending on volume. Every project is scoped individually with a free consultation and a detailed proposal within 48 hours.'
      }
    },
    {
      '@type': 'Question',
      name: 'How long does the build take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most small business CRM and quoting agents are deployed in 4 to 6 weeks. Discovery is week one, the core build runs weeks two and three, integrations and the CRM layer go in weeks four and five, and we ship to your real workflow in week six. More complex pipelines (multi-product, multi-currency, complex discount rules) extend to 8 weeks.'
      }
    },
    {
      '@type': 'Question',
      name: 'How is this different from HubSpot, Pipedrive, or Zoho?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Off-the-shelf CRMs handle pipeline tracking well but do not handle the quoting logic specific to your business. You still write quotes manually or in a clunky quote plugin. A custom AI agent is built around your exact products, your real pricing rules, your tone of voice, and your sales process. It generates the quote, sends it, and follows up automatically.'
      }
    },
    {
      '@type': 'Question',
      name: 'Where does the agent get pricing and inventory from?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'From whatever source of truth you already have: a Google Sheet, an Airtable, a custom database, or an existing ERP. We do not move your data. The agent reads from your system, applies your margin rules, and drafts the quote. If your pricing currently lives in five places, we help consolidate before building.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can the agent send quotes without human review?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'It can, but we recommend a human review loop for the first 50 to 100 quotes the agent generates. After that you can choose to fully automate, keep a one-click approval step, or send unattended below a certain deal size. The choice is configurable per workflow.'
      }
    },
    {
      '@type': 'Question',
      name: 'What channels does the agent listen to?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Gmail, Outlook, contact forms, WhatsApp Business, Instagram DMs, and Telegram are the most common. We have also built voice-call lead capture for businesses where leads come in over the phone. The list of channels is part of the discovery scope.'
      }
    },
    {
      '@type': 'Question',
      name: 'Do you offer ongoing support after deployment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. We offer ongoing support and optimization packages. AI systems improve over time with fine-tuning and monitoring, and we partner with you long-term to make sure the agent keeps pace with your products, pricing, and tone as the business evolves.'
      }
    }
  ]
}

const capabilities = [
  { title: 'Captures every inbound lead', body: 'Listens across Gmail, web forms, WhatsApp, Instagram DMs, and Telegram. Extracts the real fields (name, company, product, quantity, urgency) using an LLM, not a rigid form.' },
  { title: 'Pulls your real pricing', body: 'Reads from your sheet, Airtable, ERP, or custom DB. Applies your margin rules and your discount logic. Your pricing stays yours.' },
  { title: 'Drafts the quote in your voice', body: 'Branded PDF or doc, your tone, your terms, your signature, your attachments. Written like the last 50 quotes you sent and won.' },
  { title: 'Logs everything in a custom CRM', body: 'One pipeline view of every lead, every quote, every status. No spreadsheet. No HubSpot fees. Built for your sales process exactly.' },
  { title: 'Follows up automatically', body: 'Schedule you approve. Tone calibrated to the relationship. No more forgotten leads, no more awkward chasing emails.' },
  { title: 'Reports what is actually happening', body: 'Win rate, average deal size, time to quote, by source. Real data on your pipeline for the first time.' }
]
---

<BaseLayout
  title="Custom AI CRM + Quoting Agent for Small Business — Built in 4 to 6 Weeks"
  description="Get a custom AI agent that captures leads, drafts branded quotes from your real pricing, and runs your CRM. Fixed-price $6K to $15K, deployed in 4 to 6 weeks. Free consultation."
  keywords="ai crm quoting agent small business, custom ai crm small business, ai quoting system small business, ai sales agent small business, custom crm and quoting ai, ai agent for crm and quoting, ai agent quote generator small business, build ai crm small business, custom ai sales agent, ai crm small business pricing"
  url="https://naurra.ai/solutions/ai-crm-quoting-agent/"
  structuredData={[breadcrumbSchema, serviceSchema, faqSchema]}
>

<div class="min-h-screen bg-[#0a0e1a] text-white overflow-hidden" style="font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;">

  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-amber-500/5"></div>
    <div class="absolute top-0 -right-1/4 w-[800px] h-[800px] bg-emerald-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 -left-1/4 w-[800px] h-[800px] bg-amber-500/10 rounded-full blur-[120px]"></div>
  </div>

  <!-- Nav -->
  <nav class="relative border-b border-emerald-500/10 bg-[#0a0e1a]/95 backdrop-blur-xl sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-10 h-10 flex items-center justify-center">
          <div class="absolute inset-0 bg-emerald-500/20 blur-xl rounded-full group-hover:bg-emerald-500/30 transition-all"></div>
          <img src="/logo-transparent.png" alt="Naurra.ai" class="w-full h-full object-contain relative z-10" />
        </div>
        <span style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em; font-size: 20px; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          Naurra.ai
        </span>
      </a>
      <div class="flex items-center gap-4 flex-wrap justify-end">
        <a href="/solutions/" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium">Solutions</a>
        <a href="/company/" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium">Case Studies</a>
        <a href="/blog/" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium">Blog</a>
        <a href="/contact/" class="text-sm font-semibold px-5 py-2 rounded-lg transition-all" style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #10b981;">Book a free call</a>
      </div>
    </div>
  </nav>

  <!-- Breadcrumbs -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 pt-8">
    <nav class="text-xs text-gray-500 font-mono uppercase tracking-wider" aria-label="Breadcrumb">
      <a href="/" class="hover:text-emerald-400 transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/solutions/" class="hover:text-emerald-400 transition-colors">Solutions</a>
      <span class="mx-2">/</span>
      <span class="text-gray-300">AI CRM and Quoting Agent</span>
    </nav>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-12 lg:py-16">

    <!-- Hero -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-24 items-center">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-emerald-500/10 to-amber-500/10 border border-emerald-500/20 rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-xs font-mono uppercase tracking-widest text-emerald-300">Most popular solution</span>
        </div>

        <h1 style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em;" class="text-5xl lg:text-6xl leading-[0.95] tracking-tight mb-6">
          <span class="text-white">Custom AI</span><br/>
          <span class="bg-gradient-to-r from-emerald-400 via-emerald-300 to-amber-400 bg-clip-text text-transparent">CRM + Quoting Agent</span>
        </h1>

        <p class="text-xl text-gray-400 leading-relaxed mb-8">
          A custom AI agent that captures every inbound lead, drafts a branded quote from your real pricing in minutes, and runs a lightweight CRM your sales team will actually open. Built around your exact products and process. Fixed price, deployed in 4 to 6 weeks.
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          <span class="px-4 py-2 rounded-full text-sm font-mono" style="background: rgba(16,185,129,0.10); border: 1px solid rgba(16,185,129,0.20); color: #6ee7b7;">$6K - $15K fixed</span>
          <span class="px-4 py-2 rounded-full text-sm font-mono" style="background: rgba(245,158,11,0.10); border: 1px solid rgba(245,158,11,0.20); color: #fcd34d;">4 - 6 weeks</span>
          <span class="px-4 py-2 rounded-full text-sm font-mono" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">$100 - $375/mo running</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl font-semibold text-lg shadow-lg shadow-emerald-500/30 border border-emerald-400/30 text-white transition-all hover:shadow-xl hover:shadow-emerald-500/40 text-center">
            Book a free consultation
          </a>
          <a href="#how-it-works" class="px-8 py-4 bg-white/5 border border-white/10 rounded-xl text-gray-400 hover:bg-white/10 hover:text-white transition-all font-medium text-center">
            See how it works
          </a>
        </div>
      </div>

      <!-- Proof card -->
      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-br from-emerald-500/10 via-transparent to-amber-500/10 rounded-3xl blur-2xl"></div>
        <div class="relative bg-gradient-to-br from-gray-800/70 to-gray-900/70 border border-gray-700/50 rounded-3xl p-8">
          <div class="text-xs font-mono text-emerald-400 uppercase tracking-widest mb-4">Real client outcome</div>
          <p style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.03em;" class="text-3xl lg:text-4xl text-white leading-tight mb-6">
            <span class="bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">~$15K profit</span> every two weeks
          </p>
          <p class="text-gray-400 leading-relaxed mb-6">
            "Thanos helped me set up automation for my automotive business and it completely changed the game for me. Since implementing it we have been averaging around $15K profit every two weeks. If anyone is looking to automate parts of their business, he really knows what he is doing."
          </p>
          <div class="flex items-center justify-between pt-6 border-t border-white/5">
            <div>
              <div class="text-sm text-white font-semibold">Automotive Reseller</div>
              <div class="text-xs text-gray-500">Custom AI quoting + CRM agent</div>
            </div>
            <a href="/company/" class="text-sm text-emerald-400 hover:text-emerald-300 font-semibold flex items-center gap-1">
              Read case study
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Problem framing -->
    <div class="max-w-3xl mx-auto mb-24" style="color: rgba(255,255,255,0.74); font-size: 17px; line-height: 1.8;">
      <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-3xl lg:text-4xl text-white mb-6">If this sounds familiar, this is for you</h2>
      <p class="mb-4">
        Leads come in across email, web forms, WhatsApp, and Instagram. Someone copies the details into a spreadsheet, sometimes. Quotes get written in Google Docs from a template, with prices looked up in a separate sheet. Follow-up is sporadic. Win rate is unknown.
      </p>
      <p class="mb-4">
        The cost is invisible because it shows up in 30-second slices: a forgotten DM, a quote that takes a day to send, a price that gets entered wrong, a lead that never gets followed up on. Across a year it adds up to tens of thousands in lost revenue and a sales process the team quietly hates.
      </p>
      <p>
        A custom AI CRM and quoting agent removes that friction completely. Lead in, quote out, pipeline updated, follow-up scheduled. Built around exactly how your business sells, not how a SaaS thinks you should.
      </p>
    </div>

    <!-- Capabilities -->
    <div class="mb-24">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-1 h-8 bg-gradient-to-b from-emerald-500 to-amber-500 rounded-full"></div>
        <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-3xl text-white">What the agent actually does</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {capabilities.map((cap, i) => (
          <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
            <div class="text-xs font-mono text-emerald-400 mb-3">{String(i + 1).padStart(2, '0')}</div>
            <h3 style="font-family: 'Sora', sans-serif; font-weight: 700;" class="text-lg text-white mb-2 leading-tight">{cap.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{cap.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- How it works -->
    <div class="mb-24" id="how-it-works">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-1 h-8 bg-gradient-to-b from-emerald-500 to-amber-500 rounded-full"></div>
        <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-3xl text-white">How the build works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">WEEK 1</div>
          <h3 class="text-lg text-white font-semibold mb-2">Discovery</h3>
          <p class="text-sm text-gray-400 leading-relaxed">We map every channel leads come from, where pricing lives, your tone, your edge cases. Output: a fixed-price proposal.</p>
        </div>
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">WEEKS 2 - 3</div>
          <h3 class="text-lg text-white font-semibold mb-2">Core build</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Lead capture, pricing logic, and quote generation go into a working prototype. You see a real demo at the end of each week.</p>
        </div>
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">WEEKS 4 - 5</div>
          <h3 class="text-lg text-white font-semibold mb-2">CRM and integrations</h3>
          <p class="text-sm text-gray-400 leading-relaxed">The lightweight CRM, the follow-up logic, and integrations with Gmail, Calendar, Sheets, WhatsApp, and your existing tools get wired up.</p>
        </div>
        <div class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6">
          <div class="text-xs font-mono text-emerald-400 mb-3">WEEK 6</div>
          <h3 class="text-lg text-white font-semibold mb-2">Deploy + tune</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Goes live against your real inbox. We watch every quote for the first two weeks and tune tone and pricing rules until you are confident.</p>
        </div>
      </div>
    </div>

    <!-- Build vs buy -->
    <div class="mb-24">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-1 h-8 bg-gradient-to-b from-emerald-500 to-amber-500 rounded-full"></div>
        <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-3xl text-white">Custom build vs SaaS CRM</h2>
      </div>
      <div class="overflow-x-auto rounded-2xl border border-gray-700/50">
        <table class="w-full text-left">
          <thead class="bg-white/5 text-xs font-mono uppercase tracking-wider text-gray-400">
            <tr>
              <th class="px-6 py-4 font-semibold"></th>
              <th class="px-6 py-4 font-semibold">Spreadsheet + Docs</th>
              <th class="px-6 py-4 font-semibold">HubSpot / Pipedrive</th>
              <th class="px-6 py-4 font-semibold text-emerald-300">Custom AI Agent</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700/50 text-sm">
            <tr class="hover:bg-white/[0.02]"><td class="px-6 py-4 text-gray-300 font-medium">Cost (Year 1)</td><td class="px-6 py-4 text-gray-500">Free + lost revenue</td><td class="px-6 py-4 text-gray-500">$3K - $18K subscription</td><td class="px-6 py-4 text-emerald-300">$7K - $19K all-in</td></tr>
            <tr class="hover:bg-white/[0.02]"><td class="px-6 py-4 text-gray-300 font-medium">Quote drafting</td><td class="px-6 py-4 text-gray-500">Manual</td><td class="px-6 py-4 text-gray-500">Templated, manual edit</td><td class="px-6 py-4 text-emerald-300">Auto, in your voice</td></tr>
            <tr class="hover:bg-white/[0.02]"><td class="px-6 py-4 text-gray-300 font-medium">Pricing logic</td><td class="px-6 py-4 text-gray-500">In someone's head</td><td class="px-6 py-4 text-gray-500">Limited</td><td class="px-6 py-4 text-emerald-300">Yours, encoded</td></tr>
            <tr class="hover:bg-white/[0.02]"><td class="px-6 py-4 text-gray-300 font-medium">Inbound channels</td><td class="px-6 py-4 text-gray-500">Manual triage</td><td class="px-6 py-4 text-gray-500">Email + form</td><td class="px-6 py-4 text-emerald-300">Email, WhatsApp, IG, forms</td></tr>
            <tr class="hover:bg-white/[0.02]"><td class="px-6 py-4 text-gray-300 font-medium">Follow-up</td><td class="px-6 py-4 text-gray-500">Sporadic</td><td class="px-6 py-4 text-gray-500">Reminders only</td><td class="px-6 py-4 text-emerald-300">Auto, tone-calibrated</td></tr>
            <tr class="hover:bg-white/[0.02]"><td class="px-6 py-4 text-gray-300 font-medium">Time to first quote</td><td class="px-6 py-4 text-gray-500">Hours to a day</td><td class="px-6 py-4 text-gray-500">15 - 30 minutes</td><td class="px-6 py-4 text-emerald-300">Under 10 minutes</td></tr>
            <tr class="hover:bg-white/[0.02]"><td class="px-6 py-4 text-gray-300 font-medium">Built around your process</td><td class="px-6 py-4 text-gray-500">Yes, but lossy</td><td class="px-6 py-4 text-gray-500">No</td><td class="px-6 py-4 text-emerald-300">Yes, exactly</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-gray-500 mt-4">Read the full breakdown in our <a href="/blog/custom-ai-agents-vs-off-the-shelf-ai-which-one-does-your-business-need/" class="text-emerald-400 hover:text-emerald-300 font-semibold">custom vs off-the-shelf AI guide</a>.</p>
    </div>

    <!-- When it pays off / when it doesn't -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-24">
      <div class="bg-gradient-to-br from-emerald-500/[0.06] to-emerald-500/[0.02] border border-emerald-500/20 rounded-2xl p-7">
        <h3 style="font-family: 'Sora', sans-serif; font-weight: 700;" class="text-xl text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          When the math works
        </h3>
        <ul class="space-y-2.5 text-sm text-gray-300 leading-relaxed">
          <li class="flex gap-2"><span class="text-emerald-400 mt-0.5">+</span><span>You send more than 20 quotes per month</span></li>
          <li class="flex gap-2"><span class="text-emerald-400 mt-0.5">+</span><span>Pricing involves real logic (variants, volume discounts, region rules)</span></li>
          <li class="flex gap-2"><span class="text-emerald-400 mt-0.5">+</span><span>You lose measurable revenue to slow or missed quotes</span></li>
          <li class="flex gap-2"><span class="text-emerald-400 mt-0.5">+</span><span>Multiple people are involved in the quoting workflow</span></li>
          <li class="flex gap-2"><span class="text-emerald-400 mt-0.5">+</span><span>Leads come in across more than one channel</span></li>
        </ul>
      </div>
      <div class="bg-gradient-to-br from-amber-500/[0.06] to-amber-500/[0.02] border border-amber-500/20 rounded-2xl p-7">
        <h3 style="font-family: 'Sora', sans-serif; font-weight: 700;" class="text-xl text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
          When it does not
        </h3>
