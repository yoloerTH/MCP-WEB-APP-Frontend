---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { blogPosts, type BlogPost } from '../../../data/blogPosts'
import { blogPostsEl, mergeWithEnglish } from '../../../data/blogPostsEl'
import { UI_STRINGS, formatDate } from '../../../lib/i18n'

const t = UI_STRINGS.el

const localizedPosts: BlogPost[] = blogPostsEl
  .map((tr) => {
    const en = blogPosts.find((p) => p.slug === tr.enSlug)
    return en ? mergeWithEnglish(en, tr) : null
  })
  .filter((p): p is BlogPost => p !== null)
  .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime())

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.home, item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: t.blog, item: 'https://naurra.ai/el/blog/' }
  ]
}

const blogCollectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Naurra.ai Blog (Ελληνικά)',
  description: t.blogDescription,
  url: 'https://naurra.ai/el/blog/',
  inLanguage: 'el-GR',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: localizedPosts.slice(0, 20).map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `https://naurra.ai/el/blog/${post.slug}/`,
      name: post.title
    }))
  }
}
---

<BaseLayout
  title={t.blogTitle}
  description={t.blogDescription}
  keywords={t.blogKeywords}
  url="https://naurra.ai/el/blog/"
  lang="el"
  alternates={[
    { hreflang: 'en', href: 'https://naurra.ai/blog/' },
    { hreflang: 'x-default', href: 'https://naurra.ai/blog/' },
    { hreflang: 'el', href: 'https://naurra.ai/el/blog/' }
  ]}
  structuredData={[breadcrumbSchema, blogCollectionSchema]}
>
  <div class="min-h-screen bg-[#0a0e1a] text-white overflow-hidden">

    <div class="fixed inset-0 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-amber-500/5"></div>
      <div class="absolute top-0 -right-1/4 w-[800px] h-[800px] bg-emerald-500/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 -left-1/4 w-[800px] h-[800px] bg-amber-500/10 rounded-full blur-[120px]"></div>
    </div>

    <nav class="relative border-b border-emerald-500/10 bg-[#0a0e1a]/95 sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div class="relative w-10 h-10 flex items-center justify-center">
            <div class="absolute inset-0 bg-emerald-500/20 blur-xl rounded-full group-hover:bg-emerald-500/30 transition-all"></div>
            <img src="/logo-transparent.png" alt="Naurra.ai" class="w-full h-full object-contain relative z-10" />
          </div>
          <span class="font-display text-xl tracking-tight bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">
            Naurra.ai
          </span>
        </a>
        <div class="flex items-center gap-4">
          <div class="relative" data-lang-switcher>
            <button type="button" data-lang-toggle class="text-sm text-gray-300 hover:text-emerald-200 transition-colors flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-white/10 hover:border-emerald-500/30 bg-white/5">
              <span aria-hidden="true">🇬🇷</span>
              <span>EL</span>
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div data-lang-menu class="hidden absolute right-0 mt-2 w-44 bg-[#0f172a] border border-white/10 rounded-xl shadow-xl overflow-hidden z-50">
              <a href="/blog/" hreflang="en" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-300 hover:text-white hover:bg-white/5">
                <span aria-hidden="true">🇬🇧</span><span>English</span>
              </a>
              <a href="/el/blog/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-emerald-300 bg-emerald-500/5">
                <span aria-hidden="true">🇬🇷</span><span>Ελληνικά</span>
              </a>
            </div>
          </div>
          <a href="/contact/" class="text-sm text-amber-400 hover:text-amber-300 transition-colors font-semibold">
            {t.contact}
          </a>
        </div>
      </div>
    </nav>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-24">

      <div class="mb-16 text-center fade-in">
        <div class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-emerald-500/10 to-amber-500/10 border border-emerald-500/20 rounded-full mb-8">
          <span class="text-sm font-mono uppercase tracking-widest text-emerald-300">Naurra Blog</span>
        </div>
        <h1 class="font-display text-5xl lg:text-7xl text-white mb-6 leading-tight tracking-tight">
          AI για το Google Workspace
        </h1>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
          Πρακτικοί οδηγοί, στρατηγικές και case studies για παραγωγικότητα, automation και φωνητικό AI στο Google Workspace.
        </p>
      </div>

      {localizedPosts.length === 0 ? (
        <div class="text-center py-24">
          <p class="text-xl text-gray-400 mb-6">Σύντομα θα δημοσιεύσουμε τα πρώτα μας άρθρα στα Ελληνικά.</p>
          <a href="/blog/" class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-500/10 border border-emerald-500/30 rounded-xl text-emerald-300 hover:bg-emerald-500/20 transition-all">
            Διαβάστε στα Αγγλικά
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {localizedPosts.map((post) => (
            <a href={`/el/blog/${post.slug}/`} class="group relative block">
              <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/0 via-emerald-500/10 to-amber-500/0 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="relative h-full bg-gradient-to-br from-gray-800/30 to-gray-900/30 backdrop-blur-xl border border-gray-700/50 rounded-2xl overflow-hidden hover:border-emerald-500/30 transition-all duration-500 flex flex-col">
                <div class="p-6 flex-1 flex flex-col">
                  <div class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-lg mb-4 self-start">
                    <div class="w-1 h-1 rounded-full bg-emerald-400"></div>
                    <span class="text-xs font-mono uppercase tracking-wider text-emerald-300">{post.category}</span>
                  </div>
                  <h2 class="font-display text-xl text-white mb-3 leading-tight group-hover:text-emerald-300 transition-colors duration-300">
                    {post.title}
                  </h2>
                  <p class="text-sm text-gray-400 mb-4 leading-relaxed line-clamp-3 flex-1">
                    {post.description}
                  </p>
                  <div class="flex items-center gap-3 text-xs text-gray-500 pt-4 border-t border-gray-700/50">
                    <span>{formatDate(post.publishedAt, 'el')}</span>
                    <span>·</span>
                    <span>{post.readingTime} {t.minRead}</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="mt-24 text-center text-sm text-gray-500">
        <a href="/blog/" hreflang="en" class="text-emerald-400 hover:text-emerald-300 transition-colors">
          🇬🇧 Read all articles in English →
        </a>
      </div>
    </div>

    <footer class="relative border-t border-gray-700/50 bg-[#0a0e1a]/90 backdrop-blur-xl mt-32">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-3">
            <img src="/logo-transparent.png" alt="Naurra.ai" class="w-8 h-8" loading="lazy" />
            <span class="font-display text-lg bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">
              Naurra.ai
            </span>
          </div>
          <div class="text-center md:text-right">
            <p class="text-gray-500 text-sm">&copy; 2026 NAURRA AI LTD. {t.footerTagline}</p>
            <p class="text-gray-600 text-xs mt-1">
              Registered in Cyprus under company number HE 493756.
              <a href="/legal/" class="text-emerald-400 hover:text-emerald-300">Legal Information</a>
            </p>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <script is:inline>
    (function() {
      var wrap = document.querySelector('[data-lang-switcher]');
      if (!wrap) return;
      var toggle = wrap.querySelector('[data-lang-toggle]');
      var menu = wrap.querySelector('[data-lang-menu]');
      if (!toggle || !menu) return;
      toggle.addEventListener('click', function(e) {
        e.stopPropagation();
        menu.classList.toggle('hidden');
      });
      document.addEventListener('click', function(e) {
        if (!wrap.contains(e.target)) menu.classList.add('hidden');
      });
    })();
  </script>
</BaseLayout>
