---
import BaseLayout from '../layouts/BaseLayout.astro'

const legalEntitySchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Naurra',
  legalName: 'NAURRA AI LTD',
  url: 'https://naurra.ai',
  logo: 'https://naurra.ai/logo-transparent.png',
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'Cyprus Company Registration Number',
    value: 'HE 493756',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '10 Kyriakou Matsi, LILIANA COURT, 4th Floor',
    addressLocality: 'Nicosia',
    postalCode: '1082',
    addressCountry: 'CY',
  },
}
---

<BaseLayout
  title="Legal Information | NAURRA AI LTD"
  description="Legal information for Naurra. Naurra is operated by NAURRA AI LTD, a private limited liability company incorporated in Cyprus (Company No. HE 493756)."
  keywords="NAURRA AI LTD, Naurra legal information, company registration HE 493756, Naurra Cyprus, registered office"
  url="https://naurra.ai/legal/"
  structuredData={[legalEntitySchema]}
>
  <main class="min-h-screen bg-[#0a0e1a] text-white">
    <!-- Nav -->
    <nav class="border-b border-white/10 backdrop-blur-xl bg-[#0a0e1a]/80 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 py-5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <img src="/logo-transparent.png" alt="Naurra.ai Logo" class="w-9 h-9" />
          <span class="text-xl font-bold bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">Naurra.ai</span>
        </a>
        <a href="/company/" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Company</a>
      </div>
    </nav>

    <!-- Content -->
    <section class="max-w-4xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px w-[60px] bg-gradient-to-r from-emerald-500 to-transparent"></div>
        <span class="text-emerald-400 text-xs uppercase tracking-[0.25em] font-semibold">Legal</span>
      </div>

      <h1 class="text-4xl lg:text-5xl font-extrabold tracking-tight mb-8">Legal Information</h1>

      <p class="text-lg text-gray-300 leading-relaxed mb-10 max-w-2xl">
        Naurra is operated by <strong class="text-white">NAURRA AI LTD</strong>, a private limited liability company incorporated in the Republic of Cyprus.
      </p>

      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8 lg:p-10 space-y-5 max-w-2xl">
        <div>
          <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Legal company name</div>
          <div class="text-lg text-white font-semibold">NAURRA AI LTD</div>
        </div>
        <div class="h-px bg-white/[0.06]"></div>
        <div>
          <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Company registration number</div>
          <div class="text-lg text-white font-semibold">HE 493756</div>
        </div>
        <div class="h-px bg-white/[0.06]"></div>
        <div>
          <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Country of incorporation</div>
          <div class="text-lg text-white font-semibold">Cyprus</div>
        </div>
        <div class="h-px bg-white/[0.06]"></div>
        <div>
          <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Registered office</div>
          <div class="text-lg text-white font-semibold leading-relaxed">10 Kyriakou Matsi, LILIANA COURT, 4th Floor, 1082 Nicosia, Cyprus</div>
        </div>
      </div>

      <p class="text-gray-400 leading-relaxed mt-10 max-w-2xl">
        For business or legal enquiries, please contact us through the contact details provided on this website. Visit our
        <a href="/contact/" class="text-emerald-400 hover:text-emerald-300 underline">contact page</a> to get in touch.
      </p>

      <p class="text-sm text-gray-500 leading-relaxed mt-8 max-w-2xl">
        Naurra is a technology brand operated by NAURRA AI LTD, a company incorporated in Cyprus. References to "Naurra" on this website refer to the brand and product, while "NAURRA AI LTD" is the legal company name.
      </p>
    </section>

    <!-- Footer -->
    <footer class="relative border-t border-white/10 bg-[#0a0e1a]">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-gray-500 text-sm text-center md:text-left">
          &copy; 2026 NAURRA AI LTD. All rights reserved.<br class="hidden md:block" />
          Registered in Cyprus under company number HE 493756.
        </p>
        <div class="flex items-center gap-4 text-sm">
          <a href="/privacy/" class="text-gray-500 hover:text-gray-300 transition-colors">Privacy</a>
          <a href="/terms/" class="text-gray-500 hover:text-gray-300 transition-colors">Terms</a>
          <a href="/legal/" class="text-emerald-400 hover:text-emerald-300 transition-colors font-semibold">Legal Information</a>
          <a href="/contact/" class="text-gray-500 hover:text-gray-300 transition-colors">Contact</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
