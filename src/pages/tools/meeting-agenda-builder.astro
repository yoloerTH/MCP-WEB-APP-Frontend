---
import BaseLayout from '../../layouts/BaseLayout.astro'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Free Tools', item: 'https://naurra.ai/tools' },
    { '@type': 'ListItem', position: 3, name: 'Meeting Agenda Builder', item: 'https://naurra.ai/tools/meeting-agenda-builder' }
  ]
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Free Meeting Agenda Builder',
  url: 'https://naurra.ai/tools/meeting-agenda-builder',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Build structured meeting agendas with timed sections, attendees, and notes. Copy as formatted text or Markdown. Free, no signup required.',
  creator: { '@type': 'Organization', name: 'Naurra.ai', url: 'https://naurra.ai' }
}

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What should a meeting agenda include?',
      acceptedAnswer: { '@type': 'Answer', text: 'A good meeting agenda includes the meeting title, date and time, attendees, a list of discussion topics with time allocations, and a section for action items or next steps. This builder helps you structure all of these elements.' }
    },
    {
      '@type': 'Question',
      name: 'How do I share the agenda with my team?',
      acceptedAnswer: { '@type': 'Answer', text: 'Use the Copy as Text button to paste into an email or chat, or Copy as Markdown to paste into Google Docs, Notion, or Confluence. You can also paste directly into a Google Calendar event description.' }
    },
    {
      '@type': 'Question',
      name: 'Can I set time limits for each agenda item?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. Each agenda section has an optional time field in minutes. The builder automatically calculates the total meeting duration based on your time allocations.' }
    },
    {
      '@type': 'Question',
      name: 'Is this meeting agenda builder free?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes, completely free with no signup required. Build unlimited agendas, add as many sections as you need, and copy them in any format.' }
    },
    {
      '@type': 'Question',
      name: 'What makes a meeting agenda effective?',
      acceptedAnswer: { '@type': 'Answer', text: 'Effective agendas are specific (not vague topics), time-boxed (each item has a duration), shared in advance (at least 24 hours before), and end with clear action items. This builder encourages all four practices.' }
    },
    {
      '@type': 'Question',
      name: 'Can I use this for recurring meetings?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. Use the presets as starting templates for weekly standups, project reviews, or one-on-ones, then customize each week. Copy the agenda and paste it into your calendar event each time.' }
    }
  ]
}
---

<BaseLayout
  title="Free Meeting Agenda Builder | Create Structured Agendas"
  description="Build structured meeting agendas with timed sections, attendees, and action items. Copy as text or Markdown for Google Docs. Free, no signup required."
  keywords="meeting agenda builder, meeting agenda template, free meeting agenda, meeting agenda generator, agenda maker, meeting planner, google calendar agenda, team meeting agenda"
  image="/tools/tools-page-launch.png"
  url="https://naurra.ai/tools/meeting-agenda-builder"
  structuredData={[breadcrumbSchema, structuredData, faqData]}
>

<style>
  .tool-page { font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif; }
  .tool-page h1, .tool-page h2, .tool-page .font-display { font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em; }
  .tool-page .font-mono { font-family: 'JetBrains Mono', monospace; }

  .noise-bg::before {
    content: '';
    position: fixed;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  .tool-input {
    width: 100%;
    min-height: 46px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    transition: all 0.2s;
    outline: none;
  }
  .tool-input:focus {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
  .tool-input::placeholder { color: rgba(255,255,255,0.25); }

  .tool-input-sm {
    min-height: 38px;
    padding: 8px 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    transition: all 0.2s;
    outline: none;
  }
  .tool-input-sm:focus {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
  .tool-input-sm::placeholder { color: rgba(255,255,255,0.25); }

  .tool-textarea {
    width: 100%;
    min-height: 60px;
    padding: 10px 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    transition: all 0.2s;
    outline: none;
    resize: vertical;
  }
  .tool-textarea:focus {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
  .tool-textarea::placeholder { color: rgba(255,255,255,0.25); }

  .tool-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 6px;
  }

  .surface-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    padding: 28px;
    backdrop-filter: blur(12px);
  }

  .copy-btn {
    padding: 12px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    letter-spacing: 0.02em;
  }
  .copy-btn:hover { transform: translateY(-1px); }
  .copy-btn:active { transform: translateY(0); }

  .copy-btn-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
  }
  .copy-btn-primary:hover { box-shadow: 0 6px 28px rgba(16, 185, 129, 0.4); }

  .copy-btn-secondary {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .copy-btn-secondary:hover { background: rgba(255,255,255,0.1); color: white; }

  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #10b981;
    color: white;
    padding: 14px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    box-shadow: 0 8px 32px rgba(16, 185, 129, 0.4);
    z-index: 1000;
    opacity: 0;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(16,185,129,0.2), transparent);
    margin: 20px 0;
  }

  .agenda-item {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 18px;
    margin-bottom: 12px;
    transition: all 0.2s;
    position: relative;
  }
  .agenda-item:hover { border-color: rgba(16,185,129,0.2); }

  .agenda-item-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .agenda-item-number {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(16,185,129,0.12);
    color: #10b981;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    flex-shrink: 0;
  }

  .remove-item-btn {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.2);
    color: #f87171;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    transition: all 0.2s;
    line-height: 1;
  }
  .remove-item-btn:hover { background: rgba(239,68,68,0.2); }

  .add-item-btn {
    width: 100%;
    padding: 14px;
    border-radius: 14px;
    border: 2px dashed rgba(255,255,255,0.1);
    background: transparent;
    color: rgba(255,255,255,0.4);
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .add-item-btn:hover {
    border-color: rgba(16,185,129,0.3);
    color: #10b981;
    background: rgba(16,185,129,0.04);
  }

  .preview-output {
    width: 100%;
    padding: 20px 24px;
    background: #ffffff;
    border-radius: 12px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 14px;
    color: #1a1a1a;
    line-height: 1.6;
    min-height: 200px;
    white-space: pre-wrap;
  }

  .preset-btn {
    padding: 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
    color: white;
  }
  .preset-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(16,185,129,0.28);
    background: rgba(16,185,129,0.06);
  }

  .faq-item { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .faq-q {
    width: 100%;
    text-align: left;
    padding: 20px 0;
    background: none;
    border: none;
    color: #f1f5f9;
    font-family: 'Sora', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-q:hover { color: #10b981; }
  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    color: rgba(255,255,255,0.6);
    font-size: 15px;
    line-height: 1.7;
  }
  .faq-a.open { max-height: 300px; padding-bottom: 20px; }
  .faq-chevron { transition: transform 0.3s; width: 20px; height: 20px; flex-shrink: 0; }
  .faq-chevron.open { transform: rotate(180deg); }

  .insight-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 18px;
    padding: 24px;
    backdrop-filter: blur(10px);
  }

  .top-shell {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .seo-copy {
    max-width: 900px;
    margin: 0 auto 32px;
    color: rgba(255,255,255,0.64);
    font-size: 16px;
    line-height: 1.8;
  }
  .seo-copy strong { color: #f1f5f9; font-weight: 700; }

  @media (max-width: 1024px) {
    .tool-grid { flex-direction: column !important; }
    .tool-form, .tool-preview { width: 100% !important; }
    .tool-preview > div { position: static !important; }
    .insight-grid { grid-template-columns: 1fr !important; }
  }

  @media (max-width: 768px) {
    .top-shell { padding: 0 16px; }
    .hero-section { padding: 28px 0 28px; text-align: left; }
    .hero-section p { font-size: 16px !important; margin: 0 !important; max-width: none !important; }
    .feature-pills { justify-content: flex-start; margin-top: 18px; gap: 10px; }
    .surface-card { padding: 18px; border-radius: 18px; }
    .action-row { flex-direction: column; }
    .copy-btn, .action-row > a { width: 100%; text-align: center; justify-content: center; }
    .seo-copy { font-size: 15px; margin-bottom: 24px; }
    .agenda-item { padding: 14px; }
    .toast { left: 16px; right: 16px; bottom: 16px; transform: translateY(100px); text-align: center; padding: 14px 18px; }
    .toast.show { transform: translateY(0); }
  }

  @media (max-width: 560px) {
    .hero-section h1 { font-size: clamp(30px, 12vw, 42px) !important; line-height: 1.02 !important; margin-bottom: 14px !important; }
    .hero-section h1 br { display: none; }
    .surface-card { padding: 16px; }
    .copy-btn { padding: 13px 18px; }
    .time-row { flex-direction: column !important; }
  }
</style>

<div class="tool-page noise-bg" style="min-height: 100vh; background: #0a0e1a; position: relative;">
  <!-- Ambient glow -->
  <div style="position: fixed; inset: 0; pointer-events: none; z-index: 0;">
    <div style="position: absolute; top: -20%; left: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%); border-radius: 50%;"></div>
    <div style="position: absolute; bottom: -10%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(245,158,11,0.04) 0%, transparent 70%); border-radius: 50%;"></div>
  </div>

  <div class="top-shell">
    <!-- Header -->
    <header style="padding: 32px 0 16px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
      <a href="/" style="display: flex; align-items: center; gap: 12px; text-decoration: none;">
        <img src="/logo-transparent.png" alt="Naurra.ai" style="width: 36px; height: 36px; object-fit: contain;" />
        <span class="font-display" style="font-size: 20px; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Naurra.ai</span>
      </a>
      <nav style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap; justify-content: flex-end;">
        <a href="/tools" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">All Tools</a>
        <a href="/blog" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Blog</a>
        <a href="/pricing" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Pricing</a>
        <a href="/" style="padding: 8px 20px; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); border-radius: 8px; color: #10b981; text-decoration: none; font-size: 13px; font-weight: 600; transition: all 0.2s;" onmouseover="this.style.background='rgba(16,185,129,0.2)'" onmouseout="this.style.background='rgba(16,185,129,0.12)'">Try Naurra Free</a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="hero-section" style="text-align: center; padding: 48px 0 40px;">
      <div style="display: inline-block; padding: 6px 16px; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 100px; margin-bottom: 20px;">
        <span style="font-size: 12px; font-weight: 600; color: #10b981; letter-spacing: 0.08em; text-transform: uppercase;">Free Tool -- No Signup Required</span>
      </div>
      <h1 style="font-family: 'Sora', sans-serif; font-size: clamp(32px, 5vw, 52px); font-weight: 800; color: #f1f5f9; margin: 0 0 16px; line-height: 1.15; letter-spacing: -0.04em;">
        Meeting Agenda<br/>
        <span style="background: linear-gradient(135deg, #10b981, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Builder</span>
      </h1>
      <p style="font-size: 18px; color: rgba(255,255,255,0.5); max-width: 560px; margin: 0 auto; line-height: 1.6; font-weight: 400;">
        Build structured agendas with timed sections and notes. Copy as formatted text or Markdown. Share before the meeting starts.
      </p>
      <div class="feature-pills" style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 24px;">
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Timed sections</div>
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Copy as text or Markdown</div>
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Ready for Google Docs</div>
      </div>
    </section>

    <!-- SEO Intro -->
    <section class="seo-copy">
      <p style="margin: 0 0 14px;">
        A structured <strong>meeting agenda</strong> is the difference between a productive 30-minute call and an hour of wandering discussion. This <strong>free meeting agenda builder</strong> helps you create clear, time-boxed agendas that keep every meeting on track.
      </p>
      <p style="margin: 0;">
        Build your agenda here, then paste it into a <a href="/blog/google-calendar-ai-scheduling" style="color: #10b981; text-decoration: none; font-weight: 600;">Google Calendar event</a> or share it via email. For recurring meetings, use <a href="/voiceai" style="color: #10b981; text-decoration: none; font-weight: 600;">Naurra's voice AI</a> to generate and send agendas automatically.
      </p>
    </section>

    <!-- Presets -->
    <section style="margin-bottom: 24px;">
      <label class="tool-label" style="margin-bottom: 12px;">Quick presets</label>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;">
        <button class="preset-btn" data-preset="standup">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">Daily Standup</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">15-min team check-in</div>
        </button>
        <button class="preset-btn" data-preset="project">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">Project Review</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">45-min status review</div>
        </button>
        <button class="preset-btn" data-preset="oneonone">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">1:1 Meeting</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">30-min manager check-in</div>
        </button>
        <button class="preset-btn" data-preset="brainstorm">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">Brainstorm Session</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">60-min creative session</div>
        </button>
      </div>
    </section>

    <!-- Main Tool Area -->
    <div class="tool-grid" style="display: flex; gap: 24px; padding-bottom: 48px;">

      <!-- Form -->
      <div class="tool-form" style="flex: 1; min-width: 0;">
        <div class="surface-card">
          <!-- Meeting Info -->
          <div style="display: grid; gap: 14px; margin-bottom: 20px;">
            <div>
              <label class="tool-label" for="agenda-title">Meeting title *</label>
              <input type="text" id="agenda-title" class="tool-input" placeholder="Weekly Team Standup" />
            </div>
            <div class="time-row" style="display: flex; gap: 14px;">
              <div style="flex: 1;">
                <label class="tool-label" for="agenda-date">Date</label>
                <input type="date" id="agenda-date" class="tool-input" />
              </div>
              <div style="flex: 1;">
                <label class="tool-label" for="agenda-time">Time</label>
                <input type="time" id="agenda-time" class="tool-input" />
              </div>
            </div>
            <div>
              <label class="tool-label" for="agenda-attendees">Attendees</label>
              <input type="text" id="agenda-attendees" class="tool-input" placeholder="Alice, Bob, Charlie" />
            </div>
            <div>
              <label class="tool-label" for="agenda-objective">Meeting objective</label>
              <input type="text" id="agenda-objective" class="tool-input" placeholder="Review Q2 progress and assign next steps" />
            </div>
          </div>

          <div class="section-divider"></div>

          <!-- Agenda Items -->
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
            <label class="tool-label" style="margin-bottom: 0;">Agenda items</label>
            <span id="total-duration" style="font-size: 12px; color: rgba(255,255,255,0.35); font-family: 'JetBrains Mono', monospace;">0 min total</span>
          </div>

          <div id="agenda-items-container"></div>

          <button id="btn-add-item" class="add-item-btn">+ Add agenda item</button>

          <div class="section-divider" style="margin-top: 20px;"></div>

          <!-- Notes -->
          <div style="margin-bottom: 20px;">
            <label class="tool-label" for="agenda-notes">Additional notes</label>
            <textarea id="agenda-notes" class="tool-textarea" placeholder="Any additional context, links, or pre-read materials..."></textarea>
          </div>

          <!-- Action Buttons -->
