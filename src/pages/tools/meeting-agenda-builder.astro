</div>

<div class="toast" id="toast">Copied!</div>

<script is:inline>
  (function() {
    var items = []
    var itemId = 0

    var titleEl = document.getElementById('agenda-title')
    var dateEl = document.getElementById('agenda-date')
    var timeEl = document.getElementById('agenda-time')
    var attendeesEl = document.getElementById('agenda-attendees')
    var objectiveEl = document.getElementById('agenda-objective')
    var notesEl = document.getElementById('agenda-notes')
    var container = document.getElementById('agenda-items-container')
    var totalDuration = document.getElementById('total-duration')
    var preview = document.getElementById('preview-output')

    // Set default date to today
    var today = new Date()
    dateEl.value = today.toISOString().split('T')[0]

    function addItem(topic, minutes, notes) {
      var id = ++itemId
      items.push({ id: id, topic: topic || '', minutes: minutes || '', notes: notes || '' })
      renderItems()
      render()
    }

    function removeItem(id) {
      items = items.filter(function(i) { return i.id !== id })
      renderItems()
      render()
    }

    function renderItems() {
      container.innerHTML = ''
      items.forEach(function(item, idx) {
        var div = document.createElement('div')
        div.className = 'agenda-item'
        div.innerHTML = '<div class="agenda-item-header">' +
          '<span class="agenda-item-number">' + (idx + 1) + '</span>' +
          '<input type="text" class="tool-input-sm" style="flex:1;" placeholder="Discussion topic" value="' + escapeAttr(item.topic) + '" data-id="' + item.id + '" data-field="topic" />' +
          '<input type="number" class="tool-input-sm" style="width:80px; text-align:center;" placeholder="min" min="1" max="180" value="' + escapeAttr(item.minutes) + '" data-id="' + item.id + '" data-field="minutes" />' +
          '</div>' +
          '<textarea class="tool-textarea" style="min-height:40px; font-size:12px;" placeholder="Notes, context, or sub-items (optional)" data-id="' + item.id + '" data-field="notes">' + escapeHtml(item.notes) + '</textarea>' +
          '<button class="remove-item-btn" data-remove="' + item.id + '">&times;</button>'
        container.appendChild(div)
      })

      // Bind events
      container.querySelectorAll('input, textarea').forEach(function(el) {
        el.addEventListener('input', function() {
          var id = parseInt(this.getAttribute('data-id'))
          var field = this.getAttribute('data-field')
          var itm = items.find(function(i) { return i.id === id })
          if (itm) itm[field] = this.value
          render()
        })
      })

      container.querySelectorAll('.remove-item-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          removeItem(parseInt(this.getAttribute('data-remove')))
        })
      })
    }

    function escapeAttr(s) { return (s || '').replace(/"/g, '&quot;') }
    function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') }

    function calcTotal() {
      var total = 0
      items.forEach(function(i) { if (i.minutes) total += parseInt(i.minutes) || 0 })
      return total
    }

    function formatDate(dateStr) {
      if (!dateStr) return ''
      var d = new Date(dateStr + 'T00:00:00')
      return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })
    }

    function formatTime(timeStr) {
      if (!timeStr) return ''
      var parts = timeStr.split(':')
      var h = parseInt(parts[0])
      var m = parts[1]
      var ampm = h >= 12 ? 'PM' : 'AM'
      if (h > 12) h -= 12
      if (h === 0) h = 12
      return h + ':' + m + ' ' + ampm
    }

    function buildText() {
      var lines = []
      var title = titleEl.value.trim()
      if (title) lines.push(title)
      lines.push('='.repeat(Math.max(title.length, 30)))

      var meta = []
      if (dateEl.value) meta.push('Date: ' + formatDate(dateEl.value))
      if (timeEl.value) meta.push('Time: ' + formatTime(timeEl.value))
      var total = calcTotal()
      if (total > 0) meta.push('Duration: ' + total + ' minutes')
      if (attendeesEl.value.trim()) meta.push('Attendees: ' + attendeesEl.value.trim())
      if (objectiveEl.value.trim()) meta.push('Objective: ' + objectiveEl.value.trim())

      if (meta.length) {
        lines.push('')
        meta.forEach(function(m) { lines.push(m) })
      }

      if (items.length > 0) {
        lines.push('')
        lines.push('AGENDA')
        lines.push('-'.repeat(30))
        items.forEach(function(item, idx) {
          var timeStr = item.minutes ? ' (' + item.minutes + ' min)' : ''
          lines.push((idx + 1) + '. ' + (item.topic || 'Untitled') + timeStr)
          if (item.notes) {
            item.notes.split('\n').forEach(function(n) {
              if (n.trim()) lines.push('   ' + n.trim())
            })
          }
        })
      }

      if (notesEl.value.trim()) {
        lines.push('')
        lines.push('NOTES')
        lines.push('-'.repeat(30))
        lines.push(notesEl.value.trim())
      }

      lines.push('')
      lines.push('ACTION ITEMS')
      lines.push('-'.repeat(30))
      lines.push('[ ] ')
      lines.push('[ ] ')
      lines.push('[ ] ')

      return lines.join('\n')
    }

    function buildMarkdown() {
      var lines = []
      var title = titleEl.value.trim()
      lines.push('# ' + (title || 'Meeting Agenda'))
      lines.push('')

      var meta = []
      if (dateEl.value) meta.push('**Date:** ' + formatDate(dateEl.value))
      if (timeEl.value) meta.push('**Time:** ' + formatTime(timeEl.value))
      var total = calcTotal()
      if (total > 0) meta.push('**Duration:** ' + total + ' minutes')
      if (attendeesEl.value.trim()) meta.push('**Attendees:** ' + attendeesEl.value.trim())
      if (objectiveEl.value.trim()) meta.push('**Objective:** ' + objectiveEl.value.trim())

      if (meta.length) {
        meta.forEach(function(m) { lines.push(m + '  ') })
        lines.push('')
      }

      if (items.length > 0) {
        lines.push('## Agenda')
        lines.push('')
        items.forEach(function(item, idx) {
          var timeStr = item.minutes ? ' *(' + item.minutes + ' min)*' : ''
          lines.push((idx + 1) + '. **' + (item.topic || 'Untitled') + '**' + timeStr)
          if (item.notes) {
            item.notes.split('\n').forEach(function(n) {
              if (n.trim()) lines.push('   - ' + n.trim())
            })
          }
        })
        lines.push('')
      }

      if (notesEl.value.trim()) {
        lines.push('## Notes')
        lines.push('')
        lines.push(notesEl.value.trim())
        lines.push('')
      }

      lines.push('## Action Items')
      lines.push('')
      lines.push('- [ ] ')
      lines.push('- [ ] ')
      lines.push('- [ ] ')

      return lines.join('\n')
    }

    function render() {
      var total = calcTotal()
      totalDuration.textContent = total + ' min total'

      // Preview
      var title = titleEl.value.trim()
      var html = '<div style="margin-bottom:16px;">'
      html += '<div style="font-size:20px; font-weight:700; color:#0f172a; margin-bottom:4px;">' + escapeHtml(title || 'Meeting Agenda') + '</div>'

      var metaParts = []
      if (dateEl.value) metaParts.push(formatDate(dateEl.value))
      if (timeEl.value) metaParts.push(formatTime(timeEl.value))
      if (total > 0) metaParts.push(total + ' min')
      if (metaParts.length) {
        html += '<div style="font-size:13px; color:#64748b; margin-bottom:8px;">' + metaParts.join(' &bull; ') + '</div>'
      }

      if (attendeesEl.value.trim()) {
        html += '<div style="font-size:13px; color:#64748b;"><strong style="color:#334155;">Attendees:</strong> ' + escapeHtml(attendeesEl.value.trim()) + '</div>'
      }
      if (objectiveEl.value.trim()) {
        html += '<div style="font-size:13px; color:#64748b; margin-top:4px;"><strong style="color:#334155;">Objective:</strong> ' + escapeHtml(objectiveEl.value.trim()) + '</div>'
      }
      html += '</div>'

      if (items.length > 0) {
        html += '<div style="border-top:1px solid #e2e8f0; padding-top:12px; margin-bottom:12px;">'
        items.forEach(function(item, idx) {
          var timeLabel = item.minutes ? '<span style="color:#10b981; font-size:12px; font-weight:600; margin-left:8px;">' + item.minutes + ' min</span>' : ''
          html += '<div style="margin-bottom:10px;">'
          html += '<div style="font-size:14px; font-weight:600; color:#1e293b;">' + (idx + 1) + '. ' + escapeHtml(item.topic || 'Untitled') + timeLabel + '</div>'
          if (item.notes) {
            html += '<div style="font-size:12px; color:#94a3b8; margin-top:2px; padding-left:18px;">' + escapeHtml(item.notes).replace(/\n/g, '<br>') + '</div>'
          }
          html += '</div>'
        })
        html += '</div>'
      }

      if (notesEl.value.trim()) {
        html += '<div style="border-top:1px solid #e2e8f0; padding-top:12px; margin-bottom:12px;">'
        html += '<div style="font-size:13px; font-weight:600; color:#334155; margin-bottom:4px;">Notes</div>'
        html += '<div style="font-size:13px; color:#64748b;">' + escapeHtml(notesEl.value.trim()).replace(/\n/g, '<br>') + '</div>'
        html += '</div>'
      }

      html += '<div style="border-top:1px solid #e2e8f0; padding-top:12px;">'
      html += '<div style="font-size:13px; font-weight:600; color:#334155; margin-bottom:6px;">Action Items</div>'
      html += '<div style="font-size:13px; color:#94a3b8;">&#9744; <br>&#9744; <br>&#9744; </div>'
      html += '</div>'

      preview.innerHTML = html
    }

    // Bind header inputs
    ;[titleEl, dateEl, timeEl, attendeesEl, objectiveEl, notesEl].forEach(function(el) {
      el.addEventListener('input', render)
    })

    // Add item
    document.getElementById('btn-add-item').addEventListener('click', function() {
      addItem('', '', '')
    })

    // Presets
    var presets = {
      standup: {
        title: 'Daily Standup',
        objective: 'Quick sync on progress, blockers, and priorities',
        items: [
          { topic: 'What did you accomplish yesterday?', minutes: '5', notes: '' },
          { topic: 'What are you working on today?', minutes: '5', notes: '' },
          { topic: 'Any blockers or help needed?', minutes: '5', notes: '' }
        ]
      },
      project: {
        title: 'Project Review',
        objective: 'Review project status, timeline, and upcoming milestones',
        items: [
          { topic: 'Project status update', minutes: '10', notes: 'Current progress vs. plan' },
          { topic: 'Key deliverables this sprint', minutes: '10', notes: '' },
          { topic: 'Risks and blockers', minutes: '10', notes: '' },
          { topic: 'Timeline and milestones review', minutes: '10', notes: '' },
          { topic: 'Next steps and action items', minutes: '5', notes: '' }
        ]
      },
      oneonone: {
        title: '1:1 Meeting',
        objective: 'Check in on progress, well-being, and growth',
        items: [
          { topic: 'How are things going?', minutes: '5', notes: 'Open-ended check-in' },
          { topic: 'Current project updates', minutes: '10', notes: '' },
          { topic: 'Challenges or support needed', minutes: '5', notes: '' },
          { topic: 'Growth and development', minutes: '5', notes: '' },
          { topic: 'Action items from last time', minutes: '5', notes: '' }
        ]
      },
      brainstorm: {
        title: 'Brainstorm Session',
        objective: 'Generate ideas and explore solutions',
        items: [
          { topic: 'Context and problem statement', minutes: '10', notes: 'Frame the challenge clearly' },
          { topic: 'Individual ideation', minutes: '10', notes: 'Silent brainstorm, write ideas down' },
          { topic: 'Share and discuss ideas', minutes: '20', notes: 'Each person presents their top ideas' },
          { topic: 'Group and prioritize', minutes: '10', notes: 'Cluster similar ideas, vote on top 3' },
          { topic: 'Next steps and owners', minutes: '10', notes: 'Assign follow-ups for top ideas' }
        ]
      }
    }

    document.querySelectorAll('.preset-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var key = this.getAttribute('data-preset')
        var p = presets[key]
        if (!p) return
        titleEl.value = p.title
        objectiveEl.value = p.objective
        attendeesEl.value = ''
        notesEl.value = ''
        items = []
        itemId = 0
        p.items.forEach(function(i) { addItem(i.topic, i.minutes, i.notes) })
      })
    })

    // Copy text
    document.getElementById('btn-copy-text').addEventListener('click', function() {
      var text = buildText()
      navigator.clipboard.writeText(text).then(function() {
        showToast('Copied as text')
      }).catch(function() {
        fallbackCopy(text, 'Copied as text')
      })
    })

    // Copy markdown
    document.getElementById('btn-copy-md').addEventListener('click', function() {
      var md = buildMarkdown()
      navigator.clipboard.writeText(md).then(function() {
        showToast('Copied as Markdown')
      }).catch(function() {
        fallbackCopy(md, 'Copied as Markdown')
      })
    })

    // Clear
    document.getElementById('btn-clear').addEventListener('click', function() {
      titleEl.value = ''
      dateEl.value = new Date().toISOString().split('T')[0]
      timeEl.value = ''
      attendeesEl.value = ''
      objectiveEl.value = ''
      notesEl.value = ''
      items = []
      itemId = 0
      renderItems()
      render()
      showToast('Cleared')
    })

    function fallbackCopy(text, msg) {
      var ta = document.createElement('textarea')
      ta.value = text
      document.body.appendChild(ta)
      ta.select()
      document.execCommand('copy')
      document.body.removeChild(ta)
      showToast(msg)
    }

    function showToast(msg) {
      var t = document.getElementById('toast')
      t.textContent = msg
      t.classList.add('show')
      setTimeout(function() { t.classList.remove('show') }, 2200)
    }

    // FAQ
    document.querySelectorAll('.faq-q').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var answer = btn.nextElementSibling
        var chevron = btn.querySelector('.faq-chevron')
        var isOpen = answer.classList.contains('open')
        document.querySelectorAll('.faq-a').forEach(function(a) { a.classList.remove('open') })
        document.querySelectorAll('.faq-chevron').forEach(function(c) { c.classList.remove('open') })
        if (!isOpen) {
          answer.classList.add('open')
          chevron.classList.add('open')
        }
      })
    })

    // Start with one empty item
    addItem('', '', '')
