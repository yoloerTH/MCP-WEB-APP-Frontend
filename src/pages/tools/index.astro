---
import BaseLayout from '../../layouts/BaseLayout.astro'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Free Tools', item: 'https://naurra.ai/tools' }
  ]
}

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Free Google Workspace Tools',
  description: 'Free productivity tools for Gmail, Google Calendar, and Google Workspace. No signup required.',
  url: 'https://naurra.ai/tools',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, url: 'https://naurra.ai/tools/email-signature', name: 'Free Gmail Signature Generator' },
      { '@type': 'ListItem', position: 2, url: 'https://naurra.ai/tools/mailto-link-generator', name: 'Mailto Link Generator' },
      { '@type': 'ListItem', position: 3, url: 'https://naurra.ai/tools/meeting-agenda-builder', name: 'Meeting Agenda Builder' }
    ]
  }
}

const tools = [
  {
    title: 'Gmail Signature Generator',
    description: 'Create professional email signatures for Gmail, Outlook, and Apple Mail. Pick a template, customize colors and details, copy with one click.',
    href: '/tools/email-signature',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    category: 'Gmail',
    badge: 'Popular'
  },
  {
    title: 'Mailto Link Generator',
    description: 'Build pre-filled email links with subject, body, CC, and BCC. Perfect for websites, newsletters, and support pages.',
    href: '/tools/mailto-link-generator',
    icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
    category: 'Gmail',
    badge: 'New'
  },
  {
    title: 'Meeting Agenda Builder',
    description: 'Build structured meeting agendas with timed sections, attendees, and action items. Export to Google Docs or copy as formatted text.',
    href: '/tools/meeting-agenda-builder',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
    category: 'Calendar',
    badge: 'New'
  }
]
---

<BaseLayout
  title="Free Google Workspace Tools | Gmail, Calendar & Productivity Utilities"
  description="Free productivity tools for Gmail, Google Calendar, and Google Workspace. Generate email signatures, build mailto links, create meeting agendas. No signup required."
  keywords="free google workspace tools, gmail tools, email signature generator, mailto link generator, meeting agenda builder, google calendar tools, productivity utilities"
  image="/tools/tools-page-launch.png"
  url="https://naurra.ai/tools"
  structuredData={[breadcrumbSchema, collectionSchema]}
>

<div class="min-h-screen bg-[#0a0e1a] text-white overflow-hidden" style="font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;">

  <!-- Background Orbs -->
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-amber-500/5"></div>
    <div class="absolute top-0 -right-1/4 w-[800px] h-[800px] bg-emerald-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 -left-1/4 w-[800px] h-[800px] bg-amber-500/10 rounded-full blur-[120px]"></div>
  </div>

  <!-- Nav -->
  <nav class="relative border-b border-emerald-500/10 bg-[#0a0e1a]/95 backdrop-blur-xl sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-10 h-10 flex items-center justify-center">
          <div class="absolute inset-0 bg-emerald-500/20 blur-xl rounded-full group-hover:bg-emerald-500/30 transition-all"></div>
          <img src="/logo-transparent.png" alt="Naurra.ai" class="w-full h-full object-contain relative z-10" />
        </div>
        <span style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em; font-size: 20px; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          Naurra.ai
        </span>
      </a>
      <div class="flex items-center gap-4 flex-wrap justify-end">
        <a href="/blog" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium">Blog</a>
        <a href="/pricing" class="text-sm text-gray-400 hover:text-emerald-300 transition-colors font-medium">Pricing</a>
        <a href="/" class="text-sm font-semibold px-5 py-2 rounded-lg transition-all" style="background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #10b981;">Try Naurra Free</a>
      </div>
    </div>
  </nav>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-24">

    <!-- Hero -->
    <div class="text-center mb-20 fade-in">
      <div class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-emerald-500/10 to-amber-500/10 border border-emerald-500/20 rounded-full mb-6">
        <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
        <span class="text-xs font-mono uppercase tracking-widest text-emerald-300">Free Tools</span>
      </div>

      <h1 style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em;" class="text-5xl lg:text-6xl xl:text-7xl leading-[0.95] tracking-tight mb-6">
        <span class="text-white">Free Google</span><br/>
        <span class="bg-gradient-to-r from-emerald-400 via-emerald-300 to-amber-400 bg-clip-text text-transparent">Workspace Tools</span>
      </h1>

      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-8">
        Practical utilities for Gmail, Google Calendar, and Google Workspace. No signup, no account, no strings attached.
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        <span class="px-4 py-2 rounded-full text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">100% Free</span>
        <span class="px-4 py-2 rounded-full text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">No Signup Required</span>
        <span class="px-4 py-2 rounded-full text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.62);">Built for Google Workspace</span>
      </div>
    </div>

    <!-- Tools Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
      {tools.map((tool) => (
        <a href={tool.href} class="group relative block h-full">
          <div class="h-full bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl overflow-hidden hover:border-emerald-500/30 transition-all duration-300 p-7">
            <!-- Badge -->
            <div class="flex items-center justify-between mb-5">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-lg">
                <span class="text-xs font-mono text-emerald-300">{tool.category}</span>
              </span>
              {tool.badge && (
                <span class={`px-2.5 py-1 rounded-full text-xs font-bold ${tool.badge === 'Popular' ? 'bg-gradient-to-r from-amber-500 to-amber-600 text-white' : 'bg-gradient-to-r from-emerald-500 to-emerald-600 text-white'}`}>
                  {tool.badge}
                </span>
              )}
            </div>

            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={tool.icon} />
              </svg>
            </div>

            <!-- Content -->
            <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-xl text-white mb-3 group-hover:text-emerald-300 transition-colors">
              {tool.title}
            </h2>
            <p class="text-sm text-gray-400 leading-relaxed mb-5">
              {tool.description}
            </p>

            <!-- Action -->
            <div class="flex items-center gap-2 text-emerald-400 text-sm font-semibold">
              <span>Use this tool</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>

            <!-- Hover line -->
            <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-emerald-500 to-amber-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
        </a>
      ))}
    </div>

    <!-- SEO Content Section -->
    <div class="max-w-3xl mx-auto mb-20" style="color: rgba(255,255,255,0.64); font-size: 16px; line-height: 1.8;">
      <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-2xl text-white mb-6">Why we built these tools</h2>
      <p class="mb-4">
        Every tool here solves a specific, recurring friction point inside <strong style="color: #f1f5f9; font-weight: 700;">Google Workspace</strong>. Creating an email signature, formatting a mailto link, preparing a meeting agenda: these are small tasks that interrupt real work.
      </p>
      <p class="mb-4">
        We built each utility to be fast, free, and self-contained. No signup, no paywall, no account needed. Just open the tool, do the thing, and get back to work.
      </p>
      <p>
        For workflows that go beyond a single task, <a href="/voiceai" style="color: #10b981; text-decoration: none; font-weight: 600;">Naurra's voice AI</a> automates entire sequences across Gmail, Calendar, Drive, Docs, and Sheets with a single command. These tools are the starting point; <a href="/chatai" style="color: #10b981; text-decoration: none; font-weight: 600;">Naurra</a> is the full system.
      </p>
    </div>

    <!-- Related Content -->
    <div class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1 h-8 bg-gradient-to-b from-emerald-500 to-amber-500 rounded-full"></div>
        <h2 style="font-family: 'Sora', sans-serif; font-weight: 700; letter-spacing: -0.02em;" class="text-2xl text-white">Related guides</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <a href="/blog/automate-google-workspace-in-5-minutes" class="group block bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6 hover:border-emerald-500/30 transition-all">
          <span class="text-xs font-mono text-emerald-400 uppercase tracking-wider">Guide</span>
          <h3 class="text-white font-semibold mt-2 group-hover:text-emerald-300 transition-colors">Automate Google Workspace in 5 Minutes</h3>
          <p class="text-sm text-gray-500 mt-2">Step-by-step setup for Gmail, Calendar, and Drive automation.</p>
        </a>
        <a href="/blog/gmail-automation-tips" class="group block bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6 hover:border-emerald-500/30 transition-all">
          <span class="text-xs font-mono text-emerald-400 uppercase tracking-wider">Guide</span>
          <h3 class="text-white font-semibold mt-2 group-hover:text-emerald-300 transition-colors">Gmail Automation Tips</h3>
          <p class="text-sm text-gray-500 mt-2">Save hours each week with smarter email workflows.</p>
        </a>
        <a href="/blog/google-calendar-ai-scheduling" class="group block bg-gradient-to-br from-gray-800/50 to-gray-900/50 border border-gray-700/50 rounded-2xl p-6 hover:border-emerald-500/30 transition-all">
          <span class="text-xs font-mono text-emerald-400 uppercase tracking-wider">Guide</span>
          <h3 class="text-white font-semibold mt-2 group-hover:text-emerald-300 transition-colors">AI Calendar Scheduling</h3>
          <p class="text-sm text-gray-500 mt-2">Let AI handle your scheduling so you can focus on real work.</p>
        </a>
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-gradient-to-br from-gray-800/60 to-gray-900/60 border border-gray-700/50 rounded-3xl p-12 lg:p-16 text-center">
      <h2 style="font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em;" class="text-3xl lg:text-4xl text-white mb-4">
        Want to automate the whole workflow?
      </h2>
      <p class="text-lg text-gray-400 max-w-xl mx-auto mb-8">
        These tools handle one task at a time. Naurra handles your entire Google Workspace with voice or chat. One command, eight services.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl font-semibold text-lg shadow-lg shadow-emerald-500/30 border border-emerald-400/30 text-white transition-all hover:shadow-xl hover:shadow-emerald-500/40">
          Try Naurra Free
        </a>
        <a href="/compare" class="px-8 py-4 bg-white/5 border border-white/10 rounded-xl text-gray-400 hover:bg-white/10 hover:text-white transition-all font-medium">
          See how it compares
        </a>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="relative border-t border-gray-700/50 bg-[#0a0e1a] mt-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-gray-500 text-sm">&copy; 2026 Naurra.ai. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Privacy</a>
        <a href="/terms" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Terms</a>
        <a href="/blog" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Blog</a>
        <a href="/contact" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Contact</a>
      </div>
    </div>
  </footer>
</div>

</BaseLayout>
