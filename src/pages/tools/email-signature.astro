<script define:vars={{ mediaSupabaseUrl, mediaSupabaseKey }}>
  window.__MEDIA_SUPABASE_URL = mediaSupabaseUrl
  window.__MEDIA_SUPABASE_KEY = mediaSupabaseKey
</script>

<script>
  // @ts-nocheck
  // =========================================
  // EMAIL SIGNATURE GENERATOR ENGINE
  // =========================================

  const MEDIA_SUPABASE_URL = window.__MEDIA_SUPABASE_URL || ''
  const MEDIA_SUPABASE_KEY = window.__MEDIA_SUPABASE_KEY || ''
  const MEDIA_BUCKET = 'NaurraMedia'

  const state = {
    template: 'minimal',
    color: '#10b981',
    name: '',
    title: '',
    company: '',
    email: '',
    phone: '',
    website: '',
    linkedin: '',
    twitter: '',
    instagram: '',
    imageData: '',
    imageUrl: '',
    uploading: false
  }

  // =========================================
  // SUPABASE IMAGE UPLOAD
  // =========================================

  function generateUUID() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      const r = Math.random() * 16 | 0
      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16)
    })
  }

  async function uploadToSupabase(file) {
    if (!MEDIA_SUPABASE_URL || !MEDIA_SUPABASE_KEY) {
      throw new Error('Media storage not configured')
    }

    const ext = file.name.split('.').pop().toLowerCase()
    const uniqueName = `signatures/${generateUUID()}.${ext}`

    const response = await fetch(
      `${MEDIA_SUPABASE_URL}/storage/v1/object/${MEDIA_BUCKET}/${uniqueName}`,
      {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${MEDIA_SUPABASE_KEY}`,
          'Content-Type': file.type,
          'x-upsert': 'true'
        },
        body: file
      }
    )

    if (!response.ok) {
      const errText = await response.text()
      throw new Error(`Upload failed: ${errText}`)
    }

    return `${MEDIA_SUPABASE_URL}/storage/v1/object/public/${MEDIA_BUCKET}/${uniqueName}`
  }

  // =========================================
  // GMAIL-SAFE HELPERS
  // Uses hosted PNG icons from Supabase bucket
  // =========================================

  const ICON_BASE = 'https://gdpdhuofgvffjzhbeekn.supabase.co/storage/v1/object/public/NaurraMedia/icons'

  function icon(name, size = 20) {
    return `<img src="${ICON_BASE}/${name}.png" width="${size}" height="${size}" style="width:${size}px;height:${size}px;display:block;" alt="${name}" />`
  }

  function getImage() {
    return state.imageUrl || ''
  }

  // Social media icons — real hosted PNGs (like Hotelyzer reference)
  function socialBlock(c) {
    const items = []
    if (state.linkedin) items.push(`<td style="padding-right:8px;"><a href="${state.linkedin}" target="_blank" style="text-decoration:none;">${icon('linkedin', 28)}</a></td>`)
    if (state.twitter) items.push(`<td style="padding-right:8px;"><a href="${state.twitter}" target="_blank" style="text-decoration:none;">${icon('twitter', 28)}</a></td>`)
    if (state.instagram) items.push(`<td style="padding-right:8px;"><a href="${state.instagram}" target="_blank" style="text-decoration:none;">${icon('instagram', 28)}</a></td>`)
    if (items.length === 0) return ''
    return `<table cellpadding="0" cellspacing="0" border="0"><tr>${items.join('')}</tr></table>`
  }

  // Contact line with hosted icons + colored text
  function contactLine(c) {
    let parts = []
    if (state.email) parts.push(`<td style="vertical-align:middle;padding-right:4px;">${icon('email', 16)}</td><td style="vertical-align:middle;padding-right:14px;"><a href="mailto:${state.email}" style="color:${c};text-decoration:none;font-size:13px;">${state.email}</a></td>`)
    if (state.phone) parts.push(`<td style="vertical-align:middle;padding-right:4px;">${icon('phone', 16)}</td><td style="vertical-align:middle;padding-right:14px;"><span style="color:#555;font-size:13px;">${state.phone}</span></td>`)
    if (state.website) {
      const display = state.website.replace(/^https?:\/\//, '').replace(/\/$/, '')
      parts.push(`<td style="vertical-align:middle;padding-right:4px;">${icon('website', 16)}</td><td style="vertical-align:middle;"><a href="${state.website}" target="_blank" style="color:${c};text-decoration:none;font-size:13px;">${display}</a></td>`)
    }
    if (parts.length === 0) return ''
    return `<table cellpadding="0" cellspacing="0" border="0"><tr>${parts.join('')}</tr></table>`
  }

  // Contact line simple (pipe-separated, no icons — for compact template)
  function contactLineSimple(c) {
    let parts = []
    if (state.email) parts.push(`<a href="mailto:${state.email}" style="color:${c};text-decoration:none;font-size:12px;">${state.email}</a>`)
    if (state.phone) parts.push(`<span style="color:#555;font-size:12px;">${state.phone}</span>`)
    if (state.website) {
      const display = state.website.replace(/^https?:\/\//, '').replace(/\/$/, '')
      parts.push(`<a href="${state.website}" target="_blank" style="color:${c};text-decoration:none;font-size:12px;">${display}</a>`)
    }
    return parts.join(`<span style="color:#d1d5db;">&nbsp;&middot;&nbsp;</span>`)
  }

  // Vertical contact list with icons (for corporate template)
  function contactList(c) {
    let rows = []
    if (state.email) rows.push(`<tr><td style="vertical-align:middle;padding-right:6px;padding-bottom:5px;">${icon('email', 16)}</td><td style="padding-bottom:5px;font-size:13px;"><a href="mailto:${state.email}" style="color:${c};text-decoration:none;">${state.email}</a></td></tr>`)
    if (state.phone) rows.push(`<tr><td style="vertical-align:middle;padding-right:6px;padding-bottom:5px;">${icon('phone', 16)}</td><td style="padding-bottom:5px;font-size:13px;color:#555;">${state.phone}</td></tr>`)
    if (state.website) {
      const display = state.website.replace(/^https?:\/\//, '').replace(/\/$/, '')
      rows.push(`<tr><td style="vertical-align:middle;padding-right:6px;padding-bottom:5px;">${icon('website', 16)}</td><td style="padding-bottom:5px;font-size:13px;"><a href="${state.website}" target="_blank" style="color:${c};text-decoration:none;">${display}</a></td></tr>`)
    }
    if (rows.length === 0) return ''
    return `<table cellpadding="0" cellspacing="0" border="0">${rows.join('')}</table>`
  }

  function imgTag(size, radius) {
    const src = getImage()
    if (!src) return ''
    return `<img src="${src}" width="${size}" height="${size}" style="width:${size}px;height:${size}px;border-radius:${radius};object-fit:cover;display:block;" alt="${state.name || 'Photo'}" />`
  }

  // =========================================
  // TEMPLATE RENDERERS (Gmail-safe: tables + inline styles only)
  // =========================================

  const FONT = `-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif`

  const templates = {
    minimal(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:${FONT};color:#333;">
        <tr>
          ${img ? `<td style="padding-right:16px;vertical-align:top;">${imgTag(60, '50%')}</td>` : ''}
          <td style="vertical-align:top;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr><td style="font-size:17px;font-weight:700;color:#1a1a1a;padding-bottom:2px;">${state.name || 'Your Name'}</td></tr>
              ${state.title || state.company ? `<tr><td style="font-size:13px;color:#666;padding-bottom:8px;">${[state.title, state.company].filter(Boolean).join(' <span style="color:#d1d5db;">/</span> ')}</td></tr>` : ''}
              <tr><td>${contactLine(c)}</td></tr>
              ${socialBlock(c) ? `<tr><td style="padding-top:10px;">${socialBlock(c)}</td></tr>` : ''}
            </table>
          </td>
        </tr>
      </table>`
    },

    modern(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:${FONT};color:#333;">
        <tr>
          <td style="width:4px;background:${c};"></td>
          <td style="padding-left:18px;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                ${img ? `<td style="padding-right:16px;vertical-align:top;">${imgTag(68, '10px')}</td>` : ''}
                <td style="vertical-align:top;">
                  <table cellpadding="0" cellspacing="0" border="0">
                    <tr><td style="font-size:18px;font-weight:700;color:#1a1a1a;">${state.name || 'Your Name'}</td></tr>
                    ${state.title ? `<tr><td style="font-size:13px;font-weight:600;color:${c};padding-top:2px;">${state.title}</td></tr>` : ''}
                    ${state.company ? `<tr><td style="font-size:13px;color:#888;padding-top:1px;">${state.company}</td></tr>` : ''}
                  </table>
                </td>
              </tr>
            </table>
            <table cellpadding="0" cellspacing="0" border="0" width="100%"><tr><td style="border-top:1px solid #e5e7eb;padding-top:10px;padding-bottom:2px;">&nbsp;</td></tr></table>
            <table cellpadding="0" cellspacing="0" border="0"><tr><td>${contactLine(c)}</td></tr></table>
            ${socialBlock(c) ? `<table cellpadding="0" cellspacing="0" border="0"><tr><td style="padding-top:10px;">${socialBlock(c)}</td></tr></table>` : ''}
          </td>
        </tr>
      </table>`
    },

    corporate(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:${FONT};color:#333;">
        <tr><td colspan="${img ? '2' : '1'}" style="border-bottom:3px solid ${c};padding-bottom:0;height:3px;"></td></tr>
        <tr>
          ${img ? `<td style="padding-right:18px;padding-top:14px;vertical-align:top;">${imgTag(76, '6px')}</td>` : ''}
          <td style="vertical-align:top;padding-top:14px;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr><td style="font-size:19px;font-weight:700;color:#1a1a1a;text-transform:uppercase;letter-spacing:1px;">${state.name || 'Your Name'}</td></tr>
              ${state.title ? `<tr><td style="font-size:13px;color:#555;padding-top:3px;">${state.title}</td></tr>` : ''}
              ${state.company ? `<tr><td style="font-size:13px;font-weight:600;color:${c};padding-top:2px;">${state.company}</td></tr>` : ''}
              <tr><td style="padding-top:10px;">
                <table cellpadding="0" cellspacing="0" border="0" width="100%"><tr><td style="border-top:1px solid #e5e7eb;padding-top:10px;">&nbsp;</td></tr></table>
                ${contactList(c)}
              </td></tr>
              ${socialBlock(c) ? `<tr><td style="padding-top:10px;">${socialBlock(c)}</td></tr>` : ''}
            </table>
          </td>
        </tr>
      </table>`
    },

    creative(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:${FONT};color:#333;">
        <tr>
          ${img ? `<td style="padding-right:18px;vertical-align:top;">${imgTag(74, '50%')}</td>` : ''}
          <td style="vertical-align:top;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr><td style="font-size:24px;font-weight:800;color:${c};line-height:1.1;">${state.name || 'Your Name'}</td></tr>
              ${state.title || state.company ? `<tr><td style="font-size:13px;color:#555;padding-top:4px;padding-bottom:10px;">${[state.title, state.company].filter(Boolean).join(' at ')}</td></tr>` : '<tr><td style="padding-bottom:10px;"></td></tr>'}
              <tr><td>
                <table cellpadding="0" cellspacing="0" border="0"><tr>
                  <td style="background:${c};padding:7px 16px;border-radius:4px;">
                    ${state.email ? `<a href="mailto:${state.email}" style="color:#fff;text-decoration:none;font-size:13px;font-weight:600;">${state.email}</a>` : `<span style="color:#fff;font-size:13px;font-weight:600;">your@email.com</span>`}
                  </td>
                  ${state.phone ? `<td style="padding-left:12px;font-size:13px;color:#666;font-weight:500;">${state.phone}</td>` : ''}
                </tr></table>
              </td></tr>
              ${state.website || socialBlock(c) ? `<tr><td style="padding-top:12px;">
                <table cellpadding="0" cellspacing="0" border="0"><tr>
                  ${state.website ? `<td style="padding-right:14px;vertical-align:middle;"><a href="${state.website}" target="_blank" style="color:${c};text-decoration:none;font-size:13px;font-weight:600;">${state.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a></td>` : ''}
                  ${socialBlock(c) ? `<td style="vertical-align:middle;">${socialBlock(c)}</td>` : ''}
                </tr></table>
              </td></tr>` : ''}
            </table>
          </td>
        </tr>
      </table>`
    },

    compact(c) {
      const img = getImage()
      const titleCompany = [state.title, state.company].filter(Boolean).join(' / ')

      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:${FONT};font-size:13px;color:#333;">
        <tr>
          ${img ? `<td style="padding-right:12px;vertical-align:middle;">${imgTag(44, '50%')}</td>` : ''}
          <td style="vertical-align:middle;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr><td>
                <span style="font-weight:700;font-size:14px;color:#1a1a1a;">${state.name || 'Your Name'}</span>${titleCompany ? `<span style="color:#d1d5db;"> &nbsp;/&nbsp; </span><span style="color:#666;">${titleCompany}</span>` : ''}
              </td></tr>
              <tr><td style="padding-top:4px;">${contactLineSimple(c)}</td></tr>
              ${socialBlock(c) ? `<tr><td style="padding-top:6px;">${socialBlock(c)}</td></tr>` : ''}
            </table>
          </td>
        </tr>
      </table>`
    }
  }

  // =========================================
  // RENDER + EVENT WIRING
  // =========================================

  function render() {
    const html = templates[state.template](state.color)
    document.getElementById('signature-preview').innerHTML = html
  }

  function showToast(msg) {
    const t = document.getElementById('toast')
    t.textContent = msg
    t.classList.add('show')
    setTimeout(() => t.classList.remove('show'), 2200)
  }

  // Input bindings
  const fieldMap = {
    'sig-name': 'name', 'sig-title': 'title', 'sig-company': 'company',
    'sig-email': 'email', 'sig-phone': 'phone', 'sig-website': 'website',
    'sig-linkedin': 'linkedin', 'sig-twitter': 'twitter', 'sig-instagram': 'instagram',
    'sig-image-url': 'imageUrl'
  }

  Object.entries(fieldMap).forEach(([id, key]) => {
    const el = document.getElementById(id)
    if (el) {
      el.addEventListener('input', () => {
        state[key] = el.value
        render()
      })
    }
  })

  // Template selector
  document.getElementById('template-selector').addEventListener('click', (e) => {
    const btn = e.target.closest('[data-template]')
    if (!btn) return
    document.querySelectorAll('.tmpl-btn').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    state.template = btn.dataset.template
    render()
  })

  // Color selector
  document.getElementById('color-selector').addEventListener('click', (e) => {
    const swatch = e.target.closest('.color-swatch')
    if (!swatch) return
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'))
    swatch.classList.add('active')
    state.color = swatch.dataset.color
    document.getElementById('custom-color').value = state.color
    render()
  })

  document.getElementById('custom-color').addEventListener('input', (e) => {
    state.color = e.target.value
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'))
    render()
  })

  // Image upload
  const uploadZone = document.getElementById('upload-zone')
  const fileInput = document.getElementById('sig-image-file')
  const placeholder = document.getElementById('upload-placeholder')
  const previewWrap = document.getElementById('upload-preview')
  const previewImg = document.getElementById('upload-preview-img')

  uploadZone.addEventListener('click', (e) => {
    if (e.target.closest('#upload-remove')) return
    fileInput.click()
  })

  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.style.borderColor = 'rgba(16,185,129,0.5)' })
  uploadZone.addEventListener('dragleave', () => { uploadZone.style.borderColor = '' })
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault()
    uploadZone.style.borderColor = ''
    if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0])
  })

  fileInput.addEventListener('change', () => {
    if (fileInput.files.length) handleFile(fileInput.files[0])
  })

  async function handleFile(file) {
    if (file.size > 2 * 1024 * 1024) { showToast('Image must be under 2MB'); return }

    // Show local preview immediately
    const reader = new FileReader()
    reader.onload = (e) => showUploadPreview(e.target.result)
    reader.readAsDataURL(file)

    // Upload to Supabase for a public URL
    if (MEDIA_SUPABASE_URL && MEDIA_SUPABASE_KEY) {
      state.uploading = true
      showToast('Uploading image...')
      try {
        const publicUrl = await uploadToSupabase(file)
        state.imageUrl = publicUrl
        state.imageData = ''
        document.getElementById('sig-image-url').value = publicUrl
        showToast('Image uploaded successfully')
        render()
      } catch (err) {
        console.error('Upload error:', err)
        showToast('Upload failed — paste an image URL instead')
        clearUpload()
      } finally {
        state.uploading = false
      }
    } else {
      // No Supabase config — prompt user to use URL input
      showToast('Paste a publicly hosted image URL for Gmail compatibility')
      clearUpload()
    }
  }

  function showUploadPreview(src) {
    placeholder.style.display = 'none'
    previewWrap.style.display = 'block'
    previewImg.src = src
    uploadZone.classList.add('has-image')
  }

  function clearUpload() {
    state.imageData = ''
    state.imageUrl = ''
    fileInput.value = ''
    document.getElementById('sig-image-url').value = ''
    placeholder.style.display = ''
    previewWrap.style.display = 'none'
    uploadZone.classList.remove('has-image')
    render()
  }

  document.getElementById('upload-remove').addEventListener('click', (e) => {
    e.stopPropagation()
    clearUpload()
  })

  // Image URL input — manual URL entry
  document.getElementById('sig-image-url').addEventListener('input', () => {
    if (state.imageUrl) {
      // Clear file upload preview when URL is typed manually
      state.imageData = ''
      fileInput.value = ''
      placeholder.style.display = ''
      previewWrap.style.display = 'none'
      uploadZone.classList.remove('has-image')
    }
  })

  // Copy buttons
  document.getElementById('btn-copy-html').addEventListener('click', async () => {
    const html = templates[state.template](state.color)
    try {
      await navigator.clipboard.write([
        new ClipboardItem({
          'text/html': new Blob([html], { type: 'text/html' }),
          'text/plain': new Blob([htmlToPlainText(html)], { type: 'text/plain' })
        })
      ])
      showToast('HTML signature copied -- paste into Gmail')
    } catch {
      // Fallback
      const ta = document.createElement('textarea')
      ta.value = html
      document.body.appendChild(ta)
      ta.select()
      document.execCommand('copy')
      document.body.removeChild(ta)
      showToast('Signature HTML copied')
    }
  })

  document.getElementById('btn-copy-text').addEventListener('click', async () => {
    const html = templates[state.template](state.color)
    const text = htmlToPlainText(html)
    try {
      await navigator.clipboard.writeText(text)
      showToast('Plain text copied')
    } catch {
      const ta = document.createElement('textarea')
      ta.value = text
      document.body.appendChild(ta)
      ta.select()
      document.execCommand('copy')
      document.body.removeChild(ta)
      showToast('Plain text copied')
    }
  })

  function htmlToPlainText(html) {
    const div = document.createElement('div')
    div.innerHTML = html
    // Replace <br> and block elements with newlines
    div.querySelectorAll('br').forEach(br => br.replaceWith('\n'))
    div.querySelectorAll('div, tr').forEach(el => el.append('\n'))
    let text = div.textContent || ''
    // Clean up
    text = text.replace(/\n{3,}/g, '\n\n').trim()
    // Build plain text manually for cleanliness
    const lines = []
    if (state.name) lines.push(state.name)
    if (state.title && state.company) lines.push(`${state.title} / ${state.company}`)
    else if (state.title) lines.push(state.title)
    else if (state.company) lines.push(state.company)
    if (state.email) lines.push(state.email)
    if (state.phone) lines.push(state.phone)
    if (state.website) lines.push(state.website)
    const socials = [state.linkedin, state.twitter, state.instagram].filter(Boolean)
    if (socials.length) lines.push(socials.join(' | '))
    return lines.join('\n')
  }

  // FAQ toggles
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling
      const chevron = btn.querySelector('.faq-chevron')
      const isOpen = answer.classList.contains('open')

      // Close all
      document.querySelectorAll('.faq-a').forEach(a => a.classList.remove('open'))
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('open'))

      if (!isOpen) {
        answer.classList.add('open')
        chevron.classList.add('open')
      }
    })
  })

  // Initial render
  render()
</script>

</BaseLayout>
