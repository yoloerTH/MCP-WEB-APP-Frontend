---
import BaseLayout from '../../layouts/BaseLayout.astro'

const mediaSupabaseUrl = import.meta.env.VITE_MEDIA_SUPABASE_URL || ''
const mediaSupabaseKey = import.meta.env.VITE_MEDIA_SUPABASE_KEY || ''

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Gmail Signature Generator",
  "url": "https://naurra.ai/tools/email-signature",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": "Create a free Gmail signature with professional templates, custom colors, social links, and one-click copy for Gmail and Google Workspace.",
  "creator": {
    "@type": "Organization",
    "name": "Naurra.ai",
    "url": "https://naurra.ai"
  }
}

const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I add this signature to Gmail?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Click 'Copy HTML' in the generator, then go to Gmail Settings > General > Signature. Click in the signature editor and paste (Ctrl+V or Cmd+V). The formatted signature will appear with all your styling intact."
      }
    },
    {
      "@type": "Question",
      "name": "Is this a free Gmail signature generator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can create a Gmail signature for free, choose a template, customize your details, and copy the finished HTML signature into Gmail without signing up."
      }
    },
    {
      "@type": "Question",
      "name": "Is this email signature generator really free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, completely free with no signup required. Generate unlimited signatures, use any template, and copy them as many times as you need."
      }
    },
    {
      "@type": "Question",
      "name": "Will my signature look the same on all email clients?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The signatures use table-based HTML that is compatible with all major email clients including Gmail, Outlook, Apple Mail, and Yahoo Mail. We avoid CSS that might break in certain clients."
      }
    },
    {
      "@type": "Question",
      "name": "Can I add my company logo or profile photo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Upload an image and it will be hosted automatically, or paste a URL to any publicly hosted image. For best results, use a square image under 200x200 pixels for profile photos, or a horizontal image for logos."
      }
    },
    {
      "@type": "Question",
      "name": "What image format works best for email signatures?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PNG or JPG work best. For logos with transparency, use PNG. Keep file sizes under 2MB. Uploaded images are hosted on our servers so they display correctly in all email clients including Gmail."
      }
    }
  ]
}
---

<BaseLayout
  title="Free Gmail Signature Generator | Professional Email Signatures"
  description="Create a free Gmail signature in seconds. Choose a professional email signature template, customize your details, and copy it into Gmail or Google Workspace."
  keywords="gmail signature generator, free gmail signature generator, email signature generator for gmail, gmail signature maker, professional email signature, google workspace signature, html email signature"
  url="https://naurra.ai/tools/email-signature"
  structuredData={[structuredData, faqData]}
>

<style>
  /* Fonts loaded via BaseLayout head */
  .sig-page { font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif; }
  .sig-page h1, .sig-page h2, .sig-page .font-display { font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em; }
  .sig-page .font-mono { font-family: 'JetBrains Mono', monospace; }

  /* Noise texture overlay */
  .noise-bg::before {
    content: '';
    position: fixed;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  /* Template thumbnails */
  .tmpl-btn { transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
  .tmpl-btn:hover { transform: translateY(-2px); }
  .tmpl-btn.active {
    outline: 2px solid #10b981;
    outline-offset: 2px;
    background: rgba(16, 185, 129, 0.08);
  }

  /* Form inputs */
  .sig-input {
    width: 100%;
    min-height: 46px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    transition: all 0.2s;
    outline: none;
  }
  .sig-input:focus {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
  .sig-input::placeholder { color: rgba(255,255,255,0.25); }

  .sig-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 6px;
  }

  /* Color swatches */
  .color-swatch {
    width: 28px; height: 28px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    border: 2px solid transparent;
  }
  .color-swatch:hover { transform: scale(1.15); }
  .color-swatch.active { border-color: white; box-shadow: 0 0 12px rgba(255,255,255,0.2); }

  /* Preview card */
  .preview-card {
    background: #ffffff;
    border-radius: 8px;
    padding: 28px;
    color: #1a1a1a;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.4;
    min-height: 120px;
  }

  /* Copy buttons */
  .copy-btn {
    padding: 12px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    letter-spacing: 0.02em;
  }
  .copy-btn:hover { transform: translateY(-1px); }
  .copy-btn:active { transform: translateY(0); }

  .copy-btn-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
  }
  .copy-btn-primary:hover { box-shadow: 0 6px 28px rgba(16, 185, 129, 0.4); }

  .copy-btn-secondary {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .copy-btn-secondary:hover { background: rgba(255,255,255,0.1); color: white; }

  /* Image upload zone */
  .upload-zone {
    border: 2px dashed rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .upload-zone:hover {
    border-color: rgba(16, 185, 129, 0.4);
    background: rgba(16, 185, 129, 0.04);
  }
  .upload-zone.has-image {
    border-style: solid;
    border-color: rgba(16, 185, 129, 0.3);
    padding: 8px;
  }

  /* Toast notification */
  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #10b981;
    color: white;
    padding: 14px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    box-shadow: 0 8px 32px rgba(16, 185, 129, 0.4);
    z-index: 1000;
    opacity: 0;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Section divider */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(16,185,129,0.2), transparent);
    margin: 20px 0;
  }

  /* FAQ */
  .faq-item { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .faq-q {
    width: 100%;
    text-align: left;
    padding: 20px 0;
    background: none;
    border: none;
    color: #f1f5f9;
    font-family: 'Sora', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-q:hover { color: #10b981; }
  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    color: rgba(255,255,255,0.6);
    font-size: 15px;
    line-height: 1.7;
  }
  .faq-a.open { max-height: 300px; padding-bottom: 20px; }
  .faq-chevron { transition: transform 0.3s; width: 20px; height: 20px; flex-shrink: 0; }
  .faq-chevron.open { transform: rotate(180deg); }

  .preset-btn {
    padding: 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
  }
  .preset-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(16,185,129,0.28);
    background: rgba(16,185,129,0.06);
  }

  .success-card {
    display: none;
    background: linear-gradient(135deg, rgba(16,185,129,0.12), rgba(16,185,129,0.04));
    border: 1px solid rgba(16,185,129,0.22);
    border-radius: 18px;
    padding: 20px;
    margin-bottom: 20px;
  }
  .success-card.show { display: block; }

  .insight-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 18px;
    padding: 24px;
    backdrop-filter: blur(10px);
  }

  .top-shell {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .sig-header {
    padding: 32px 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .sig-nav {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .hero-section {
    text-align: center;
    padding: 48px 0 40px;
  }

  .feature-pills {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 24px;
  }

  .surface-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    padding: 28px;
    backdrop-filter: blur(12px);
  }

  .field-group {
    display: grid;
    gap: 14px;
    margin-bottom: 20px;
  }

  .action-row {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .insight-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .seo-copy {
    max-width: 900px;
    margin: 0 auto 32px;
    color: rgba(255,255,255,0.64);
    font-size: 16px;
    line-height: 1.8;
  }

  .seo-copy strong {
    color: #f1f5f9;
    font-weight: 700;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .sig-grid { flex-direction: column !important; }
    .sig-form, .sig-preview { width: 100% !important; }
    .sig-preview > div { position: static !important; }
    .insight-grid,
    .guide-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .top-shell {
      padding: 0 16px;
    }

    .sig-header {
      padding: 20px 0 12px;
      align-items: flex-start;
      flex-direction: column;
    }

    .sig-nav {
      width: 100%;
      gap: 10px;
      justify-content: flex-start;
    }

    .hero-section {
      padding: 28px 0 28px;
      text-align: left;
    }

    .hero-section p {
      font-size: 16px !important;
      margin: 0 !important;
      max-width: none !important;
    }

    .feature-pills {
      justify-content: flex-start;
      margin-top: 18px;
      gap: 10px;
    }

    .seo-copy {
      font-size: 15px;
      margin-bottom: 24px;
    }

    .sig-grid {
      gap: 18px !important;
      padding-bottom: 44px !important;
    }

    .sig-form {
      order: 2;
    }

    .sig-preview {
      order: 1;
    }

    .surface-card,
    .insight-card {
      padding: 18px;
      border-radius: 18px;
    }

    #template-selector {
      grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
      gap: 10px !important;
    }

    .field-group {
      gap: 12px;
      margin-bottom: 16px;
    }

    .action-row {
      flex-direction: column;
      margin-bottom: 16px;
    }

    .copy-btn,
    .action-row > a {
      width: 100%;
      text-align: center;
      justify-content: center;
    }

    .preview-card {
      font-size: 13px;
    }
  }

  @media (max-width: 560px) {
    .sig-header img {
      width: 32px !important;
      height: 32px !important;
    }

    .sig-nav a {
      font-size: 13px !important;
    }

    .hero-section h1 {
      font-size: clamp(30px, 12vw, 42px) !important;
      line-height: 1.02 !important;
      margin-bottom: 14px !important;
    }

    .hero-section h1 br {
      display: none;
    }

    .surface-card {
      padding: 16px;
    }

    #template-selector {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .preset-btn {
      padding: 12px;
    }

    .color-swatch,
    #custom-color {
      width: 32px !important;
      height: 32px !important;
    }

    .copy-btn {
      padding: 13px 18px;
    }

    .toast {
      left: 16px;
      right: 16px;
      bottom: 16px;
      transform: translateY(100px);
      text-align: center;
      padding: 14px 18px;
    }

    .toast.show {
      transform: translateY(0);
    }
  }
</style>

<div class="sig-page noise-bg" style="min-height: 100vh; background: #0a0e1a; position: relative;">
  <!-- Ambient glow -->
  <div style="position: fixed; inset: 0; pointer-events: none; z-index: 0;">
    <div style="position: absolute; top: -20%; left: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%); border-radius: 50%;"></div>
    <div style="position: absolute; bottom: -10%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(245,158,11,0.04) 0%, transparent 70%); border-radius: 50%;"></div>
  </div>

  <div class="top-shell">

    <!-- Header -->
    <header class="sig-header">
      <a href="/" style="display: flex; align-items: center; gap: 12px; text-decoration: none;">
        <img src="/logo-transparent.png" alt="Naurra.ai" style="width: 36px; height: 36px; object-fit: contain;" />
        <span class="font-display" style="font-size: 20px; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Naurra.ai</span>
      </a>
      <nav class="sig-nav">
        <a href="/tools" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">All Tools</a>
        <a href="/blog" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Blog</a>
        <a href="/pricing" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Pricing</a>
        <a href="/" style="padding: 8px 20px; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); border-radius: 8px; color: #10b981; text-decoration: none; font-size: 13px; font-weight: 600; transition: all 0.2s;" onmouseover="this.style.background='rgba(16,185,129,0.2)'" onmouseout="this.style.background='rgba(16,185,129,0.12)'">Try Naurra Free</a>
      </nav>
    </header>

    <!-- Hero Section -->
    <section class="hero-section">
      <div style="display: inline-block; padding: 6px 16px; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 100px; margin-bottom: 20px;">
        <span style="font-size: 12px; font-weight: 600; color: #10b981; letter-spacing: 0.08em; text-transform: uppercase;">Free Tool -- No Signup Required</span>
      </div>
      <h1 style="font-family: 'Sora', sans-serif; font-size: clamp(32px, 5vw, 52px); font-weight: 800; color: #f1f5f9; margin: 0 0 16px; line-height: 1.15; letter-spacing: -0.04em;">
        Free Gmail Signature<br/>
        <span style="background: linear-gradient(135deg, #10b981, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Generator</span>
      </h1>
      <p style="font-size: 18px; color: rgba(255,255,255,0.5); max-width: 560px; margin: 0 auto; line-height: 1.6; font-weight: 400;">
        Create a polished, professional signature for Gmail and Google Workspace. Pick a template, customize it, copy it. Done in 30 seconds.
      </p>
      <div class="feature-pills">
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">5 templates</div>
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Works with Gmail, Outlook, Apple Mail</div>
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Built for Google Workspace users</div>
      </div>
    </section>

    <section class="seo-copy">
      <p style="margin: 0 0 14px;">
        This <strong>free Gmail signature generator</strong> is built for people who want a cleaner, more professional signature without touching HTML. Use it to create a <strong>professional email signature for Gmail</strong>, Google Workspace, Outlook, or Apple Mail, then paste it directly into your email client.
      </p>
      <p style="margin: 0;">
        If your goal is outreach, sales, consulting, or founder-led communication, pair your signature with our <a href="/blog/free-email-signature-generator-outreach" style="color: #10b981; text-decoration: none; font-weight: 600;">email signature best-practices guide</a> and our <a href="/blog/how-ai-organizes-emails-summaries-bulk-replies-and-meetings" style="color: #10b981; text-decoration: none; font-weight: 600;">AI email workflow guide</a> to turn every email into a stronger conversion touchpoint.
      </p>
    </section>

    <!-- Main Tool -->
    <section class="sig-grid" style="display: flex; gap: 32px; padding-bottom: 64px; align-items: flex-start;">

      <!-- LEFT: Form -->
      <div class="sig-form" style="width: 420px; flex-shrink: 0;">
        <div class="surface-card">

          <!-- Persona Presets -->
          <div style="margin-bottom: 24px;">
            <label class="sig-label">Start with a Role</label>
            <div style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px;">
              <button class="preset-btn" data-preset="founder" type="button">
                <div style="font-size: 13px; font-weight: 700; color: #f1f5f9; margin-bottom: 4px;">Founder</div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.5;">Company-first signature with booking CTA</div>
              </button>
              <button class="preset-btn" data-preset="sales" type="button">
                <div style="font-size: 13px; font-weight: 700; color: #f1f5f9; margin-bottom: 4px;">Sales</div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.5;">Reply-focused signature built for outreach</div>
              </button>
              <button class="preset-btn" data-preset="consultant" type="button">
                <div style="font-size: 13px; font-weight: 700; color: #f1f5f9; margin-bottom: 4px;">Consultant</div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.5;">Clean authority-driven layout for clients</div>
              </button>
              <button class="preset-btn" data-preset="creator" type="button">
                <div style="font-size: 13px; font-weight: 700; color: #f1f5f9; margin-bottom: 4px;">Creator</div>
                <div style="font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.5;">Personal brand signature with social links</div>
              </button>
            </div>
          </div>

          <!-- Template Selector -->
          <div style="margin-bottom: 24px;">
            <label class="sig-label">Template</label>
            <div id="template-selector" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px;">
              <button class="tmpl-btn active" data-template="minimal" style="padding: 10px 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 600; color: #f1f5f9;">Minimal</div>
              </button>
              <button class="tmpl-btn" data-template="modern" style="padding: 10px 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; cursor: pointer; text-align: center;">
