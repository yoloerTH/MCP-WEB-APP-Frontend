      rows.push(`<tr><td style="vertical-align:middle;padding-right:6px;padding-bottom:5px;">${icon('calendar', 16)}</td><td style="padding-bottom:5px;font-size:13px;"><a href="${state.bookingUrl}" target="_blank" style="color:${c};text-decoration:none;font-weight:600;">${label}</a></td></tr>`)
    }
    if (rows.length === 0) return ''
    return `<table cellpadding="0" cellspacing="0" border="0">${rows.join('')}</table>`
  }

