---
import BaseLayout from '../../layouts/BaseLayout.astro'

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Email Signature Generator",
  "url": "https://naurra.ai/tools/email-signature",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": "Create professional email signatures for Gmail and Google Workspace. Choose from 5 templates, customize colors, add your photo or logo, and copy to clipboard.",
  "creator": {
    "@type": "Organization",
    "name": "Naurra.ai",
    "url": "https://naurra.ai"
  }
}

const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I add this signature to Gmail?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Click 'Copy HTML' in the generator, then go to Gmail Settings > General > Signature. Click in the signature editor and paste (Ctrl+V or Cmd+V). The formatted signature will appear with all your styling intact."
      }
    },
    {
      "@type": "Question",
      "name": "Is this email signature generator really free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, completely free with no signup required. Generate unlimited signatures, use any template, and copy them as many times as you need."
      }
    },
    {
      "@type": "Question",
      "name": "Will my signature look the same on all email clients?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The signatures use table-based HTML that is compatible with all major email clients including Gmail, Outlook, Apple Mail, and Yahoo Mail. We avoid CSS that might break in certain clients."
      }
    },
    {
      "@type": "Question",
      "name": "Can I add my company logo or profile photo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can upload an image directly or paste a URL to any publicly hosted image. For best results, use a square image under 200x200 pixels for profile photos, or a horizontal image for logos."
      }
    },
    {
      "@type": "Question",
      "name": "What image format works best for email signatures?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PNG or JPG work best. For logos with transparency, use PNG. Keep file sizes under 100KB for fast loading. If uploading directly, the generator will embed the image as base64 so it travels with the signature."
      }
    }
  ]
}
---

<BaseLayout
  title="Free Email Signature Generator for Gmail & Google Workspace"
  description="Create professional email signatures in seconds. 5 beautiful templates, custom colors, image upload, one-click copy to Gmail. No signup required."
  keywords="email signature generator, Gmail signature, Google Workspace signature, free email signature maker, professional email signature, HTML email signature, business email signature"
  url="https://naurra.ai/tools/email-signature"
  structuredData={[structuredData, faqData]}
>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

  .sig-page { font-family: 'Outfit', sans-serif; }

  /* Noise texture overlay */
  .noise-bg::before {
    content: '';
    position: fixed;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  /* Template thumbnails */
  .tmpl-btn { transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
  .tmpl-btn:hover { transform: translateY(-2px); }
  .tmpl-btn.active {
    outline: 2px solid #10b981;
    outline-offset: 2px;
    background: rgba(16, 185, 129, 0.08);
  }

  /* Form inputs */
  .sig-input {
    width: 100%;
    padding: 10px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    transition: all 0.2s;
    outline: none;
  }
  .sig-input:focus {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
  .sig-input::placeholder { color: rgba(255,255,255,0.25); }

  .sig-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 6px;
  }

  /* Color swatches */
  .color-swatch {
    width: 28px; height: 28px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    border: 2px solid transparent;
  }
  .color-swatch:hover { transform: scale(1.15); }
  .color-swatch.active { border-color: white; box-shadow: 0 0 12px rgba(255,255,255,0.2); }

  /* Preview card */
  .preview-card {
    background: #ffffff;
    border-radius: 8px;
    padding: 28px;
    color: #1a1a1a;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.4;
    min-height: 120px;
  }

  /* Copy buttons */
  .copy-btn {
    padding: 12px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    letter-spacing: 0.02em;
  }
  .copy-btn:hover { transform: translateY(-1px); }
  .copy-btn:active { transform: translateY(0); }

  .copy-btn-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
  }
  .copy-btn-primary:hover { box-shadow: 0 6px 28px rgba(16, 185, 129, 0.4); }

  .copy-btn-secondary {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .copy-btn-secondary:hover { background: rgba(255,255,255,0.1); color: white; }

  /* Image upload zone */
  .upload-zone {
    border: 2px dashed rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .upload-zone:hover {
    border-color: rgba(16, 185, 129, 0.4);
    background: rgba(16, 185, 129, 0.04);
  }
  .upload-zone.has-image {
    border-style: solid;
    border-color: rgba(16, 185, 129, 0.3);
    padding: 8px;
  }

  /* Toast notification */
  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #10b981;
    color: white;
    padding: 14px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    box-shadow: 0 8px 32px rgba(16, 185, 129, 0.4);
    z-index: 1000;
    opacity: 0;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Section divider */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(16,185,129,0.2), transparent);
    margin: 20px 0;
  }

  /* FAQ */
  .faq-item { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .faq-q {
    width: 100%;
    text-align: left;
    padding: 20px 0;
    background: none;
    border: none;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-q:hover { color: #10b981; }
  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    color: rgba(255,255,255,0.6);
    font-size: 15px;
    line-height: 1.7;
  }
  .faq-a.open { max-height: 300px; padding-bottom: 20px; }
  .faq-chevron { transition: transform 0.3s; width: 20px; height: 20px; flex-shrink: 0; }
  .faq-chevron.open { transform: rotate(180deg); }

  /* Responsive */
  @media (max-width: 1024px) {
    .sig-grid { flex-direction: column !important; }
    .sig-form, .sig-preview { width: 100% !important; }
  }
</style>

<div class="sig-page noise-bg" style="min-height: 100vh; background: #0a0e1a; position: relative;">
  <!-- Ambient glow -->
  <div style="position: fixed; inset: 0; pointer-events: none; z-index: 0;">
    <div style="position: absolute; top: -20%; left: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%); border-radius: 50%;"></div>
    <div style="position: absolute; bottom: -10%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(245,158,11,0.04) 0%, transparent 70%); border-radius: 50%;"></div>
  </div>

  <div style="position: relative; z-index: 1; max-width: 1280px; margin: 0 auto; padding: 0 24px;">

    <!-- Header -->
    <header style="padding: 32px 0 16px; display: flex; align-items: center; justify-content: space-between;">
      <a href="/" style="display: flex; align-items: center; gap: 12px; text-decoration: none;">
        <img src="/logo-transparent.png" alt="Naurra.ai" style="width: 36px; height: 36px; object-fit: contain;" />
        <span style="font-size: 20px; font-weight: 700; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Naurra.ai</span>
      </a>
      <nav style="display: flex; gap: 24px; align-items: center;">
        <a href="/blog" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Blog</a>
        <a href="/pricing" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Pricing</a>
        <a href="/" style="padding: 8px 20px; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); border-radius: 8px; color: #10b981; text-decoration: none; font-size: 13px; font-weight: 600; transition: all 0.2s;" onmouseover="this.style.background='rgba(16,185,129,0.2)'" onmouseout="this.style.background='rgba(16,185,129,0.12)'">Try Naurra Free</a>
      </nav>
    </header>

    <!-- Hero Section -->
    <section style="text-align: center; padding: 48px 0 40px;">
      <div style="display: inline-block; padding: 6px 16px; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 100px; margin-bottom: 20px;">
        <span style="font-size: 12px; font-weight: 600; color: #10b981; letter-spacing: 0.08em; text-transform: uppercase;">Free Tool -- No Signup Required</span>
      </div>
      <h1 style="font-size: clamp(32px, 5vw, 52px); font-weight: 800; color: #f1f5f9; margin: 0 0 16px; line-height: 1.15; letter-spacing: -0.02em;">
        Email Signature<br/>
        <span style="background: linear-gradient(135deg, #10b981, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Generator</span>
      </h1>
      <p style="font-size: 18px; color: rgba(255,255,255,0.5); max-width: 560px; margin: 0 auto; line-height: 1.6; font-weight: 400;">
        Create a polished, professional signature for Gmail and Google Workspace. Pick a template, customize it, copy it. Done in 30 seconds.
      </p>
    </section>

    <!-- Main Tool -->
    <section class="sig-grid" style="display: flex; gap: 32px; padding-bottom: 64px; align-items: flex-start;">

      <!-- LEFT: Form -->
      <div class="sig-form" style="width: 420px; flex-shrink: 0;">
        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px; padding: 28px; backdrop-filter: blur(12px);">

          <!-- Template Selector -->
          <div style="margin-bottom: 24px;">
            <label class="sig-label">Template</label>
            <div id="template-selector" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px;">
              <button class="tmpl-btn active" data-template="minimal" style="padding: 10px 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 600; color: #f1f5f9;">Minimal</div>
              </button>
              <button class="tmpl-btn" data-template="modern" style="padding: 10px 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 600; color: #f1f5f9;">Modern</div>
              </button>
              <button class="tmpl-btn" data-template="corporate" style="padding: 10px 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 600; color: #f1f5f9;">Corporate</div>
              </button>
              <button class="tmpl-btn" data-template="creative" style="padding: 10px 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 600; color: #f1f5f9;">Creative</div>
              </button>
              <button class="tmpl-btn" data-template="compact" style="padding: 10px 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 600; color: #f1f5f9;">Compact</div>
              </button>
            </div>
          </div>

          <!-- Color Selector -->
          <div style="margin-bottom: 24px;">
            <label class="sig-label">Accent Color</label>
            <div id="color-selector" style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
              <div class="color-swatch active" data-color="#10b981" style="background: #10b981;" title="Emerald"></div>
              <div class="color-swatch" data-color="#3b82f6" style="background: #3b82f6;" title="Blue"></div>
              <div class="color-swatch" data-color="#8b5cf6" style="background: #8b5cf6;" title="Violet"></div>
              <div class="color-swatch" data-color="#ef4444" style="background: #ef4444;" title="Red"></div>
              <div class="color-swatch" data-color="#f59e0b" style="background: #f59e0b;" title="Amber"></div>
              <div class="color-swatch" data-color="#ec4899" style="background: #ec4899;" title="Pink"></div>
              <div class="color-swatch" data-color="#06b6d4" style="background: #06b6d4;" title="Cyan"></div>
              <div class="color-swatch" data-color="#1a1a1a" style="background: #1a1a1a;" title="Black"></div>
              <div style="position: relative;">
                <input type="color" id="custom-color" value="#10b981" style="width: 28px; height: 28px; border: 2px solid rgba(255,255,255,0.15); border-radius: 8px; cursor: pointer; background: none; padding: 0;" title="Custom color" />
              </div>
            </div>
          </div>

          <div class="section-divider"></div>

          <!-- Personal Info -->
          <div style="display: grid; gap: 14px; margin-bottom: 20px;">
            <div>
              <label class="sig-label">Full Name</label>
              <input class="sig-input" id="sig-name" type="text" placeholder="Sarah Chen" />
            </div>
            <div>
              <label class="sig-label">Job Title</label>
              <input class="sig-input" id="sig-title" type="text" placeholder="Marketing Director" />
            </div>
            <div>
              <label class="sig-label">Company</label>
              <input class="sig-input" id="sig-company" type="text" placeholder="Acme Inc." />
            </div>
          </div>

          <div class="section-divider"></div>

          <!-- Contact Info -->
          <div style="display: grid; gap: 14px; margin-bottom: 20px;">
            <div>
              <label class="sig-label">Email</label>
              <input class="sig-input" id="sig-email" type="email" placeholder="sarah@acme.com" />
            </div>
            <div>
              <label class="sig-label">Phone</label>
              <input class="sig-input" id="sig-phone" type="tel" placeholder="+1 (555) 123-4567" />
            </div>
            <div>
              <label class="sig-label">Website</label>
              <input class="sig-input" id="sig-website" type="url" placeholder="https://acme.com" />
            </div>
          </div>

          <div class="section-divider"></div>

          <!-- Social Links -->
          <div style="display: grid; gap: 14px; margin-bottom: 20px;">
            <div>
              <label class="sig-label">LinkedIn URL</label>
              <input class="sig-input" id="sig-linkedin" type="url" placeholder="https://linkedin.com/in/sarahchen" />
            </div>
            <div>
              <label class="sig-label">Twitter / X URL</label>
              <input class="sig-input" id="sig-twitter" type="url" placeholder="https://x.com/sarahchen" />
            </div>
            <div>
              <label class="sig-label">Instagram URL <span style="color: rgba(255,255,255,0.25); text-transform: none; font-weight: 400;">(optional)</span></label>
              <input class="sig-input" id="sig-instagram" type="url" placeholder="https://instagram.com/sarahchen" />
            </div>
          </div>

          <div class="section-divider"></div>

          <!-- Image Upload -->
          <div style="margin-bottom: 8px;">
            <label class="sig-label">Photo or Logo <span style="color: rgba(255,255,255,0.25); text-transform: none; font-weight: 400;">(optional)</span></label>
            <div id="upload-zone" class="upload-zone">
              <input type="file" id="sig-image-file" accept="image/png,image/jpeg,image/gif,image/webp" style="display: none;" />
              <div id="upload-placeholder">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" style="margin: 0 auto 8px;">
                  <rect x="3" y="3" width="18" height="18" rx="3"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <path d="M21 15l-5-5L5 21"/>
                </svg>
                <div style="font-size: 13px; color: rgba(255,255,255,0.45); font-weight: 500;">Click to upload or drag an image</div>
                <div style="font-size: 11px; color: rgba(255,255,255,0.25); margin-top: 4px;">PNG, JPG, GIF up to 500KB</div>
              </div>
              <div id="upload-preview" style="display: none; position: relative;">
                <img id="upload-preview-img" style="max-width: 80px; max-height: 80px; border-radius: 8px; object-fit: cover;" />
                <button id="upload-remove" style="position: absolute; top: -6px; right: -6px; width: 22px; height: 22px; background: #ef4444; border: 2px solid #0a0e1a; border-radius: 50%; color: white; font-size: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; font-weight: 700;">&times;</button>
              </div>
            </div>
            <div style="margin-top: 8px;">
              <label class="sig-label">Or paste image URL</label>
              <input class="sig-input" id="sig-image-url" type="url" placeholder="https://example.com/photo.jpg" />
            </div>
          </div>

        </div>
      </div>

      <!-- RIGHT: Preview + Actions -->
      <div class="sig-preview" style="flex: 1; min-width: 0;">
        <div style="position: sticky; top: 24px;">

          <!-- Preview -->
          <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px; padding: 28px; backdrop-filter: blur(12px); margin-bottom: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
              <label class="sig-label" style="margin-bottom: 0;">Live Preview</label>
              <span style="font-size: 11px; color: rgba(255,255,255,0.25); font-weight: 500;">Updates as you type</span>
            </div>

            <!-- Email mockup frame -->
            <div style="background: #f8f9fa; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;">
              <!-- Email header bar -->
              <div style="background: #ffffff; padding: 12px 16px; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; gap: 8px;">
                <div style="width: 8px; height: 8px; border-radius: 50%; background: #ef4444;"></div>
                <div style="width: 8px; height: 8px; border-radius: 50%; background: #f59e0b;"></div>
                <div style="width: 8px; height: 8px; border-radius: 50%; background: #22c55e;"></div>
                <span style="margin-left: 8px; font-size: 12px; color: #9ca3af; font-family: -apple-system, sans-serif;">New Message</span>
              </div>
              <!-- Signature area -->
              <div style="background: #ffffff; padding: 20px;">
                <div style="color: #6b7280; font-size: 13px; font-family: -apple-system, sans-serif; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid #f3f4f6;">Thanks for getting back to me. Looking forward to our call next week.</div>
                <div style="color: #9ca3af; font-size: 13px; font-family: -apple-system, sans-serif; margin-bottom: 12px;">--</div>
                <div id="signature-preview" class="preview-card" style="padding: 0; border-radius: 0; min-height: 60px;"></div>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div style="display: flex; gap: 12px; margin-bottom: 20px;">
            <button id="btn-copy-html" class="copy-btn copy-btn-primary" style="flex: 1;">Copy HTML Signature</button>
            <button id="btn-copy-text" class="copy-btn copy-btn-secondary">Copy Plain Text</button>
          </div>

          <!-- Gmail Instructions -->
          <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 20px;">
            <h2 style="font-size: 14px; font-weight: 700; color: #f1f5f9; margin: 0 0 12px;">How to Add to Gmail</h2>
            <ol style="margin: 0; padding-left: 20px; color: rgba(255,255,255,0.5); font-size: 13px; line-height: 1.8;">
              <li>Click <strong style="color: rgba(255,255,255,0.8);">Copy HTML Signature</strong> above</li>
              <li>Open Gmail and go to <strong style="color: rgba(255,255,255,0.8);">Settings</strong> (gear icon)</li>
              <li>Click <strong style="color: rgba(255,255,255,0.8);">See all settings</strong></li>
              <li>Scroll to <strong style="color: rgba(255,255,255,0.8);">Signature</strong> section</li>
              <li>Click in the signature editor and paste (<strong style="color: rgba(255,255,255,0.8);">Ctrl+V</strong> or <strong style="color: rgba(255,255,255,0.8);">Cmd+V</strong>)</li>
              <li>Click <strong style="color: rgba(255,255,255,0.8);">Save Changes</strong> at the bottom</li>
            </ol>
          </div>

        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section style="max-width: 720px; margin: 0 auto; padding: 32px 0 80px;">
      <h2 style="font-size: 28px; font-weight: 800; color: #f1f5f9; text-align: center; margin-bottom: 40px; letter-spacing: -0.02em;">Frequently Asked Questions</h2>

      <div id="faq-list">
        <div class="faq-item">
          <button class="faq-q">
            How do I add this signature to Gmail?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-a">Click "Copy HTML Signature", then open Gmail Settings, scroll to the Signature section, click inside the editor, and paste. Gmail will render the full formatted signature with colors, layout, and links intact.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">
            Is this generator really free?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-a">Yes, completely free with no signup, no watermark, no limits. Generate as many signatures as you want and use them anywhere.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">
            Will it look the same on all email clients?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-a">The signatures use table-based HTML compatible with Gmail, Outlook, Apple Mail, Yahoo Mail, and most other clients. We avoid modern CSS that can break in older email renderers.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">
            Can I add my photo or company logo?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-a">Yes. Upload an image directly (PNG, JPG, or GIF) or paste a URL to a publicly hosted image. Uploaded images are embedded as base64 so they travel with the signature. For best results, use images under 200x200px and 500KB.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">
            Does it work with Outlook and Apple Mail?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="faq-a">Yes. Copy the HTML signature and paste it into any email client's signature settings. The table-based layout ensures consistent rendering across all major platforms.</div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer style="text-align: center; padding: 32px 0; border-top: 1px solid rgba(255,255,255,0.06);">
      <a href="/" style="color: rgba(255,255,255,0.3); text-decoration: none; font-size: 13px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
        Made by Naurra.ai -- AI Voice Assistant for Google Workspace
      </a>
    </footer>
  </div>

  <!-- Toast -->
  <div id="toast" class="toast">Copied to clipboard</div>
</div>

<script>
  // @ts-nocheck
  // =========================================
  // EMAIL SIGNATURE GENERATOR ENGINE
  // =========================================

  const state = {
    template: 'minimal',
    color: '#10b981',
    name: '',
    title: '',
    company: '',
    email: '',
    phone: '',
    website: '',
    linkedin: '',
    twitter: '',
    instagram: '',
    imageData: '',
    imageUrl: ''
  }

  // Social icon SVGs (inline for email compatibility)
  const icons = {
    linkedin: (color) => `<a href="__URL__" target="_blank" style="text-decoration:none;display:inline-block;margin-right:6px;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="${color}"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>`,
    twitter: (color) => `<a href="__URL__" target="_blank" style="text-decoration:none;display:inline-block;margin-right:6px;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="${color}"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>`,
    instagram: (color) => `<a href="__URL__" target="_blank" style="text-decoration:none;display:inline-block;margin-right:6px;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="${color}"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>`,
    email: (color) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>`,
    phone: (color) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>`,
    web: (color) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`
  }

  function getImage() {
    return state.imageData || state.imageUrl || ''
  }

  function socialBlock(c) {
    let html = ''
    if (state.linkedin) html += icons.linkedin(c).replace('__URL__', state.linkedin)
    if (state.twitter) html += icons.twitter(c).replace('__URL__', state.twitter)
    if (state.instagram) html += icons.instagram(c).replace('__URL__', state.instagram)
    return html
  }

  function contactLine(c) {
    let parts = []
    if (state.email) parts.push(`<a href="mailto:${state.email}" style="color:${c};text-decoration:none;">${icons.email(c)}${state.email}</a>`)
    if (state.phone) parts.push(`<span style="color:#555;">${icons.phone(c)}${state.phone}</span>`)
    if (state.website) {
      const display = state.website.replace(/^https?:\/\//, '').replace(/\/$/, '')
      parts.push(`<a href="${state.website}" target="_blank" style="color:${c};text-decoration:none;">${icons.web(c)}${display}</a>`)
    }
    return parts.join('&nbsp;&nbsp;<span style="color:#ccc;">|</span>&nbsp;&nbsp;')
  }

  function imgTag(size, radius) {
    const src = getImage()
    if (!src) return ''
    return `<img src="${src}" width="${size}" height="${size}" style="width:${size}px;height:${size}px;border-radius:${radius};object-fit:cover;display:block;" alt="${state.name || 'Photo'}" />`
  }

  // =========================================
  // TEMPLATE RENDERERS
  // =========================================

  const templates = {
    minimal(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#333;">
        <tr>
          ${img ? `<td style="padding-right:14px;vertical-align:top;">${imgTag(56, '50%')}</td>` : ''}
          <td style="vertical-align:top;">
            <div style="font-size:16px;font-weight:700;color:#1a1a1a;margin-bottom:2px;">${state.name || 'Your Name'}</div>
            ${state.title || state.company ? `<div style="font-size:13px;color:#666;margin-bottom:6px;">${[state.title, state.company].filter(Boolean).join(' / ')}</div>` : ''}
            <div style="font-size:12px;line-height:1.8;">${contactLine(c)}</div>
            ${socialBlock(c) ? `<div style="margin-top:8px;">${socialBlock(c)}</div>` : ''}
          </td>
        </tr>
      </table>`
    },

    modern(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#333;">
        <tr>
          <td style="width:4px;background:${c};border-radius:4px;"></td>
          <td style="padding-left:16px;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                ${img ? `<td style="padding-right:14px;vertical-align:top;">${imgTag(64, '10px')}</td>` : ''}
                <td style="vertical-align:top;">
                  <div style="font-size:17px;font-weight:700;color:#1a1a1a;">${state.name || 'Your Name'}</div>
                  ${state.title ? `<div style="font-size:13px;font-weight:600;color:${c};margin-top:2px;">${state.title}</div>` : ''}
                  ${state.company ? `<div style="font-size:13px;color:#666;margin-top:1px;">${state.company}</div>` : ''}
                </td>
              </tr>
            </table>
            <div style="border-top:1px solid #e5e7eb;margin:10px 0;"></div>
            <div style="font-size:12px;line-height:1.8;">${contactLine(c)}</div>
            ${socialBlock(c) ? `<div style="margin-top:8px;">${socialBlock(c)}</div>` : ''}
          </td>
        </tr>
      </table>`
    },

    corporate(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#333;border-top:3px solid ${c};padding-top:12px;">
        <tr>
          ${img ? `<td style="padding-right:16px;vertical-align:top;">${imgTag(72, '6px')}</td>` : ''}
          <td style="vertical-align:top;">
            <div style="font-size:18px;font-weight:700;color:#1a1a1a;text-transform:uppercase;letter-spacing:0.5px;">${state.name || 'Your Name'}</div>
            ${state.title ? `<div style="font-size:13px;color:#555;margin-top:3px;">${state.title}</div>` : ''}
            ${state.company ? `<div style="font-size:13px;font-weight:600;color:${c};margin-top:1px;">${state.company}</div>` : ''}
            <div style="border-top:1px solid #e5e7eb;margin:10px 0;"></div>
            ${state.email ? `<div style="font-size:12px;margin-bottom:3px;">${icons.email(c)}<a href="mailto:${state.email}" style="color:#333;text-decoration:none;">${state.email}</a></div>` : ''}
            ${state.phone ? `<div style="font-size:12px;margin-bottom:3px;">${icons.phone(c)}<span>${state.phone}</span></div>` : ''}
            ${state.website ? `<div style="font-size:12px;margin-bottom:3px;">${icons.web(c)}<a href="${state.website}" target="_blank" style="color:#333;text-decoration:none;">${state.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a></div>` : ''}
            ${socialBlock(c) ? `<div style="margin-top:10px;">${socialBlock(c)}</div>` : ''}
          </td>
        </tr>
      </table>`
    },

    creative(c) {
      const img = getImage()
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#333;">
        <tr>
          ${img ? `<td style="padding-right:16px;vertical-align:top;">${imgTag(70, '50%')}</td>` : ''}
          <td style="vertical-align:top;">
            <div style="font-size:22px;font-weight:800;color:${c};line-height:1.1;">${state.name || 'Your Name'}</div>
            ${state.title || state.company ? `<div style="font-size:13px;color:#555;margin-top:4px;margin-bottom:8px;">${[state.title, state.company].filter(Boolean).join(' at ')}</div>` : '<div style="margin-bottom:8px;"></div>'}
            <table cellpadding="0" cellspacing="0" border="0"><tr>
              <td style="background:${c};padding:6px 14px;border-radius:4px;">
                ${state.email ? `<a href="mailto:${state.email}" style="color:#fff;text-decoration:none;font-size:12px;font-weight:600;">${state.email}</a>` : `<span style="color:#fff;font-size:12px;font-weight:600;">your@email.com</span>`}
              </td>
              ${state.phone ? `<td style="padding-left:10px;font-size:12px;color:#666;">${state.phone}</td>` : ''}
            </tr></table>
            ${state.website || socialBlock(c) ? `<div style="margin-top:10px;">
              ${state.website ? `<a href="${state.website}" target="_blank" style="color:${c};text-decoration:none;font-size:12px;font-weight:600;margin-right:12px;">${state.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a>` : ''}
              ${socialBlock(c)}
            </div>` : ''}
          </td>
        </tr>
      </table>`
    },

    compact(c) {
      const img = getImage()
      const parts = [state.title, state.company].filter(Boolean).join(' / ')
      const contact = [state.email, state.phone, state.website ? state.website.replace(/^https?:\/\//, '').replace(/\/$/, '') : ''].filter(Boolean)
      return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:13px;color:#333;">
        <tr>
          ${img ? `<td style="padding-right:10px;vertical-align:middle;">${imgTag(40, '50%')}</td>` : ''}
          <td style="vertical-align:middle;">
            <span style="font-weight:700;color:#1a1a1a;">${state.name || 'Your Name'}</span>${parts ? `<span style="color:#999;"> &nbsp;/&nbsp; </span><span style="color:#666;">${parts}</span>` : ''}
            <br/>
            <span style="font-size:12px;color:#888;">${contact.join(' &nbsp;&middot;&nbsp; ')}</span>
            ${socialBlock(c) ? `<span style="margin-left:8px;">${socialBlock(c)}</span>` : ''}
          </td>
        </tr>
      </table>`
    }
  }

  // =========================================
  // RENDER + EVENT WIRING
  // =========================================

  function render() {
    const html = templates[state.template](state.color)
    document.getElementById('signature-preview').innerHTML = html
  }

  function showToast(msg) {
    const t = document.getElementById('toast')
    t.textContent = msg
    t.classList.add('show')
    setTimeout(() => t.classList.remove('show'), 2200)
  }

  // Input bindings
  const fieldMap = {
    'sig-name': 'name', 'sig-title': 'title', 'sig-company': 'company',
    'sig-email': 'email', 'sig-phone': 'phone', 'sig-website': 'website',
    'sig-linkedin': 'linkedin', 'sig-twitter': 'twitter', 'sig-instagram': 'instagram',
    'sig-image-url': 'imageUrl'
  }

  Object.entries(fieldMap).forEach(([id, key]) => {
    const el = document.getElementById(id)
    if (el) {
      el.addEventListener('input', () => {
        state[key] = el.value
        render()
      })
    }
  })

  // Template selector
  document.getElementById('template-selector').addEventListener('click', (e) => {
    const btn = e.target.closest('[data-template]')
    if (!btn) return
    document.querySelectorAll('.tmpl-btn').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    state.template = btn.dataset.template
    render()
  })

  // Color selector
  document.getElementById('color-selector').addEventListener('click', (e) => {
    const swatch = e.target.closest('.color-swatch')
    if (!swatch) return
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'))
    swatch.classList.add('active')
    state.color = swatch.dataset.color
    document.getElementById('custom-color').value = state.color
    render()
  })

  document.getElementById('custom-color').addEventListener('input', (e) => {
    state.color = e.target.value
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'))
    render()
  })

  // Image upload
  const uploadZone = document.getElementById('upload-zone')
  const fileInput = document.getElementById('sig-image-file')
  const placeholder = document.getElementById('upload-placeholder')
  const previewWrap = document.getElementById('upload-preview')
  const previewImg = document.getElementById('upload-preview-img')

  uploadZone.addEventListener('click', (e) => {
    if (e.target.closest('#upload-remove')) return
    fileInput.click()
  })

  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.style.borderColor = 'rgba(16,185,129,0.5)' })
  uploadZone.addEventListener('dragleave', () => { uploadZone.style.borderColor = '' })
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault()
    uploadZone.style.borderColor = ''
    if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0])
  })

  fileInput.addEventListener('change', () => {
    if (fileInput.files.length) handleFile(fileInput.files[0])
  })

  function handleFile(file) {
    if (file.size > 512000) { showToast('Image must be under 500KB'); return }
    const reader = new FileReader()
    reader.onload = (e) => {
      state.imageData = e.target.result
      state.imageUrl = ''
      document.getElementById('sig-image-url').value = ''
      showUploadPreview(state.imageData)
      render()
    }
    reader.readAsDataURL(file)
  }

  function showUploadPreview(src) {
    placeholder.style.display = 'none'
    previewWrap.style.display = 'block'
    previewImg.src = src
    uploadZone.classList.add('has-image')
  }

  function clearUpload() {
    state.imageData = ''
    fileInput.value = ''
    placeholder.style.display = ''
    previewWrap.style.display = 'none'
    uploadZone.classList.remove('has-image')
    render()
  }

  document.getElementById('upload-remove').addEventListener('click', (e) => {
    e.stopPropagation()
    clearUpload()
  })

  // Image URL input also clears file upload
  document.getElementById('sig-image-url').addEventListener('input', () => {
    if (state.imageUrl && state.imageData) {
      state.imageData = ''
      fileInput.value = ''
      placeholder.style.display = ''
      previewWrap.style.display = 'none'
      uploadZone.classList.remove('has-image')
    }
  })

  // Copy buttons
  document.getElementById('btn-copy-html').addEventListener('click', async () => {
    const html = templates[state.template](state.color)
    try {
      await navigator.clipboard.write([
        new ClipboardItem({
          'text/html': new Blob([html], { type: 'text/html' }),
          'text/plain': new Blob([htmlToPlainText(html)], { type: 'text/plain' })
        })
      ])
      showToast('HTML signature copied -- paste into Gmail')
    } catch {
      // Fallback
      const ta = document.createElement('textarea')
      ta.value = html
      document.body.appendChild(ta)
      ta.select()
      document.execCommand('copy')
      document.body.removeChild(ta)
      showToast('Signature HTML copied')
    }
  })

  document.getElementById('btn-copy-text').addEventListener('click', async () => {
    const html = templates[state.template](state.color)
    const text = htmlToPlainText(html)
    try {
      await navigator.clipboard.writeText(text)
      showToast('Plain text copied')
    } catch {
      const ta = document.createElement('textarea')
      ta.value = text
      document.body.appendChild(ta)
      ta.select()
      document.execCommand('copy')
      document.body.removeChild(ta)
      showToast('Plain text copied')
    }
  })

  function htmlToPlainText(html) {
    const div = document.createElement('div')
    div.innerHTML = html
    // Replace <br> and block elements with newlines
    div.querySelectorAll('br').forEach(br => br.replaceWith('\n'))
    div.querySelectorAll('div, tr').forEach(el => el.append('\n'))
    let text = div.textContent || ''
    // Clean up
    text = text.replace(/\n{3,}/g, '\n\n').trim()
    // Build plain text manually for cleanliness
    const lines = []
    if (state.name) lines.push(state.name)
    if (state.title && state.company) lines.push(`${state.title} / ${state.company}`)
    else if (state.title) lines.push(state.title)
    else if (state.company) lines.push(state.company)
    if (state.email) lines.push(state.email)
    if (state.phone) lines.push(state.phone)
    if (state.website) lines.push(state.website)
    const socials = [state.linkedin, state.twitter, state.instagram].filter(Boolean)
    if (socials.length) lines.push(socials.join(' | '))
    return lines.join('\n')
  }

  // FAQ toggles
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling
      const chevron = btn.querySelector('.faq-chevron')
      const isOpen = answer.classList.contains('open')

      // Close all
      document.querySelectorAll('.faq-a').forEach(a => a.classList.remove('open'))
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('open'))

      if (!isOpen) {
        answer.classList.add('open')
        chevron.classList.add('open')
      }
    })
  })

  // Initial render
  render()
</script>

</BaseLayout>
