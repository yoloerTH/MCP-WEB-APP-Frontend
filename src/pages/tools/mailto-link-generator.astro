<div class="toast" id="toast">Copied!</div>

<script is:inline>
  (function() {
    var toEl = document.getElementById('mailto-to')
    var ccEl = document.getElementById('mailto-cc')
    var bccEl = document.getElementById('mailto-bcc')
    var subjectEl = document.getElementById('mailto-subject')
    var bodyEl = document.getElementById('mailto-body')
    var linkTextEl = document.getElementById('mailto-linktext')
    var previewLink = document.getElementById('preview-link')
    var previewHtml = document.getElementById('preview-html')
    var previewRendered = document.getElementById('preview-rendered')
    var charCount = document.getElementById('char-count')

    function buildMailto() {
      var to = (toEl.value || '').trim()
      var cc = (ccEl.value || '').trim()
      var bcc = (bccEl.value || '').trim()
      var subject = (subjectEl.value || '').trim()
      var body = (bodyEl.value || '').trim()
      var params = []
      if (cc) params.push('cc=' + encodeURIComponent(cc))
      if (bcc) params.push('bcc=' + encodeURIComponent(bcc))
      if (subject) params.push('subject=' + encodeURIComponent(subject))
      if (body) params.push('body=' + encodeURIComponent(body))
      var mailto = 'mailto:' + encodeURIComponent(to)
      if (params.length) mailto += '?' + params.join('&')
      return mailto
    }

    function escapeHtmlStr(s) {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
    }

    function render() {
      var mailto = buildMailto()
      var linkText = (linkTextEl.value || 'Email us').trim()
      previewLink.textContent = mailto
      previewHtml.textContent = '<a href="' + mailto + '">' + linkText + '</a>'
      previewRendered.textContent = linkText
      previewRendered.href = mailto
      charCount.textContent = mailto.length + ' chars'
      charCount.style.color = mailto.length > 2000 ? '#f87171' : 'rgba(255,255,255,0.3)'
    }

    // Bind inputs
    ;[toEl, ccEl, bccEl, subjectEl, bodyEl, linkTextEl].forEach(function(el) {
      el.addEventListener('input', render)
    })

    // Presets
    var presets = {
      support: { to: 'support@yourcompany.com', subject: 'Support Request', body: 'Hi,\n\nI need help with the following issue:\n\n[Describe your issue here]\n\nThank you.' },
      feedback: { to: 'feedback@yourcompany.com', subject: 'Product Feedback', body: 'Hi,\n\nI\'d like to share some feedback:\n\nWhat I like:\n\nWhat could be improved:\n\nThank you.' },
      meeting: { to: '', subject: 'Meeting Request', body: 'Hi,\n\nI\'d like to schedule a meeting to discuss:\n\nPreferred times:\n- \n- \n\nLooking forward to hearing from you.' },
      sales: { to: 'sales@yourcompany.com', subject: 'Pricing Inquiry', body: 'Hi,\n\nI\'m interested in learning more about your pricing for:\n\nCompany size: \nUse case: \n\nThank you.' }
    }

    document.querySelectorAll('.preset-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var key = this.getAttribute('data-preset')
        var p = presets[key]
        if (!p) return
        toEl.value = p.to || ''
        ccEl.value = ''
        bccEl.value = ''
        subjectEl.value = p.subject || ''
        bodyEl.value = p.body || ''
        render()
      })
    })

    // Copy mailto link
    document.getElementById('btn-copy-link').addEventListener('click', function() {
      var mailto = buildMailto()
      navigator.clipboard.writeText(mailto).then(function() {
        showToast('Mailto link copied')
      }).catch(function() {
        fallbackCopy(mailto, 'Mailto link copied')
      })
    })

    // Copy HTML
    document.getElementById('btn-copy-html').addEventListener('click', function() {
      var mailto = buildMailto()
      var linkText = (linkTextEl.value || 'Email us').trim()
      var html = '<a href="' + mailto + '">' + escapeHtmlStr(linkText) + '</a>'
      navigator.clipboard.writeText(html).then(function() {
        showToast('HTML code copied')
      }).catch(function() {
        fallbackCopy(html, 'HTML code copied')
      })
    })

    // Test link
    document.getElementById('btn-test').addEventListener('click', function() {
      var mailto = buildMailto()
      window.location.href = mailto
    })

    function fallbackCopy(text, msg) {
      var ta = document.createElement('textarea')
      ta.value = text
      document.body.appendChild(ta)
      ta.select()
      document.execCommand('copy')
      document.body.removeChild(ta)
      showToast(msg)
    }

    function showToast(msg) {
      var t = document.getElementById('toast')
      t.textContent = msg
      t.classList.add('show')
      setTimeout(function() { t.classList.remove('show') }, 2200)
    }

    // FAQ
    document.querySelectorAll('.faq-q').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var answer = btn.nextElementSibling
        var chevron = btn.querySelector('.faq-chevron')
        var isOpen = answer.classList.contains('open')
        document.querySelectorAll('.faq-a').forEach(function(a) { a.classList.remove('open') })
        document.querySelectorAll('.faq-chevron').forEach(function(c) { c.classList.remove('open') })
        if (!isOpen) {
          answer.classList.add('open')
          chevron.classList.add('open')
        }
      })
    })

    render()
  })()
</script>

