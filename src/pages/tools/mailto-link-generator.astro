---
import BaseLayout from '../../layouts/BaseLayout.astro'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Free Tools', item: 'https://naurra.ai/tools' },
    { '@type': 'ListItem', position: 3, name: 'Mailto Link Generator', item: 'https://naurra.ai/tools/mailto-link-generator' }
  ]
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Free Mailto Link Generator',
  url: 'https://naurra.ai/tools/mailto-link-generator',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Generate mailto links with pre-filled subject, body, CC, and BCC fields. Free, no signup required.',
  creator: { '@type': 'Organization', name: 'Naurra.ai', url: 'https://naurra.ai' }
}

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a mailto link?',
      acceptedAnswer: { '@type': 'Answer', text: 'A mailto link is an HTML hyperlink that opens the user\'s default email client with pre-filled fields like recipient, subject, body, CC, and BCC. It uses the mailto: protocol instead of http:// or https://.' }
    },
    {
      '@type': 'Question',
      name: 'Do mailto links work on mobile devices?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. Mailto links work on iOS (opens Mail or Gmail), Android (opens Gmail or default mail app), and desktop browsers. The user\'s default email client opens automatically.' }
    },
    {
      '@type': 'Question',
      name: 'Can I pre-fill the email body in a mailto link?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. Add a body= parameter to the mailto URL. Line breaks use %0A and spaces use %20. This generator handles all encoding automatically.' }
    },
    {
      '@type': 'Question',
      name: 'Is there a character limit for mailto links?',
      acceptedAnswer: { '@type': 'Answer', text: 'Technically, URLs should stay under 2,000 characters for broad compatibility. Very long email bodies may get truncated in some browsers or email clients. For longer templates, consider using a link to a pre-written draft instead.' }
    },
    {
      '@type': 'Question',
      name: 'Can I add multiple recipients to a mailto link?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. Separate multiple email addresses with commas in the To, CC, or BCC fields. For example: mailto:one@example.com,two@example.com.' }
    },
    {
      '@type': 'Question',
      name: 'How do I use a mailto link on my website?',
      acceptedAnswer: { '@type': 'Answer', text: 'Copy the generated HTML code and paste it into your website\'s source. The link will appear as clickable text that opens the visitor\'s email client when clicked.' }
    }
  ]
}
---

<BaseLayout
  title="Free Mailto Link Generator | Create Pre-Filled Email Links"
  description="Generate mailto links with pre-filled subject, body, CC, and BCC fields. Copy as a link or HTML code for your website. Free, no signup required."
  keywords="mailto link generator, mailto link builder, create mailto link, email link generator, html email link, mailto with subject, mailto with body, pre-filled email link"
  image="/tools/tools-page-launch.png"
  url="https://naurra.ai/tools/mailto-link-generator"
  structuredData={[breadcrumbSchema, structuredData, faqData]}
>

<style>
  .tool-page { font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif; }
  .tool-page h1, .tool-page h2, .tool-page .font-display { font-family: 'Sora', sans-serif; font-weight: 800; letter-spacing: -0.04em; }
  .tool-page .font-mono { font-family: 'JetBrains Mono', monospace; }

  .noise-bg::before {
    content: '';
    position: fixed;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  .tool-input {
    width: 100%;
    min-height: 46px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    transition: all 0.2s;
    outline: none;
  }
  .tool-input:focus {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
  .tool-input::placeholder { color: rgba(255,255,255,0.25); }

  .tool-textarea {
    width: 100%;
    min-height: 100px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #f1f5f9;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    transition: all 0.2s;
    outline: none;
    resize: vertical;
  }
  .tool-textarea:focus {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
  .tool-textarea::placeholder { color: rgba(255,255,255,0.25); }

  .tool-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 6px;
  }

  .surface-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    padding: 28px;
    backdrop-filter: blur(12px);
  }

  .copy-btn {
    padding: 12px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    letter-spacing: 0.02em;
  }
  .copy-btn:hover { transform: translateY(-1px); }
  .copy-btn:active { transform: translateY(0); }

  .copy-btn-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
  }
  .copy-btn-primary:hover { box-shadow: 0 6px 28px rgba(16, 185, 129, 0.4); }

  .copy-btn-secondary {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .copy-btn-secondary:hover { background: rgba(255,255,255,0.1); color: white; }

  .preview-output {
    width: 100%;
    padding: 14px 16px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: #34d399;
    word-break: break-all;
    line-height: 1.6;
    min-height: 60px;
  }

  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #10b981;
    color: white;
    padding: 14px 28px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    box-shadow: 0 8px 32px rgba(16, 185, 129, 0.4);
    z-index: 1000;
    opacity: 0;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(16,185,129,0.2), transparent);
    margin: 20px 0;
  }

  .faq-item { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .faq-q {
    width: 100%;
    text-align: left;
    padding: 20px 0;
    background: none;
    border: none;
    color: #f1f5f9;
    font-family: 'Sora', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-q:hover { color: #10b981; }
  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    color: rgba(255,255,255,0.6);
    font-size: 15px;
    line-height: 1.7;
  }
  .faq-a.open { max-height: 300px; padding-bottom: 20px; }
  .faq-chevron { transition: transform 0.3s; width: 20px; height: 20px; flex-shrink: 0; }
  .faq-chevron.open { transform: rotate(180deg); }

  .preset-btn {
    padding: 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
    color: white;
  }
  .preset-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(16,185,129,0.28);
    background: rgba(16,185,129,0.06);
  }

  .top-shell {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .seo-copy {
    max-width: 900px;
    margin: 0 auto 32px;
    color: rgba(255,255,255,0.64);
    font-size: 16px;
    line-height: 1.8;
  }
  .seo-copy strong { color: #f1f5f9; font-weight: 700; }

  .insight-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 18px;
    padding: 24px;
    backdrop-filter: blur(10px);
  }

  @media (max-width: 1024px) {
    .tool-grid { flex-direction: column !important; }
    .tool-form, .tool-preview { width: 100% !important; }
    .tool-preview > div { position: static !important; }
    .insight-grid { grid-template-columns: 1fr !important; }
  }

  @media (max-width: 768px) {
    .top-shell { padding: 0 16px; }
    .hero-section { padding: 28px 0 28px; text-align: left; }
    .hero-section p { font-size: 16px !important; margin: 0 !important; max-width: none !important; }
    .feature-pills { justify-content: flex-start; margin-top: 18px; gap: 10px; }
    .surface-card { padding: 18px; border-radius: 18px; }
    .action-row { flex-direction: column; }
    .copy-btn, .action-row > a { width: 100%; text-align: center; justify-content: center; }
    .seo-copy { font-size: 15px; margin-bottom: 24px; }
    .toast { left: 16px; right: 16px; bottom: 16px; transform: translateY(100px); text-align: center; padding: 14px 18px; }
    .toast.show { transform: translateY(0); }
  }

  @media (max-width: 560px) {
    .hero-section h1 { font-size: clamp(30px, 12vw, 42px) !important; line-height: 1.02 !important; margin-bottom: 14px !important; }
    .hero-section h1 br { display: none; }
    .surface-card { padding: 16px; }
    .copy-btn { padding: 13px 18px; }
  }
</style>

<div class="tool-page noise-bg" style="min-height: 100vh; background: #0a0e1a; position: relative;">
  <!-- Ambient glow -->
  <div style="position: fixed; inset: 0; pointer-events: none; z-index: 0;">
    <div style="position: absolute; top: -20%; left: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%); border-radius: 50%;"></div>
    <div style="position: absolute; bottom: -10%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(245,158,11,0.04) 0%, transparent 70%); border-radius: 50%;"></div>
  </div>

  <div class="top-shell">
    <!-- Header -->
    <header style="padding: 32px 0 16px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
      <a href="/" style="display: flex; align-items: center; gap: 12px; text-decoration: none;">
        <img src="/logo-transparent.png" alt="Naurra.ai" style="width: 36px; height: 36px; object-fit: contain;" />
        <span class="font-display" style="font-size: 20px; background: linear-gradient(135deg, #10b981, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Naurra.ai</span>
      </a>
      <nav style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap; justify-content: flex-end;">
        <a href="/tools" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">All Tools</a>
        <a href="/blog" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Blog</a>
        <a href="/pricing" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Pricing</a>
        <a href="/" style="padding: 8px 20px; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); border-radius: 8px; color: #10b981; text-decoration: none; font-size: 13px; font-weight: 600; transition: all 0.2s;" onmouseover="this.style.background='rgba(16,185,129,0.2)'" onmouseout="this.style.background='rgba(16,185,129,0.12)'">Try Naurra Free</a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="hero-section" style="text-align: center; padding: 48px 0 40px;">
      <div style="display: inline-block; padding: 6px 16px; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 100px; margin-bottom: 20px;">
        <span style="font-size: 12px; font-weight: 600; color: #10b981; letter-spacing: 0.08em; text-transform: uppercase;">Free Tool -- No Signup Required</span>
      </div>
      <h1 style="font-family: 'Sora', sans-serif; font-size: clamp(32px, 5vw, 52px); font-weight: 800; color: #f1f5f9; margin: 0 0 16px; line-height: 1.15; letter-spacing: -0.04em;">
        Mailto Link<br/>
        <span style="background: linear-gradient(135deg, #10b981, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Generator</span>
      </h1>
      <p style="font-size: 18px; color: rgba(255,255,255,0.5); max-width: 560px; margin: 0 auto; line-height: 1.6; font-weight: 400;">
        Build pre-filled email links with subject, body, CC, and BCC. Perfect for websites, newsletters, and support pages.
      </p>
      <div class="feature-pills" style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 24px;">
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Live preview</div>
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Copy as link or HTML</div>
        <div style="padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); font-size: 13px; color: rgba(255,255,255,0.62);">Works everywhere</div>
      </div>
    </section>

    <!-- SEO Intro -->
    <section class="seo-copy">
      <p style="margin: 0 0 14px;">
        A <strong>mailto link</strong> opens the user's default email client with pre-filled fields. Use this <strong>mailto link generator</strong> to create links for your website's contact page, newsletter CTAs, or customer support buttons without writing any code.
      </p>
      <p style="margin: 0;">
        Pair it with a professional email signature from our <a href="/tools/email-signature" style="color: #10b981; text-decoration: none; font-weight: 600;">free Gmail signature generator</a> to make every email look polished from the first click.
      </p>
    </section>

    <!-- Presets -->
    <section style="margin-bottom: 24px;">
      <label class="tool-label" style="margin-bottom: 12px;">Quick presets</label>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;">
        <button class="preset-btn" data-preset="support">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">Customer Support</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">Pre-filled support request</div>
        </button>
        <button class="preset-btn" data-preset="feedback">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">Feedback Request</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">Ask for product feedback</div>
        </button>
        <button class="preset-btn" data-preset="meeting">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">Meeting Request</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">Schedule a call or meeting</div>
        </button>
        <button class="preset-btn" data-preset="sales">
          <div style="font-size: 13px; font-weight: 700; margin-bottom: 4px;">Sales Inquiry</div>
          <div style="font-size: 12px; color: rgba(255,255,255,0.4);">Product pricing question</div>
        </button>
      </div>
    </section>

    <!-- Main Tool Area -->
    <div class="tool-grid" style="display: flex; gap: 24px; padding-bottom: 48px;">

      <!-- Form -->
      <div class="tool-form" style="flex: 1; min-width: 0;">
        <div class="surface-card">
          <div style="display: grid; gap: 14px; margin-bottom: 20px;">
            <div>
              <label class="tool-label" for="mailto-to">To (email address) *</label>
              <input type="email" id="mailto-to" class="tool-input" placeholder="hello@company.com" />
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;">
              <div>
                <label class="tool-label" for="mailto-cc">CC</label>
                <input type="text" id="mailto-cc" class="tool-input" placeholder="cc@company.com" />
              </div>
              <div>
                <label class="tool-label" for="mailto-bcc">BCC</label>
                <input type="text" id="mailto-bcc" class="tool-input" placeholder="bcc@company.com" />
              </div>
            </div>
            <div>
              <label class="tool-label" for="mailto-subject">Subject</label>
              <input type="text" id="mailto-subject" class="tool-input" placeholder="I'd like to learn more about..." />
            </div>
            <div>
              <label class="tool-label" for="mailto-body">Body</label>
              <textarea id="mailto-body" class="tool-textarea" placeholder="Hi there,&#10;&#10;I'm reaching out because..."></textarea>
            </div>
          </div>

          <div class="section-divider"></div>

          <!-- Link Text -->
          <div style="margin-bottom: 20px;">
            <label class="tool-label" for="mailto-linktext">Link text (for HTML output)</label>
            <input type="text" id="mailto-linktext" class="tool-input" placeholder="Email us" value="Email us" />
          </div>

          <!-- Action Buttons -->
          <div class="action-row" style="display: flex; gap: 12px; flex-wrap: wrap;">
            <button id="btn-copy-link" class="copy-btn copy-btn-primary" style="display: flex; align-items: center; gap: 8px;">
              <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
              Copy Mailto Link
            </button>
            <button id="btn-copy-html" class="copy-btn copy-btn-secondary" style="display: flex; align-items: center; gap: 8px;">
              <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
              Copy HTML Code
            </button>
            <button id="btn-test" class="copy-btn copy-btn-secondary" style="display: flex; align-items: center; gap: 8px;">
              <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
              Test Link
            </button>
          </div>
        </div>
      </div>

      <!-- Preview -->
      <div class="tool-preview" style="width: 420px; flex-shrink: 0;">
        <div style="position: sticky; top: 100px;">
          <div class="surface-card">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
              <span style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.45);">Mailto Link</span>
              <span id="char-count" style="font-size: 11px; color: rgba(255,255,255,0.3); font-family: 'JetBrains Mono', monospace;">0 chars</span>
            </div>
            <div id="preview-link" class="preview-output">mailto:</div>
          </div>

          <div class="surface-card" style="margin-top: 16px;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
              <span style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.45);">HTML Code</span>
            </div>
            <div id="preview-html" class="preview-output" style="color: #fbbf24;">&lt;a href="mailto:"&gt;Email us&lt;/a&gt;</div>
          </div>

          <div class="surface-card" style="margin-top: 16px;">
            <span style="font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.45); display: block; margin-bottom: 12px;">Preview</span>
            <div style="background: #ffffff; border-radius: 8px; padding: 20px; text-align: center;">
              <a id="preview-rendered" href="mailto:" style="color: #10b981; font-size: 16px; font-weight: 600; text-decoration: underline; font-family: -apple-system, sans-serif;">Email us</a>
            </div>
