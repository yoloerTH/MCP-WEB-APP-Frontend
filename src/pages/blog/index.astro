---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { blogPosts, getFeaturedPosts, getPillarPosts, getAllCategories, getAllTags } from '../../data/blogPosts'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://naurra.ai/blog' }
  ]
}

const blogCollectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Naurra.ai Blog',
  description: 'AI workspace automation insights, voice AI tutorials, and productivity guides from Naurra.ai.',
  url: 'https://naurra.ai/blog',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: blogPosts.slice(0, 20).map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `https://naurra.ai/blog/${post.slug}`,
      name: post.title
    }))
  }
}

const categories = getAllCategories()
const tags = getAllTags()
const featuredPosts = getFeaturedPosts()
const pillarPosts = getPillarPosts()
const totalPosts = blogPosts.length
---

<BaseLayout
  title="Blog - Naurra.ai | AI Workspace Automation Insights & Tutorials"
  description="Explore expert articles on AI workspace automation, productivity tips, Google Workspace optimization, and voice AI tutorials. Stay ahead with Naurra.ai's latest insights."
  keywords="AI blog, workspace automation articles, productivity tips, Google Workspace tutorials, voice AI guides, AI assistant insights"
  url="https://naurra.ai/blog"
  structuredData={[breadcrumbSchema, blogCollectionSchema]}
>
  <div class="min-h-screen bg-[#0a0e1a] text-white overflow-hidden">

    <!-- Background Orbs -->
    <div class="fixed inset-0 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-amber-500/5"></div>
      <div class="absolute top-0 -right-1/4 w-[800px] h-[800px] bg-emerald-500/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 -left-1/4 w-[800px] h-[800px] bg-amber-500/10 rounded-full blur-[120px]"></div>
    </div>

    <!-- Sticky Nav Header -->
    <nav class="relative border-b border-emerald-500/10 bg-[#0a0e1a]/95 sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div class="relative w-10 h-10 flex items-center justify-center">
            <div class="absolute inset-0 bg-emerald-500/20 blur-xl rounded-full group-hover:bg-emerald-500/30 transition-all"></div>
            <img src="/logo-transparent.png" alt="Naurra.ai" class="w-full h-full object-contain relative z-10" />
          </div>
          <span class="font-display text-xl tracking-tight bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">
            Naurra.ai
          </span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/contact" class="text-sm text-amber-400 hover:text-amber-300 transition-colors font-semibold">
            Contact
          </a>
          <a href="/" class="text-sm text-emerald-300 hover:text-emerald-200 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Home
          </a>
        </div>
      </div>
    </nav>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-24">

      <!-- Hero Section -->
      <div class="mb-20 text-center fade-in">
        <div class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-emerald-500/10 to-amber-500/10 border border-emerald-500/20 rounded-full mb-8">
          <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
          <span class="text-xs font-mono uppercase tracking-widest text-emerald-300">AI Insights & Guides</span>
        </div>

        <h1 class="font-display text-6xl lg:text-7xl xl:text-8xl mb-8 tracking-tight leading-[0.9]">
          <span class="block text-white mb-2">The Naurra</span>
          <span class="block bg-gradient-to-r from-emerald-400 via-emerald-300 to-amber-400 bg-clip-text text-transparent">
            Intelligence Hub
          </span>
        </h1>

        <p class="text-xl text-gray-400 max-w-3xl mx-auto leading-relaxed">
          Discover cutting-edge AI strategies, workspace automation secrets, and productivity insights that transform how you work.
        </p>
      </div>

      <!-- Search & Filters -->
      <div class="mb-16 fade-in" style="animation-delay: 0.2s;">

        <!-- Search Bar -->
        <div class="relative max-w-2xl mx-auto mb-10">
          <div class="relative">
            <input
              id="blog-search"
              type="text"
              placeholder="Search articles, topics, or keywords..."
              class="w-full px-6 py-4 pl-14 bg-white/5 border border-white/10 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/20 transition-all"
            />
            <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
        </div>

        <!-- Category Pills -->
        <div class="flex flex-wrap items-center justify-center gap-3 mb-6" id="category-filters">
          <button
            data-category=""
            class="category-pill active px-5 py-2.5 rounded-xl font-medium text-sm transition-all bg-gradient-to-r from-emerald-500 to-emerald-600 text-white shadow-lg shadow-emerald-500/30"
          >
            All Posts
          </button>
          {categories.map((category) => (
            <button
              data-category={category}
              class="category-pill px-5 py-2.5 rounded-xl font-medium text-sm transition-all bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10"
            >
              {category}
            </button>
          ))}
        </div>

        <!-- Tag Pills -->
        {tags.length > 0 && (
          <div class="flex flex-wrap items-center justify-center gap-2" id="tag-filters">
            {tags.map((tag) => (
              <button
                data-tag={tag}
                class="tag-pill px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-white/5 text-gray-500 hover:bg-white/10 hover:text-gray-400 border border-white/5"
              >
                #{tag}
              </button>
            ))}
          </div>
        )}

        <!-- Active Filters Indicator (hidden by default) -->
        <div id="active-filters" class="hidden flex items-center justify-center gap-3 mt-6">
          <span class="text-sm text-gray-500">Active filters:</span>
          <button
            id="clear-all-filters"
            class="text-sm text-emerald-400 hover:text-emerald-300 transition-colors flex items-center gap-1"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Clear all
          </button>
        </div>
      </div>

      <!-- Core Guides (Pillar Posts) Section -->
      <div class="mb-20 fade-in" style="animation-delay: 0.25s;">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-1 h-8 bg-gradient-to-b from-violet-500 to-emerald-500 rounded-full"></div>
          <h2 class="font-display text-3xl lg:text-4xl text-white">Core Guides</h2>
        </div>
        <p class="text-gray-500 text-sm mb-8 ml-5">In-depth pillar articles that cover each topic end-to-end. Start here.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {pillarPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group relative block">
              <div class="relative bg-gradient-to-br from-violet-900/20 to-emerald-900/20 border border-violet-500/20 rounded-2xl overflow-hidden hover:border-emerald-500/30 transition-all duration-300">
                <!-- Pillar Badge -->
                <div class="absolute top-5 right-5 z-10">
                  <div class="px-3 py-1.5 bg-gradient-to-r from-violet-500 to-emerald-500 rounded-full text-xs font-bold text-white shadow-lg shadow-violet-500/20">
                    CORE GUIDE
                  </div>
                </div>

                <div class="p-7 lg:p-8">
                  <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-violet-500/10 border border-violet-500/20 rounded-full mb-5">
                    <div class="w-1.5 h-1.5 rounded-full bg-violet-400"></div>
                    <span class="text-xs font-mono uppercase tracking-wider text-violet-300">{post.category}</span>
                  </div>

                  <h3 class="font-display text-xl lg:text-2xl text-white mb-3 leading-tight group-hover:text-emerald-300 transition-colors duration-300">
                    {post.title}
                  </h3>

                  <p class="text-gray-400 text-sm mb-5 leading-relaxed line-clamp-2">
                    {post.description}
                  </p>

                  <div class="flex items-center gap-5 text-xs text-gray-500">
                    <span>{post.readingTime} min read</span>
                    <span class="flex items-center gap-1.5">
                      <div class="w-1 h-1 rounded-full bg-emerald-400"></div>
                      Pillar Article
                    </span>
                  </div>
                </div>

                <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-violet-500 to-emerald-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Featured Posts Section -->
      <div id="featured-section" class="mb-20 fade-in" style="animation-delay: 0.3s;">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-8 bg-gradient-to-b from-emerald-500 to-amber-500 rounded-full"></div>
          <h2 class="font-display text-3xl lg:text-4xl text-white">Featured Articles</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {featuredPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group relative block">
              <div class="relative bg-gradient-to-br from-gray-800/60 to-gray-900/60 border border-gray-700/50 rounded-3xl overflow-hidden hover:border-emerald-500/30 transition-all duration-300">
                <!-- Featured Badge -->
                <div class="absolute top-6 right-6 z-10">
                  <div class="px-3 py-1.5 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full text-xs font-bold text-white shadow-lg shadow-amber-500/30">
                    FEATURED
                  </div>
                </div>

                <div class="p-8 lg:p-10">
                  <!-- Category -->
                  <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full mb-6">
                    <div class="w-1.5 h-1.5 rounded-full bg-emerald-400"></div>
                    <span class="text-xs font-mono uppercase tracking-wider text-emerald-300">{post.category}</span>
                  </div>

                  <!-- Title -->
                  <h3 class="font-display text-2xl lg:text-3xl text-white mb-4 leading-tight group-hover:text-emerald-300 transition-colors duration-300">
                    {post.title}
                  </h3>

                  <!-- Description -->
                  <p class="text-gray-400 mb-6 leading-relaxed line-clamp-2">
                    {post.description}
                  </p>

                  <!-- Tags -->
                  <div class="flex flex-wrap gap-2 mb-6">
                    {post.tags.slice(0, 3).map((tag) => (
                      <span class="px-2.5 py-1 bg-white/5 border border-white/10 rounded-lg text-xs text-gray-500">
                        #{tag}
                      </span>
                    ))}
                  </div>

                  <!-- Meta Info -->
                  <div class="flex items-center gap-6 text-sm text-gray-500">
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      <span>{new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span>{post.readingTime} min read</span>
                    </div>
                  </div>
                </div>

                <!-- Hover indicator -->
                <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-emerald-500 to-amber-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- All Posts Grid -->
      <div class="fade-in" style="animation-delay: 0.4s;">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-8 bg-gradient-to-b from-emerald-500 to-amber-500 rounded-full"></div>
          <h2 id="posts-heading" class="font-display text-3xl lg:text-4xl text-white">All Articles</h2>
          <span id="posts-count" class="text-gray-500 text-lg">({totalPosts})</span>
        </div>

        <!-- No Results Message (hidden by default) -->
        <div id="no-results" class="hidden text-center py-20">
          <div class="w-20 h-20 bg-gray-800/50 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-display text-white mb-3">No articles found</h3>
          <p class="text-gray-500 mb-6">Try adjusting your search or filters</p>
          <button
            id="no-results-clear"
            class="px-6 py-3 bg-gradient-to-r from-emerald-500 to-emerald-600 text-white rounded-xl font-medium hover:shadow-lg hover:shadow-emerald-500/30 transition-all"
          >
            Clear filters
          </button>
        </div>

        <!-- Posts Grid -->
        <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {blogPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="post-card group relative block"
              data-slug={post.slug}
              data-title={post.title.toLowerCase()}
              data-description={post.description.toLowerCase()}
              data-category={post.category}
              data-tags={post.tags.map(t => t.toLowerCase()).join(',')}
            >
              <div class={`relative h-full bg-gradient-to-br from-gray-800/50 to-gray-900/50 border ${post.isPillar ? 'border-violet-500/25' : 'border-gray-700/50'} rounded-2xl overflow-hidden hover:border-emerald-500/30 transition-all duration-300 flex flex-col`}>
                {post.isPillar && (
                  <div class="absolute top-4 right-4 z-10">
                    <div class="px-2 py-1 bg-gradient-to-r from-violet-500/80 to-emerald-500/80 rounded-md text-[10px] font-bold text-white uppercase tracking-wider">
                      Core Guide
                    </div>
                  </div>
                )}
                <div class="p-6 flex-1 flex flex-col">
                  <!-- Category & Reading Time -->
                  <div class="flex items-center justify-between mb-4">
                    <div class={`inline-flex items-center gap-1.5 px-2.5 py-1 ${post.isPillar ? 'bg-violet-500/10 border-violet-500/20' : 'bg-emerald-500/10 border-emerald-500/20'} border rounded-lg`}>
                      <div class={`w-1 h-1 rounded-full ${post.isPillar ? 'bg-violet-400' : 'bg-emerald-400'}`}></div>
                      <span class={`text-xs font-mono uppercase tracking-wider ${post.isPillar ? 'text-violet-300' : 'text-emerald-300'}`}>{post.category}</span>
                    </div>
                    <span class="text-xs text-gray-500">{post.readingTime} min</span>
                  </div>

                  <!-- Title -->
                  <h3 class="font-display text-xl text-white mb-3 leading-tight group-hover:text-emerald-300 transition-colors duration-300 line-clamp-2">
                    {post.title}
                  </h3>

                  <!-- Description -->
                  <p class="text-sm text-gray-400 mb-4 leading-relaxed line-clamp-3 flex-1">
                    {post.description}
                  </p>

                  <!-- Tags -->
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {post.tags.slice(0, 2).map((tag) => (
                      <span class="px-2 py-0.5 bg-white/5 border border-white/10 rounded text-xs text-gray-500">
                        #{tag}
                      </span>
                    ))}
                    {post.tags.length > 2 && (
                      <span class="px-2 py-0.5 text-xs text-gray-600">
                        +{post.tags.length - 2}
                      </span>
                    )}
                  </div>

                  <!-- Meta Info -->
                  <div class="flex items-center gap-3 text-xs text-gray-500 pt-4 border-t border-gray-700/50">
                    <span>{new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                    <span>&bull;</span>
                    <span>{post.author.name}</span>
                  </div>
                </div>

                <!-- Hover indicator -->
                <div class="h-0.5 bg-gradient-to-r from-emerald-500 to-amber-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA Section -->
      <div class="mt-32 relative fade-in" style="animation-delay: 0.5s;">
        <div class="relative bg-gradient-to-br from-gray-800/60 to-gray-900/60 border border-gray-700/50 rounded-3xl p-12 lg:p-16 text-center">
          <h2 class="font-display text-4xl lg:text-5xl text-white mb-6">
            Ready to Transform Your Workspace?
          </h2>
          <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
            Experience the power of AI-driven workspace automation. Start your free 3-day trial today.
          </p>
          <a
            href="/pricing"
            class="group relative inline-flex px-8 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 text-white font-bold text-lg rounded-xl shadow-lg shadow-emerald-500/30 hover:shadow-emerald-500/50 transition-all duration-300 overflow-hidden"
          >
            <div class="absolute inset-0 bg-gradient-to-r from-emerald-400 to-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="relative flex items-center gap-2">
              Start Free Trial
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="relative border-t border-gray-700/50 bg-[#0a0e1a] mt-32">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-3">
            <img src="/logo-transparent.png" alt="Naurra.ai" class="w-8 h-8" loading="lazy" />
            <span class="font-display text-lg bg-gradient-to-r from-emerald-400 to-amber-400 bg-clip-text text-transparent">
              Naurra.ai
            </span>
          </div>
          <p class="text-gray-500 text-sm">
            &copy; 2026 Naurra.ai. Transforming workspaces with AI.
          </p>
        </div>
      </div>
    </footer>
  </div>

  <!-- Search & Filter Script (vanilla JS) -->
  <script is:inline>
    (function() {
      var searchInput = document.getElementById('blog-search');
      var categoryButtons = document.querySelectorAll('.category-pill');
      var tagButtons = document.querySelectorAll('.tag-pill');
      var postCards = document.querySelectorAll('.post-card');
      var featuredSection = document.getElementById('featured-section');
      var activeFiltersBar = document.getElementById('active-filters');
      var clearAllBtn = document.getElementById('clear-all-filters');
      var noResultsClearBtn = document.getElementById('no-results-clear');
      var noResultsEl = document.getElementById('no-results');
      var postsGrid = document.getElementById('posts-grid');
      var postsHeading = document.getElementById('posts-heading');
      var postsCount = document.getElementById('posts-count');

      var currentCategory = '';
      var currentTag = '';
      var currentSearch = '';

      function applyFilters() {
        var query = currentSearch.toLowerCase().trim();
        var visibleCount = 0;

        postCards.forEach(function(card) {
          var title = card.getAttribute('data-title') || '';
          var description = card.getAttribute('data-description') || '';
          var category = card.getAttribute('data-category') || '';
          var tags = card.getAttribute('data-tags') || '';

          var matchesSearch = !query ||
            title.indexOf(query) !== -1 ||
            description.indexOf(query) !== -1 ||
            tags.indexOf(query) !== -1;

          var matchesCategory = !currentCategory || category === currentCategory;
          var matchesTag = !currentTag || tags.split(',').indexOf(currentTag.toLowerCase()) !== -1;

          if (matchesSearch && matchesCategory && matchesTag) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // Update count
        postsCount.textContent = '(' + visibleCount + ')';

        // Update heading
        var hasFilters = currentSearch || currentCategory || currentTag;
        postsHeading.textContent = hasFilters ? 'Search Results' : 'All Articles';

        // Toggle featured section
        if (featuredSection) {
          featuredSection.style.display = hasFilters ? 'none' : '';
        }

        // Toggle active filters bar
        if (activeFiltersBar) {
          if (hasFilters) {
            activeFiltersBar.classList.remove('hidden');
            activeFiltersBar.classList.add('flex');
          } else {
            activeFiltersBar.classList.add('hidden');
            activeFiltersBar.classList.remove('flex');
          }
        }

        // Toggle no results / grid
        if (visibleCount === 0) {
          noResultsEl.classList.remove('hidden');
          postsGrid.style.display = 'none';
        } else {
          noResultsEl.classList.add('hidden');
          postsGrid.style.display = '';
        }
      }

      function clearFilters() {
        currentSearch = '';
        currentCategory = '';
        currentTag = '';
        searchInput.value = '';

        // Reset category pills
        categoryButtons.forEach(function(btn) {
          var cat = btn.getAttribute('data-category');
          if (cat === '' || cat === null) {
            btn.className = 'category-pill active px-5 py-2.5 rounded-xl font-medium text-sm transition-all bg-gradient-to-r from-emerald-500 to-emerald-600 text-white shadow-lg shadow-emerald-500/30';
          } else {
            btn.className = 'category-pill px-5 py-2.5 rounded-xl font-medium text-sm transition-all bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10';
          }
        });

        // Reset tag pills
        tagButtons.forEach(function(btn) {
          btn.className = 'tag-pill px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-white/5 text-gray-500 hover:bg-white/10 hover:text-gray-400 border border-white/5';
        });

        applyFilters();
      }

      // Search input handler
      if (searchInput) {
        // Pre-fill from ?q= URL param (powers Google sitelinks searchbox)
        var urlParams = new URLSearchParams(window.location.search);
        var initialQuery = urlParams.get('q');
        if (initialQuery) {
          searchInput.value = initialQuery;
          currentSearch = initialQuery;
          applyFilters();
        }

        searchInput.addEventListener('input', function() {
          currentSearch = this.value;
          applyFilters();
        });
      }

      // Category pill click handlers
      categoryButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var cat = this.getAttribute('data-category');
          currentCategory = cat || '';

          // Update pill styles
          categoryButtons.forEach(function(b) {
            var bCat = b.getAttribute('data-category');
            if (bCat === cat) {
              b.className = 'category-pill active px-5 py-2.5 rounded-xl font-medium text-sm transition-all bg-gradient-to-r from-emerald-500 to-emerald-600 text-white shadow-lg shadow-emerald-500/30';
            } else {
              b.className = 'category-pill px-5 py-2.5 rounded-xl font-medium text-sm transition-all bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10';
            }
          });

          applyFilters();
        });
      });

      // Tag pill click handlers
      tagButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var tag = this.getAttribute('data-tag');

          if (currentTag === tag) {
            // Deselect
            currentTag = '';
            this.className = 'tag-pill px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-white/5 text-gray-500 hover:bg-white/10 hover:text-gray-400 border border-white/5';
          } else {
            // Deselect previous
            tagButtons.forEach(function(b) {
              b.className = 'tag-pill px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-white/5 text-gray-500 hover:bg-white/10 hover:text-gray-400 border border-white/5';
            });
            // Select this one
            currentTag = tag;
            this.className = 'tag-pill px-3 py-1.5 rounded-lg text-xs font-medium transition-all bg-amber-500/20 text-amber-300 border border-amber-500/30';
          }

          applyFilters();
        });
      });

      // Clear all buttons
      if (clearAllBtn) {
        clearAllBtn.addEventListener('click', clearFilters);
      }
      if (noResultsClearBtn) {
        noResultsClearBtn.addEventListener('click', clearFilters);
      }
    })();
  </script>
</BaseLayout>
