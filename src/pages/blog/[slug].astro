---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogPostIsland from '../../components/islands/BlogPostIsland'
import { blogPosts, type BlogPost } from '../../data/blogPosts'

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props as { post: BlogPost }

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://naurra.ai/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://naurra.ai/blog' },
    { '@type': 'ListItem', position: 3, name: post.title, item: `https://naurra.ai/blog/${post.slug}` }
  ]
}

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  image: `https://naurra.ai${post.image}`,
  author: {
    '@type': 'Organization',
    name: 'Naurra AI Team',
    url: 'https://naurra.ai'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Naurra.ai',
    logo: {
      '@type': 'ImageObject',
      url: 'https://naurra.ai/logo-transparent.png'
    }
  },
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://naurra.ai/blog/${post.slug}`
  }
}
---

<BaseLayout
  title={`${post.title} - Naurra.ai Blog`}
  description={post.description}
  keywords={post.keywords}
  image={`https://naurra.ai${post.image}`}
  url={`https://naurra.ai/blog/${post.slug}`}
  type="article"
  publishedTime={post.publishedAt}
  modifiedTime={post.updatedAt}
  structuredData={[breadcrumbSchema, articleSchema]}
>
  <BlogPostIsland client:only="react" />
</BaseLayout>
